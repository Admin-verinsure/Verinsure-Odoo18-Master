<odoo>
    <record id="view_smart_form_logic_rule_list" model="ir.ui.view">
        <field name="name">smart.form.logic.rule.list</field>
        <field name="model">smart.form.logic.rule</field>
        <field name="arch" type="xml">
            <list string="Logic Rules">
                <field name="sequence" widget="handle"/>
                <field name="form_id"/>
                <field name="trigger_field_id"/>
                <field name="operator"/>
                <field name="value_text"/>
                <field name="action"/>
                <field name="target_field_id"/>
            </list>
        </field>
    </record>

    <record id="view_smart_form_logic_rule_form" model="ir.ui.view">
        <field name="name">smart.form.logic.rule.form</field>
        <field name="model">smart.form.logic.rule</field>
        <field name="arch" type="xml">
            <form string="Logic Rule">
                <sheet>
                    <group>
                        <group>
                            <field name="sequence"/>
                            <field name="form_id"/>
                            <field name="trigger_field_id"/>
                        </group>
                        <group>
                            <field name="operator"/>
                            <field name="value_text"/>
                            <field name="action"/>
                            <field name="target_field_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
