<odoo>

  <!-- ============================================================
       Standard submissions list (Submissions menu — all forms)
  ============================================================ -->
  <record id="view_smart_form_submission_list" model="ir.ui.view">
    <field name="name">smart.form.submission.list</field>
    <field name="model">smart.form.submission</field>
    <field name="arch" type="xml">
      <list default_order="create_date desc">
        <field name="create_date" string="Submitted On" widget="datetime"/>
        <field name="form_id" string="Form"/>
        <field name="key_value" string="Key Value" optional="show"/>
        <field name="ip" string="IP" optional="show"/>
        <field name="user_agent" string="Browser" optional="hide"/>
      </list>
    </field>
  </record>

  <!-- ============================================================
       Submissions TABLE view — one form at a time, per-form columns
       Opened from the "Submissions Table" menu (scoped by form via
       action domain) or from action_view_submissions_table on form.
       Rows are clickable → opens form detail view.
       Export button available via Odoo's built-in list export (⚙ Action > Export).
  ============================================================ -->
  <record id="view_smart_form_submission_table_list" model="ir.ui.view">
    <field name="name">smart.form.submission.table.list</field>
    <field name="model">smart.form.submission</field>
    <field name="arch" type="xml">
      <list string="Submissions Table"
            default_order="create_date desc"
            export_xlsx="1"
            multi_edit="0">
        <field name="create_date" string="Submitted On" widget="datetime"/>
        <field name="key_value" string="Key" decoration-bf="True"/>
        <field name="form_id" string="Form" optional="hide"/>
        <field name="ip" string="IP" optional="hide"/>
        <field name="data_json" string="Raw Data" optional="hide"/>
      </list>
    </field>
  </record>

  <!-- ============================================================
       Full submission detail (form view)
       Opened when clicking any row in either list view.
  ============================================================ -->
  <record id="view_smart_form_submission_form" model="ir.ui.view">
    <field name="name">smart.form.submission.form</field>
    <field name="model">smart.form.submission</field>
    <field name="arch" type="xml">
      <form string="Submission Detail">
        <sheet>
          <header>
            <button name="action_view_chain" type="object"
                    string="&#128279; View Submission Chain"
                    class="btn-primary"
                    invisible="not session_token or not child_submission_ids"/>
          </header>
          <group>
            <group>
              <field name="form_id" readonly="1"/>
              <field name="create_date" readonly="1" widget="datetime"/>
              <field name="key_value" readonly="1" string="Key Value"
                     invisible="not key_value"/>
              <field name="chain_depth" readonly="1" string="Chain Step"
                     invisible="chain_depth == 1 and not parent_submission_id"/>
              <field name="parent_submission_id" readonly="1"
                     invisible="not parent_submission_id"/>
            </group>
            <group>
              <field name="ip" readonly="1"/>
              <field name="user_agent" readonly="1"/>
            </group>
          </group>

          <separator string="Form Responses"/>
          <field name="response_html" readonly="1" widget="html" nolabel="1"/>

          <separator string="Raw JSON"/>
          <field name="data_json" widget="text" readonly="1" nolabel="1"/>
        </sheet>
      </form>
    </field>
  </record>

</odoo>
