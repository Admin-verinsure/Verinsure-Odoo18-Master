<odoo>
  <record id="view_smart_submission_list" model="ir.ui.view">
    <field name="name">smart.form.submission.list</field>
    <field name="model">smart.form.submission</field>
    <field name="type">list</field>
    <field name="arch" type="xml">
      <list>
        <field name="create_date"/>
        <field name="form_id"/>
      </list>
    </field>
  </record>

  <record id="view_smart_submission_form" model="ir.ui.view">
    <field name="name">smart.form.submission.form</field>
    <field name="model">smart.form.submission</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <group>
            <field name="form_id" readonly="1"/>
            <field name="create_date" readonly="1"/>
          </group>
          <group>
            <field name="data_json" readonly="1" widget="text"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>
</odoo>
