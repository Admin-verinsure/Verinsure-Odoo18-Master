<odoo>
  <record id="view_smart_form_list" model="ir.ui.view">
    <field name="name">smart.form.list</field>
    <field name="model">smart.form</field>
    <field name="arch" type="xml">
      <list>
        <field name="name"/>
        <field name="token"/>
        <field name="submission_count" string="Submissions"/>
        <field name="active"/>
        <field name="target_model_id" options="{'no_create': True}"/>
      </list>
    </field>
  </record>

  <record id="view_smart_form_form" model="ir.ui.view">
    <field name="name">smart.form.form</field>
    <field name="model">smart.form</field>
    <field name="arch" type="xml">
      <form>
        <header>
          <button name="action_open_preview" type="object" string="Preview" class="btn-primary"/>
          <button name="action_open_public" type="object" string="Open Public Link" class="btn-secondary"/>
          <button name="action_view_submissions" type="object" string="View Submissions" class="btn-secondary"/>
        </header>
        <sheet>
          <group>
            <group>
              <field name="name"/>
              <field name="active"/>
              <field name="target_model_id" options="{'no_create': True}"/>
            </group>
            <group>
              <field name="token" readonly="1"/>
              <field name="submission_count" readonly="1"/>
            </group>
          </group>

          <notebook>
            <page string="Fields">
              <field name="field_ids">
                <list editable="bottom">
                  <field name="sequence" widget="handle"/>
                  <field name="label"/>
                  <field name="field_type"/>
                  <field name="name" string="Technical Name"/>
                  <field name="required"/>
                  <field name="option_source"
                         invisible="field_type not in ('select','radio','checkbox')"/>
                  <button name="action_open_select_config"
                          type="object"
                          string="⚙ Options"
                          class="btn-link"
                          invisible="field_type not in ('select','radio','checkbox')"/>
                </list>
              </field>
            </page>

            <page string="Branching">
              <field name="branch_rule_ids">
                <list editable="bottom">
                  <field name="sequence" widget="handle"/>
                  <field name="trigger_field_id" context="{'default_form_id': id}"/>
                  <field name="operator"/>
                  <field name="value_text"/>
                  <field name="target_form_id"/>
                  <field name="fallback_form_id"/>
                </list>
              </field>
              <p class="text-muted mt-2">Branching evaluates rules in order. First match wins.</p>
            </page>

            <page string="Conditional Logic">
              <field name="logic_rule_ids">
                <list editable="bottom">
                  <field name="sequence" widget="handle"/>
                  <field name="trigger_field_id" context="{'default_form_id': id}"/>
                  <field name="operator"/>
                  <field name="value_text"/>
                  <field name="action"/>
                  <field name="target_field_id" context="{'default_form_id': id}"/>
                </list>
              </field>
              <p class="text-muted mt-2">Use rules to show/hide/require fields based on answers.</p>
            </page>

            <page string="Submissions">
              <field name="submission_ids" readonly="1">
                <list>
                  <field name="create_date" string="Submitted On" widget="datetime"/>
                  <field name="ip" string="IP Address"/>
                  <field name="user_agent" string="Browser"/>
                  <field name="target_model" string="Linked Model"/>
                </list>
              </field>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>
</odoo>
