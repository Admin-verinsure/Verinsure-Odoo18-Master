<odoo>
  <record id="view_smart_form_list" model="ir.ui.view">
    <field name="name">smart.form.list</field>
    <field name="model">smart.form</field>
    <field name="arch" type="xml">
      <list>
        <field name="name"/>
        <field name="token"/>
        <field name="submission_count" string="Submissions"/>
        <field name="key_field_label" string="Key Field" optional="show"/>
        <field name="active"/>
      </list>
    </field>
  </record>

  <record id="view_smart_form_form" model="ir.ui.view">
    <field name="name">smart.form.form</field>
    <field name="model">smart.form</field>
    <field name="arch" type="xml">
      <form>
        <header>
          <button name="action_open_preview" type="object" string="Preview" class="btn-primary"/>
          <button name="action_open_public" type="object" string="Open Public" class="btn-secondary"/>
          <button name="action_view_submissions" type="object" string="Submissions" class="btn-secondary"/>
          <button name="action_open_table_view" type="object" string="&#128202; Submissions Table"
                  class="btn-secondary"
                  invisible="submission_count == 0"/>
        </header>
        <sheet>
          <group>
            <field name="name"/>
            <field name="active"/>
            <field name="token" readonly="1"/>
            <field name="key_field_label" readonly="1" string="Key Field"
                   invisible="not key_field_label"/>
          </group>

          <notebook>
            <page string="Fields">
              <field name="field_ids">
                <list editable="bottom">
                  <field name="sequence" widget="handle"/>
                  <field name="label"/>
                  <field name="field_type"/>
                  <field name="required"/>
                  <field name="is_key_field" string="Key"
                         invisible="field_type == 'subheading'"
                         widget="boolean_toggle"/>
                  <field name="option_source"
                         invisible="field_type not in ('select','radio','checkbox')"/>
                  <button type="action" name="%(action_smart_form_select_config_wizard)d"
                          string="Configure" class="btn-link"
                          context="{'default_field_id': id}"
                          invisible="field_type not in ('select','radio','checkbox')"/>
                </list>
              </field>
              <p class="text-muted">
                Mark one field as <strong>Key</strong> — it labels each row in the
                Submissions Table (e.g. Email or Name).
              </p>
            </page>

            <page string="Branching">
              <field name="branch_rule_ids">
                <list editable="bottom">
                  <field name="sequence"/>
                  <field name="trigger_field_id" context="{'default_form_id': id}"/>
                  <field name="operator"/>
                  <field name="value_text"/>
                  <field name="target_form_id"/>
                  <field name="fallback_form_id"/>
                </list>
              </field>
              <p class="text-muted">Branching evaluates rules in order. First match wins.</p>
            </page>

            <page string="Logic">
              <field name="logic_rule_ids">
                <list editable="bottom">
                  <field name="sequence"/>
                  <field name="trigger_field_id" context="{'default_form_id': id}"/>
                  <field name="operator"/>
                  <field name="value_text"/>
                  <field name="action"/>
                  <field name="target_field_id" context="{'default_form_id': id}"/>
                </list>
              </field>
              <p class="text-muted">Use rules to show/hide/require fields based on answers.</p>
            </page>

            <page string="Submissions">
              <field name="submission_ids" readonly="1">
                <list default_order="create_date desc">
                  <field name="create_date" string="Submitted On" widget="datetime"/>
                  <field name="key_value" string="Key Value"/>
                  <field name="ip"/>
                  <field name="user_agent" optional="hide"/>
                </list>
              </field>
            </page>

          </notebook>
        </sheet>
      </form>
    </field>
  </record>
</odoo>
