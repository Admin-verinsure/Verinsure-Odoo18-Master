<odoo>
    <record id="view_res_config_settings_sfb" model="ir.ui.view">
        <field name="name">res.config.settings.sfb.form</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.action_general_configuration"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('settings')]" position="inside">
                <div class="app_settings_block"
                     data-string="Smart Form Builder"
                     string="Smart Form Builder"
                     data-key="smart_form_builder">
                    <h2>LDAP Enrichment</h2>
                    <div class="row mt16 o_settings_container" id="sfb_ldap_settings">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="sfb_ldap_enabled"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="sfb_ldap_enabled" string="Enable LDAP Enrichment"/>
                                <div class="text-muted">
                                    Look up submitter details via LDAP on form submit.
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-6 o_setting_box"
                             invisible="not sfb_ldap_enabled">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <field name="sfb_ldap_server_uri"
                                       placeholder="ldap://ldap.example.com:389"/>
                                <field name="sfb_ldap_bind_dn"
                                       placeholder="cn=admin,dc=example,dc=com"/>
                                <field name="sfb_ldap_bind_password"
                                       password="True"/>
                                <field name="sfb_ldap_base_dn"
                                       placeholder="dc=example,dc=com"/>
                                <field name="sfb_ldap_filter"/>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
