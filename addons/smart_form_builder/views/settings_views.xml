<odoo>
  <record id="view_res_config_settings_sfb" model="ir.ui.view">
    <field name="name">res.config.settings.sfb.form</field>
    <field name="model">res.config.settings</field>
    <field name="inherit_id" ref="base.res_config_settings_view_form"/>
    <field name="arch" type="xml">
      <xpath expr="//div[hasclass('settings')]" position="inside">
        <div class="app_settings_block" data-string="Forms" string="Forms">
          <h2>Forms - LDAP Enrichment</h2>
          <div class="row mt16 o_settings_container">
            <div class="col-12 col-lg-6 o_setting_box">
              <div class="o_setting_left_pane">
                <field name="sfb_ldap_enabled"/>
              </div>
              <div class="o_setting_right_pane">
                <label for="sfb_ldap_enabled"/>
                <div class="text-muted">Enable LDAP lookup on submit (match first name + last name + email).</div>
              </div>
            </div>

            <div class="col-12 col-lg-6 o_setting_box">
              <div class="o_setting_left_pane"/>
              <div class="o_setting_right_pane">
                <field name="sfb_ldap_server_uri" placeholder="ldap://ldap.example.com:389" invisible="not sfb_ldap_enabled"/>
                <field name="sfb_ldap_bind_dn" placeholder="cn=admin,dc=example,dc=com" invisible="not sfb_ldap_enabled"/>
                <field name="sfb_ldap_bind_password" password="True" invisible="not sfb_ldap_enabled"/>
                <field name="sfb_ldap_base_dn" placeholder="dc=example,dc=com" invisible="not sfb_ldap_enabled"/>
                <field name="sfb_ldap_filter" invisible="not sfb_ldap_enabled"/>
              </div>
            </div>
          </div>
        </div>
      </xpath>
    </field>
  </record>
</odoo>
