<odoo>
  <template id="smart_form_page" name="Smart Form Page">
    <t t-call="website.layout">
      <div class="container my-4">
        <h2 t-esc="form.name"/>
        <form action="/smart_form/submit" method="post" enctype="multipart/form-data" class="mt-3" id="smart-form">
          <input type="hidden" name="token" t-att-value="form.token"/>

          <t t-foreach="form.field_ids" t-as="f">
            <div class="mb-3">
              <label class="form-label">
                <span t-esc="f.label"/>
                <t t-if="f.required"><span class="text-danger">*</span></t>
              </label>

              <t t-if="f.field_type == 'text'">
                <input class="form-control" type="text"
                       t-att-name="f.name or ('field_%s' % f.id)"
                       t-att-required="'required' if f.required else None"/>
              </t>
              <t t-elif="f.field_type == 'textarea'">
                <textarea class="form-control"
                          t-att-name="f.name or ('field_%s' % f.id)"
                          t-att-required="'required' if f.required else None"></textarea>
              </t>
                            <t t-elif="f.field_type == 'select'">
                <div class="sfb-select-wrap" t-att-data-field-id="f.id">
                  <select class="form-select sfb-enhanced-select"
                          t-att-name="f.name or ('field_%s' % f.id)"
                          t-att-required="'required' if f.required else None">
                    <option value="">-- Select --</option>
                    <t t-foreach="f.get_options()" t-as="o">
                      <option t-att-value="o['value']"><t t-esc="o['label']"/></option>
                    </t>
                  </select>
                </div>
              </t>

<t t-elif="f.field_type == 'radio'">
                <t t-foreach="f.get_options()" t-as="o">
                  <div class="form-check">
                    <input class="form-check-input" type="radio"
                           t-att-name="f.name or ('field_%s' % f.id)"
                           t-att-value="o['value']"/>
                    <label class="form-check-label"><t t-esc="o['label']"/></label>
                  </div>
                </t>
              </t>
              <t t-elif="f.field_type == 'checkbox'">
                <t t-foreach="f.get_options()" t-as="o">
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox"
                           t-att-name="(f.name or ('field_%s' % f.id)) + '[]'"
                           t-att-value="o['value']"/>
                    <label class="form-check-label"><t t-esc="o['label']"/></label>
                  </div>
                </t>
              </t>
              <t t-elif="f.field_type == 'file'">
                <input class="form-control" type="file"
                       t-att-name="f.name or ('field_%s' % f.id)"/>
              </t>
            </div>
          </t>

          <button type="submit" class="btn btn-primary">Submit</button>
        </form>
      </div>
    </t>
  </template>

  <template id="smart_form_thanks" name="Smart Form Thanks">
    <t t-call="website.layout">
      <div class="container my-5">
        <h3>Thank you!</h3>
        <p>Your response has been submitted for <strong t-esc="form.name"/>.</p>
      </div>
    </t>
  </template>
</odoo>
