<odoo>
  <template id="smart_form_page" name="Forms Page">
    <t t-call="website.layout">
      <div class="container my-5">
        <div class="row justify-content-center">
          <div class="col-12 col-lg-8">
            <div class="card shadow-sm border-0">
              <div class="card-body p-4 p-md-5">

                <h2 class="mb-1" t-esc="form.name"/>
                <p class="text-muted mb-4">Please fill the form below.</p>

                <!-- ==================================================
                     FIELD LOGIC RULES JSON (VALID JSON ONLY)
                ================================================== -->
                <script type="application/json" id="sfb-rules-json">
<t t-raw="rules_json or '[]'"/>
                </script>

                <!-- ==================================================
                     FORM
                ================================================== -->
                <form action="/smart_form/submit"
                      method="post"
                      enctype="multipart/form-data"
                      id="smart-form">

                  <input type="hidden" name="token" t-att-value="form.token"/>

                  <!-- ================= FIELDS ================= -->
                  <t t-foreach="form.field_ids" t-as="f">
                    <t t-if="f.field_type == 'subheading'">
                      <div class="mt-4 mb-2">
                        <h5 class="mb-0" t-esc="f.label"/>
                      </div>
                    </t>
                    <t t-else="">
                      <div class="mb-3 sfb-field" t-att-data-field-id="f.id">
                        <label class="form-label">
                          <span t-esc="f.label"/>
                          <t t-if="f.required">
                            <span class="text-danger">*</span>
                          </t>
                        </label>

                        <t t-if="f.field_type == 'text'">
                          <input class="form-control" type="text"
                                 t-att-name="f.name or ('field_%s' % f.id)"
                                 t-att-data-field-id="f.id"/>
                        </t>

                        <t t-elif="f.field_type == 'email'">
                          <input class="form-control" type="email"
                                 t-att-name="f.name or ('field_%s' % f.id)"
                                 t-att-data-field-id="f.id"/>
                        </t>

                        <t t-elif="f.field_type == 'phone'">
                          <input class="form-control" type="tel"
                                 t-att-name="f.name or ('field_%s' % f.id)"
                                 t-att-data-field-id="f.id"/>
                        </t>

                        <t t-elif="f.field_type == 'number'">
                          <input class="form-control" type="number"
                                 t-att-name="f.name or ('field_%s' % f.id)"
                                 t-att-data-field-id="f.id"/>
                        </t>

                        <t t-elif="f.field_type == 'textarea'">
                          <textarea class="form-control" rows="4"
                                    t-att-name="f.name or ('field_%s' % f.id)"
                                    t-att-data-field-id="f.id"/>
                        </t>

                        <t t-elif="f.field_type == 'select'">
                          <select class="form-select"
                                  t-att-name="f.name or ('field_%s' % f.id)"
                                  t-att-data-field-id="f.id">
                            <option value="">-- Select --</option>
                            <t t-foreach="f.get_options()" t-as="o">
                              <option t-att-value="o['value']">
                                <t t-esc="o['label']"/>
                              </option>
                            </t>
                          </select>
                        </t>

                        <t t-elif="f.field_type == 'radio'">
                          <t t-foreach="f.get_options()" t-as="o">
                            <div class="form-check">
                              <input class="form-check-input" type="radio"
                                     t-att-name="f.name or ('field_%s' % f.id)"
                                     t-att-data-field-id="f.id"
                                     t-att-value="o['value']"/>
                              <label class="form-check-label">
                                <t t-esc="o['label']"/>
                              </label>
                            </div>
                          </t>
                        </t>

                        <t t-elif="f.field_type == 'checkbox'">
                          <t t-foreach="f.get_options()" t-as="o">
                            <div class="form-check">
                              <input class="form-check-input" type="checkbox"
                                     t-att-name="(f.name or ('field_%s' % f.id)) + '[]'"
                                     t-att-data-field-id="f.id"
                                     t-att-value="o['value']"/>
                              <label class="form-check-label">
                                <t t-esc="o['label']"/>
                              </label>
                            </div>
                          </t>
                        </t>

                        <t t-elif="f.field_type == 'file'">
                          <input class="form-control" type="file"
                                 t-att-name="f.name or ('field_%s' % f.id)"
                                 t-att-data-field-id="f.id"/>
                        </t>
                      </div>
                    </t>
                  </t>

                  <!-- ================= ACTION BUTTON ================= -->
                  <div class="d-grid mt-4">
                    <t t-if="has_branching">
                      <button type="button"
                              id="sfb-continue"
                              class="btn btn-primary btn-lg">
                        Continue
                      </button>
                    </t>
                    <t t-else="">
                      <button type="submit"
                              class="btn btn-primary btn-lg">
                        Submit
                      </button>
                    </t>
                  </div>

                </form>

                <!-- ==================================================
                     FIELD LOGIC JS (SHOW / HIDE) ✅ FINAL
                ================================================== -->
                <script type="text/javascript"><![CDATA[
                (function(){
                  function getRules(){
                    var el = document.getElementById("sfb-rules-json");
                    if(!el) return [];
                    try {
                      return JSON.parse(el.textContent.trim() || "[]");
                    } catch(e){
                      console.error("Field logic JSON error", e);
                      return [];
                    }
                  }

                  function nodes(fid){
                    return document.querySelectorAll(
                      'input[data-field-id="'+fid+'"],select[data-field-id="'+fid+'"],textarea[data-field-id="'+fid+'"]'
                    );
                  }

                  function wrap(fid){
                    return document.querySelector('.sfb-field[data-field-id="'+fid+'"]');
                  }

                  function valueOf(fid){
                    var els = nodes(fid);
                    if(!els.length) return "";

                    var first = els[0];

                    if(first.type === "radio"){
                      for(var i=0;i<els.length;i++){
                        if(els[i].checked) return els[i].value || "";
                      }
                      return "";
                    }

                    if(first.type === "checkbox"){
                      var vals=[];
                      els.forEach(function(x){
                        if(x.checked) vals.push(x.value || "true");
                      });
                      return vals;
                    }

                    return first.value || "";
                  }

                  function match(op,left,right){
                    var want = String(right||"").toLowerCase().trim();
                    var vals = Array.isArray(left) ? left : [left];
                    vals = vals.map(v => String(v||"").toLowerCase());

                    if(op === "contains" || op === "ilike" || op === "like"){
                      return vals.some(v => v.indexOf(want) !== -1);
                    }
                    if(op === "!="){
                      return vals.every(v => v !== want);
                    }
                    if(op === "in"){
                      return want.split(",").some(w => vals.includes(w.trim()));
                    }
                    return vals.includes(want);
                  }

                  var RULES = getRules();
                  if(!RULES.length) return;

                  RULES.forEach(function(r){
                    if(r.action === "show"){
                      var w = wrap(r.target);
                      if(w) w.style.display = "none";
                    }
                  });

                  function apply(){
                    RULES.forEach(function(r){
                      var ok = match(r.op, valueOf(r.trigger), r.value);
                      var w = wrap(r.target);
                      if(!w) return;

                      if(r.action === "show"){
                        w.style.display = ok ? "" : "none";
                      } else if(r.action === "hide"){
                        w.style.display = ok ? "none" : "";
                      }
                    });
                  }

                  var form = document.getElementById("smart-form");
                  if(!form) return;

                  form.addEventListener("input", apply, true);
                  form.addEventListener("change", apply, true);
                  apply();
                })();
                ]]></script>

                <!-- ==================================================
                     BRANCHING JS (BACKEND AUTHORITATIVE)
                ================================================== -->
                <t t-if="has_branching">
                  <script type="text/javascript"><![CDATA[
                  (function(){
                    function collect(){
                      var out={};
                      document.querySelectorAll(
                        'input[data-field-id],select[data-field-id],textarea[data-field-id]'
                      ).forEach(function(el){
                        var id = el.dataset.fieldId;
                        if(!id) return;

                        if(el.type==="radio"){
                          if(el.checked) out[id]=el.value||"";
                          return;
                        }
                        if(el.type==="checkbox"){
                          out[id]=out[id]||[];
                          if(el.checked) out[id].push(el.value||"true");
                          return;
                        }
                        out[id]=el.value||"";
                      });
                      return out;
                    }

                    var btn = document.getElementById("sfb-continue");
                    var form = document.getElementById("smart-form");
                    if(!btn || !form) return;

                    btn.addEventListener("click", function(){
                      var token = form.querySelector('input[name="token"]').value;

                      fetch("/smart_form/branching/"+encodeURIComponent(token),{
                        method:"POST",
                        headers:{"Content-Type":"application/json"},
                        body:JSON.stringify({answers:collect()}),
                        credentials:"same-origin"
                      })
                      .then(r => r.json())
                      .then(function(d){
                        if(d && d.next_token){
                          window.location.href="/smart_form/"+d.next_token;
                        } else {
                          form.submit();
                        }
                      });
                    });
                  })();
                  ]]></script>
                </t>

              </div>
            </div>
          </div>
        </div>
      </div>
    </t>
  </template>

  <template id="smart_form_thanks" name="Forms Thanks">
    <t t-call="website.layout">
      <div class="container my-5">
        <div class="row justify-content-center">
          <div class="col-12 col-lg-6">
            <div class="card shadow-sm border-0">
              <div class="card-body p-4 p-md-5 text-center">
                <h3 class="mb-2">Thank you!</h3>
                <p class="text-muted mb-0">Your response has been submitted.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </t>
  </template>
</odoo>
