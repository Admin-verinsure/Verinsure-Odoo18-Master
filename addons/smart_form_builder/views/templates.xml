<odoo>
  <template id="smart_form_page" name="Forms Page">
    <t t-call="website.layout">
      <div class="container my-5">
        <div class="row justify-content-center">
          <div class="col-12 col-lg-8">
            <div class="card shadow-sm border-0">
              <div class="card-body p-4 p-md-5">
                <h2 class="mb-1" t-esc="form.name"/>
                <p class="text-muted mb-4">Please fill the form below.</p>

                <!-- Rules JSON (must not be escaped) -->
                <script type="application/json" id="sfb-rules-json"><t t-raw="rules_json or '[]'"/></script>

                <form action="/smart_form/submit" method="post" enctype="multipart/form-data" id="smart-form">
                  <input type="hidden" name="token" t-att-value="form.token"/>

                  <t t-foreach="form.field_ids" t-as="f">
                    <t t-if="f.field_type == 'subheading'">
                      <div class="mt-4 mb-2">
                        <h5 class="mb-0" t-esc="f.label"/>
                      </div>
                    </t>
                    <t t-else="">
                      <div class="mb-3 sfb-field" t-att-data-field-id="f.id">
                        <label class="form-label">
                          <span t-esc="f.label"/>
                          <t t-if="f.required"><span class="text-danger">*</span></t>
                        </label>

                        <t t-if="f.field_type == 'text'">
                          <input class="form-control" type="text"
                                 t-att-name="f.name or ('field_%s' % f.id)"
                                 t-att-data-field-id="f.id"
                                 t-att-required="'required' if f.required else None"/>
                        </t>
                        <t t-elif="f.field_type == 'email'">
                          <input class="form-control" type="email"
                                 placeholder="name@example.com"
                                 t-att-name="f.name or ('field_%s' % f.id)"
                                 t-att-data-field-id="f.id"
                                 t-att-required="'required' if f.required else None"/>
                        </t>
                        <t t-elif="f.field_type == 'phone'">
                          <input class="form-control" type="tel"
                                 placeholder="+91 XXXXX XXXXX"
                                 t-att-name="f.name or ('field_%s' % f.id)"
                                 t-att-data-field-id="f.id"
                                 t-att-required="'required' if f.required else None"/>
                        </t>
                        <t t-elif="f.field_type == 'number'">
                          <input class="form-control" type="number"
                                 t-att-name="f.name or ('field_%s' % f.id)"
                                 t-att-data-field-id="f.id"
                                 t-att-required="'required' if f.required else None"/>
                        </t>
                        <t t-elif="f.field_type == 'textarea'">
                          <textarea class="form-control" rows="4"
                                    t-att-name="f.name or ('field_%s' % f.id)"
                                    t-att-data-field-id="f.id"
                                    t-att-required="'required' if f.required else None"></textarea>
                        </t>
                        <t t-elif="f.field_type == 'select'">
                          <div class="sfb-select-wrap">
                            <select class="form-select sfb-enhanced-select"
                                    t-att-name="f.name or ('field_%s' % f.id)"
                                    t-att-data-field-id="f.id"
                                    t-att-required="'required' if f.required else None">
                              <option value="">-- Select --</option>
                              <t t-foreach="f.get_options()" t-as="o">
                                <option t-att-value="o['value']"><t t-esc="o['label']"/></option>
                              </t>
                            </select>
                          </div>
                        </t>
                        <t t-elif="f.field_type == 'radio'">
                          <t t-foreach="f.get_options()" t-as="o">
                            <div class="form-check">
                              <input class="form-check-input" type="radio"
                                     t-att-name="f.name or ('field_%s' % f.id)"
                                     t-att-data-field-id="f.id"
                                     t-att-value="o['value']"/>
                              <label class="form-check-label"><t t-esc="o['label']"/></label>
                            </div>
                          </t>
                        </t>
                        <t t-elif="f.field_type == 'checkbox'">
                          <t t-foreach="f.get_options()" t-as="o">
                            <div class="form-check">
                              <input class="form-check-input" type="checkbox"
                                     t-att-name="(f.name or ('field_%s' % f.id)) + '[]'"
                                     t-att-data-field-id="f.id"
                                     t-att-value="o['value']"/>
                              <label class="form-check-label"><t t-esc="o['label']"/></label>
                            </div>
                          </t>
                        </t>
                        <t t-elif="f.field_type == 'file'">
                          <input class="form-control" type="file"
                                 t-att-name="f.name or ('field_%s' % f.id)"
                                 t-att-data-field-id="f.id"/>
                        </t>
                      </div>
                    </t>
                  </t>

                  <div class="d-grid mt-4">
                    <button type="submit" class="btn btn-primary btn-lg">Submit</button>
                  </div>

                  <!-- Inline Logic (runs even if assets are cached) -->
                  

              <script type="text/javascript"><![CDATA[
  (function(){
    function collectAnswers(){
      var out={};
      var nodes=document.querySelectorAll('input[data-field-id],select[data-field-id],textarea[data-field-id]');
      nodes.forEach(function(el){
        var fid=el.getAttribute('data-field-id');
        if(!fid) return;
        if(el.type==="radio"){
          if(el.checked) out[fid]=el.value||"";
          return;
        }
        if(el.type==="checkbox"){
          if(!out[fid]) out[fid]=[];
          if(el.checked) out[fid].push(el.value||"true");
          return;
        }
        out[fid]=el.value||"";
      });
      return out;
    }

    function post(url, payload){
      return fetch(url, {
        method: "POST",
        headers: {"Content-Type":"application/json"},
        body: JSON.stringify(payload||{}),
        credentials: "same-origin"
      }).then(function(r){ return r.ok ? r.json() : null; })
        .catch(function(){ return null; });
    }

    var form=document.getElementById("smart-form");
    if(!form) return;

    form.addEventListener("submit", function(e){
      var tokenEl=document.querySelector('input[name="token"]');
      var token=tokenEl ? tokenEl.value : "";
      if(!token) return;

      e.preventDefault();

      post("/smart_form/branching/"+encodeURIComponent(token), {answers: collectAnswers()})
        .then(function(data){
          if(data && data.success && data.next_token){
            window.location.href="/smart_form/"+data.next_token;
          } else {
            form.submit();
          }
        });
    }, true);
  })();
]]></script>

                </form>
              </div>
            </div>
          </div>
        </div>
      </div>
    </t>
  </template>

  <template id="smart_form_thanks" name="Forms Thanks">
    <t t-call="website.layout">
      <div class="container my-5">
        <div class="row justify-content-center">
          <div class="col-12 col-lg-6">
            <div class="card shadow-sm border-0">
              <div class="card-body p-4 p-md-5 text-center">
                <h3 class="mb-2">Thank you!</h3>
                <p class="text-muted mb-0">Your response has been submitted.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </t>
  </template>
</odoo>
