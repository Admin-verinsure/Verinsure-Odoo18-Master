<odoo>
  <template id="smart_form_page" name="Forms Page">
    <t t-call="website.layout">
      <div class="container my-5">
        <div class="row justify-content-center">
          <div class="col-12 col-lg-8">
            <div class="card shadow-sm border-0">
              <div class="card-body p-4 p-md-5">

                <h2 class="mb-1" t-esc="form.name"/>
                <p class="text-muted mb-4">Please fill the form below.</p>

                <!-- ============================= -->
                <!-- FIELD + LOGIC RULES (JSON) -->
                <!-- ============================= -->
                <script type="application/json" id="sfb-rules-json">
                  <t t-raw="rules_json or '[]'"/>
                </script>

                <form
                  id="smart-form"
                  action="/smart_form/submit"
                  method="post"
                  enctype="multipart/form-data">

                  <input type="hidden" name="token" t-att-value="form.token"/>

                  <!-- ============================= -->
                  <!-- FORM FIELDS -->
                  <!-- ============================= -->
                  <t t-foreach="form.field_ids" t-as="f">

                    <t t-if="f.field_type == 'subheading'">
                      <div class="mt-4 mb-2">
                        <h5 t-esc="f.label"/>
                      </div>
                    </t>

                    <t t-else="">
                      <div class="mb-3 sfb-field" t-att-data-field-id="f.id">

                        <label class="form-label">
                          <span t-esc="f.label"/>
                          <t t-if="f.required">
                            <span class="text-danger">*</span>
                          </t>
                        </label>

                        <t t-if="f.field_type == 'text'">
                          <input class="form-control" type="text"
                            t-att-name="f.name or ('field_%s' % f.id)"
                            t-att-data-field-id="f.id"
                            t-att-required="'required' if f.required else None"/>
                        </t>

                        <t t-elif="f.field_type == 'email'">
                          <input class="form-control" type="email"
                            placeholder="name@example.com"
                            t-att-name="f.name or ('field_%s' % f.id)"
                            t-att-data-field-id="f.id"
                            t-att-required="'required' if f.required else None"/>
                        </t>

                        <t t-elif="f.field_type == 'phone'">
                          <input class="form-control" type="tel"
                            t-att-name="f.name or ('field_%s' % f.id)"
                            t-att-data-field-id="f.id"
                            t-att-required="'required' if f.required else None"/>
                        </t>

                        <t t-elif="f.field_type == 'number'">
                          <input class="form-control" type="number"
                            t-att-name="f.name or ('field_%s' % f.id)"
                            t-att-data-field-id="f.id"
                            t-att-required="'required' if f.required else None"/>
                        </t>

                        <t t-elif="f.field_type == 'textarea'">
                          <textarea class="form-control" rows="4"
                            t-att-name="f.name or ('field_%s' % f.id)"
                            t-att-data-field-id="f.id"
                            t-att-required="'required' if f.required else None"/>
                        </t>

                        <t t-elif="f.field_type == 'select'">
                          <select class="form-select"
                            t-att-name="f.name or ('field_%s' % f.id)"
                            t-att-data-field-id="f.id">
                            <option value="">-- Select --</option>
                            <t t-foreach="f.get_options()" t-as="o">
                              <option t-att-value="o['value']">
                                <t t-esc="o['label']"/>
                              </option>
                            </t>
                          </select>
                        </t>

                        <t t-elif="f.field_type == 'radio'">
                          <t t-foreach="f.get_options()" t-as="o">
                            <div class="form-check">
                              <input class="form-check-input" type="radio"
                                t-att-name="f.name or ('field_%s' % f.id)"
                                t-att-data-field-id="f.id"
                                t-att-value="o['value']"/>
                              <label class="form-check-label">
                                <t t-esc="o['label']"/>
                              </label>
                            </div>
                          </t>
                        </t>

                        <t t-elif="f.field_type == 'checkbox'">
                          <t t-foreach="f.get_options()" t-as="o">
                            <div class="form-check">
                              <input class="form-check-input" type="checkbox"
                                t-att-name="(f.name or ('field_%s' % f.id)) + '[]'"
                                t-att-data-field-id="f.id"
                                t-att-value="o['value']"/>
                              <label class="form-check-label">
                                <t t-esc="o['label']"/>
                              </label>
                            </div>
                          </t>
                        </t>

                        <t t-elif="f.field_type == 'file'">
                          <input class="form-control" type="file"
                            t-att-name="f.name or ('field_%s' % f.id)"
                            t-att-data-field-id="f.id"/>
                        </t>

                      </div>
                    </t>
                  </t>

                  <div class="d-grid mt-4">
                    <button type="submit" class="btn btn-primary btn-lg">
                      Submit
                    </button>
                  </div>

                  <!-- ============================= -->
                  <!-- BRANCHING (FINAL & FIXED) -->
                  <!-- ============================= -->
                  <script type="text/javascript"><![CDATA[
                    (function(){
                      function collectAnswers(){
                        var out = {};
                        document.querySelectorAll(
                          'input[data-field-id],select[data-field-id],textarea[data-field-id]'
                        ).forEach(function(el){
                          var fid = el.getAttribute('data-field-id');
                          if(!fid) return;

                          if(el.type === "radio"){
                            if(el.checked) out[fid] = el.value || "";
                            return;
                          }

                          if(el.type === "checkbox"){
                            if(!out[fid]) out[fid] = [];
                            if(el.checked) out[fid].push(el.value || "true");
                            return;
                          }

                          out[fid] = el.value || "";
                        });
                        return out;
                      }

                      function post(url, payload){
                        return fetch(url,{
                          method:"POST",
                          headers:{ "Content-Type":"application/json" },
                          body:JSON.stringify(payload||{}),
                          credentials:"same-origin"
                        }).then(function(r){
                          return r.ok ? r.json() : null;
                        }).catch(function(){ return null; });
                      }

                      var form = document.getElementById("smart-form");
                      if(!form) return;

                      function onSubmit(e){
                        var tokenEl = document.querySelector('input[name="token"]');
                        if(!tokenEl) return;

                        e.preventDefault();

                        post(
                          "/smart_form/branching/" + encodeURIComponent(tokenEl.value),
                          { answers: collectAnswers() }
                        ).then(function(data){
                          if(data && data.success && data.next_token){
                            window.location.href = "/smart_form/" + data.next_token;
                          } else {
                            form.removeEventListener("submit", onSubmit, true);
                            form.submit();
                          }
                        });
                      }

                      form.addEventListener("submit", onSubmit, true);
                    })();
                  ]]></script>

                </form>
              </div>
            </div>
          </div>
        </div>
      </div>
    </t>
  </template>
</odoo>
