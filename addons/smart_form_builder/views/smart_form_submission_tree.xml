<odoo>

    <!-- ==================================================
         LIST VIEW
    =================================================== -->
    <record id="view_smart_form_submission_list" model="ir.ui.view">
        <field name="name">smart.form.submission.list</field>
        <field name="model">smart.form.submission</field>
        <field name="arch" type="xml">
            <list string="Form Submissions">
                <field name="create_date" string="Submitted On"/>
                <field name="first_name"/>
                <field name="last_name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="partner_id"/>
                <field name="data_source"/>
            </list>
        </field>
    </record>

    <!-- ==================================================
         FORM VIEW
    =================================================== -->
    <record id="view_smart_form_submission_form" model="ir.ui.view">
        <field name="name">smart.form.submission.form</field>
        <field name="model">smart.form.submission</field>
        <field name="arch" type="xml">
            <form string="Form Submission">
                <sheet>

                    <!-- Basic Info -->
                    <group>
                        <group>
                            <field name="form_id" readonly="1"/>
                            <field name="partner_id" readonly="1"/>
                            <field name="data_source" readonly="1"/>
                        </group>
                        <group>
                            <field name="create_date" readonly="1"/>
                            <field name="ip" readonly="1"/>
                            <field name="user_agent" readonly="1"/>
                        </group>
                    </group>

                    <separator string="Readable Data"/>

                    <!-- ✅ SUPPORTED WAY -->
                    <group>
                        <field name="readable_data" widget="json" readonly="1" nolabel="1"/>
                    </group>

                    <separator string="Raw Data (JSON)"/>

                    <group>
                        <field name="data_json" readonly="1" nolabel="1"/>
                    </group>

                </sheet>
            </form>
        </field>
    </record>

    <!-- ==================================================
         ACTION
    =================================================== -->
    <record id="action_smart_form_submissions_per_form" model="ir.actions.act_window">
        <field name="name">Submissions</field>
        <field name="res_model">smart.form.submission</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_smart_form_submission_list"/>
        <field name="domain">[('form_id', '=', active_id)]</field>
    </record>

</odoo>
