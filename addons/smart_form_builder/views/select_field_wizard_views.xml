<odoo>
  <record id="view_smart_select_field_wizard_form" model="ir.ui.view">
    <field name="name">smart.form.field.select.wizard.form</field>
    <field name="model">smart.form.field.select.wizard</field>
    <field name="arch" type="xml">
      <form string="Configure Select Field">
        <sheet>
          <group>
            <field name="option_values" placeholder="Option 1&#10;Option 2"/>
          </group>

          <separator string="Dynamic Options (DB)"/>

          <group>
            <field name="is_dynamic"/>
            <field name="option_model_id"
                   invisible="not is_dynamic"
                   required="is_dynamic"/>
            <field name="option_domain"
                   placeholder="[('active','=',True)]"
                   invisible="not is_dynamic"/>
            <field name="option_label_field" invisible="not is_dynamic"/>
            <field name="option_value_field" invisible="not is_dynamic"/>
            <field name="option_limit" invisible="not is_dynamic"/>
            <div class="o_form_label">Tip: If Dynamic Options is enabled, manual Options can be left empty.</div>
          </group>
        </sheet>
        <footer>
          <button string="Save" type="object" name="action_save" class="btn-primary"/>
          <button string="Cancel" special="cancel" class="btn-secondary"/>
        </footer>
      </form>
    </field>
  </record>
</odoo>
