
<odoo>
    <record id="view_journal_auto_reconcile" model="ir.ui.view">
        <field name="name">account.journal.auto.reconcile</field>
        <field name="model">account.journal</field>
        <field name="inherit_id" ref="account.view_account_journal_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='bank_statements_source']" position="after">
                <group string="Auto Reconciliation">
                    <field name="auto_reconcile_enabled"/>
                    <field name="auto_reconcile_days"/>
                    <field name="auto_reconcile_tolerance"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
