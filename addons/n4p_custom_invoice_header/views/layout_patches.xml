<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- BOLD -->
  <template id="patch_external_layout_bold" inherit_id="web.external_layout_bold" priority="199">
    <!-- Collapse original header -->
    <xpath expr="/t/div[1]" position="replace">
      <div t-attf-class="header o_company_#{company.id}_layout"
           style="display:none;height:0;line-height:0;padding:0;margin:0;border:0;"/>
    </xpath>
    <!-- Insert our block at top of body -->
    <xpath expr="//t[@t-call='web.address_layout']" position="replace">
      <t t-call="n4p_custom_invoice_header.n4p_header_block"/>
    </xpath>
    <xpath expr="/t" position="inside">
      <style>
        .o_report_layout_bold.article{margin-top:0!important;padding-top:0!important}
        .o_report_layout_bold.article h2{margin-top:0!important}
      </style>
    </xpath>
  </template>

  

  <!-- BUBBLE -->
  <template id="patch_external_layout_bubble"
          inherit_id="web.external_layout_bubble"
          priority="199">

  <!-- Hide the stock header completely -->
  <xpath expr="/t/div[1]" position="replace">
    <div t-attf-class="header o_company_#{company.id}_layout"
         style="display:none;height:0;line-height:0;padding:0;margin:0;border:0;"/>
  </xpath>

  <!-- Replace ANY call to web.address_layout with your header + the normal title -->
  <xpath expr="//t[@t-call='web.address_layout']" position="replace">
    <t t-call="n4p_custom_invoice_header.n4p_header_block"/>
    <h2 t-out="layout_document_title"/>
  </xpath>

  <!-- Bubble tweaks via CSS (no XPath to .o_bubble_title) -->
  <xpath expr="/t" position="inside">
    <style>
      /* Hide Bubble’s overlay title safely */
      .o_report_layout_bubble .o_bubble_title { display: none !important; }
      /* Compact spacing */
      .o_report_layout_bubble h2 { margin: 6px 0 8px 0 !important; }
      /* Keep header compact */
      .o_report_layout_bubble .n4p-header img { max-height: 60px !important; height: auto !important; }
    </style>
  </xpath>
</template>



