<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <!-- Only override the HEADER of the bold layout -->
  <template id="external_layout_bold_header_patch"
            inherit_id="web.external_layout_bold"
            priority="199">
    <!-- Header is the first <div> under the template -->
    <xpath expr="/t/div[1]" position="replace">
      <div t-attf-class="header o_company_#{company.id}_layout" t-att-style="report_header_style">
        <div class="row align-items-center">
          <!-- LEFT: Logo -->
          <div class="col-6">
            <img t-if="company.logo"
                 class="o_company_logo_big"
                 t-att-src="image_data_uri(company.logo)"
                 alt="Logo"/>
          </div>
          <!-- RIGHT: Two centered lines (tagline + country) -->
          <div class="col-6 text-center">
            <!-- First line: use report_header if set; fall back to company.name -->
            <strong class="h5 d-block">
              <t t-esc="company.report_header or company.name"/>
            </strong>
            <!-- Second line: country -->
            <span t-if="company.country_id" class="d-block" t-field="company.country_id"/>
          </div>
        </div>
      </div>
    </xpath>
  </template>
</odoo>
