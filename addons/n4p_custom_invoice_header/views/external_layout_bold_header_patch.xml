<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <!-- Inherit the Bold external layout -->
  <template id="layout_bold_move_header_into_body"
            inherit_id="web.external_layout_bold"
            priority="199">

    <!-- 1) Make the header EMPTY (keep container to preserve layout spacing) -->
    <xpath expr="/t/div[1]" position="replace">
      <div t-attf-class="header o_company_#{company.id}_layout" t-att-style="report_header_style"/>
    </xpath>

    <!-- 2) Insert your header table INSIDE the body (article), ABOVE the title -->
    <!-- We place it just before <h2 t-out="layout_document_title"/> -->
    <xpath expr="//h2[@t-out='layout_document_title']" position="before">
      <!-- Custom Header block now in the body -->
      <table style="width:100%; margin-bottom:20px;">
        <tr>
          <td style="width:50%;">
            <img t-if="company.logo"
                 t-att-src="image_data_uri(company.logo)"
                 style="max-height:80px;"
                 alt="Company Logo"/>
          </td>
          <td style="width:50%; text-align:right; color:#000;">
            <h4 style="margin:0;" t-field="company.name"/>
            <div><span t-field="company.street"/></div>
            <div>
              <span t-field="company.city"/> <span t-field="company.zip"/>
            </div>
            <div><span t-field="company.country_id"/></div>
          </td>
        </tr>
      </table>
    </xpath>

    <!-- OPTIONAL: if you want to hide the default address block that Bold prints above the title,
         uncomment the block below (it removes web.address_layout call).
    <xpath expr="//t[@t-call='web.address_layout']" position="replace">
      <t/>
    </xpath>
    -->

  </template>
</odoo>
