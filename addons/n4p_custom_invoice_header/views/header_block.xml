<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <!-- Reusable header block (wizard-safe) -->
  <template id="n4p_header_block" name="N4P Header Block">
    <!-- Give the template a stable QWeb name -->
    <t t-name="n4p_custom_invoice_header.n4p_header_block">
      <table class="n4p-header" style="width:100%; margin:0 0 6px 0; border-collapse:collapse;">
        <tr>
          <!-- LEFT: logo -->
          <td class="n4p-header-left" style="width:50%; vertical-align:top;">
            <img t-if="company.logo"
                 t-att-src="image_data_uri(company.logo)"
                 style="max-height:60px;"  
                 alt="Company Logo"/>
          </td>

          <!-- RIGHT: title + details -->
          <td class="n4p-header-right"
              style="width:50%; vertical-align:top; text-align:right; color:#000;">
            <div class="n4p-header-title"
                 style="font-weight:700; font-size:18px; margin:0 0 3px 0;">
              <t t-esc="company.report_header or company.name or ''"/>
            </div>

            <!-- Use the same safe pattern as core layouts -->
            <t t-if="company.is_company_details_empty">
              <span t-field="company.partner_id"
                    t-options='{"widget":"contact","fields":["address"],"no_marker": true}'/>
            </t>
            <t t-else="">
              <span t-field="company.company_details"/>
            </t>
          </td>
        </tr>
      </table>
    </t>
  </template>
</odoo>
