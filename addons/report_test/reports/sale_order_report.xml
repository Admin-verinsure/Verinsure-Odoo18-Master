<odoo>
    <record id="action_report_saleorder_test" model="ir.actions.report">
        <field name="name">Test Sale Order Print</field>
        <field name="model">sale.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">report_test.report_saleorder_test_document</field>
        <field name="report_file">report_test.report_saleorder_test_document</field>
        <field name="print_report_name">'Test Sale Order - %s' % (object.name)</field>
        <field name="binding_model_id" ref="sale.model_sale_order"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_saleorder_test_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h1>Sale Order PDF Test</h1>
                        <p>If you can see the company header above, the layout is working.</p>
                        <h2>Quotation Number: <span t-field="doc.name"/></h2>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>