<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <record id="view_x_form_question_list" model="ir.ui.view">
      <field name="name">x.form.question.list</field>
      <field name="model">x_form.question</field>
      <field name="arch" type="xml">
        <list decoration-muted="not template_id">
          <field name="sequence" widget="handle"/>
          <field name="label"/>
          <field name="field_type"/>
          <field name="required" widget="boolean_toggle"/>
          <field name="step_id"/>
          <field name="template_id" optional="hide"/>
        </list>
      </field>
    </record>

    <record id="view_x_form_question_form" model="ir.ui.view">
      <field name="name">x.form.question.form</field>
      <field name="model">x_form.question</field>
      <field name="arch" type="xml">
        <form string="Question">
          <sheet>
            <div class="oe_title">
              <label for="label" class="oe_edit_only"/>
              <h1><field name="label" placeholder="e.g., What is your email address?"/></h1>
            </div>

            <group>
              <group>
                <field name="template_id" required="1"/>
                <field name="step_id" required="1" domain="[('template_id', '=', template_id)]"/>
              </group>
              <group>
                <field name="field_type" required="1"/>
                <field name="required" widget="boolean_toggle"/>
              </group>
            </group>

            <notebook>
              <page string="Basic Configuration">
                <group>
                  <field name="placeholder" placeholder="e.g., user@example.com"/>
                  <field name="help" placeholder="Help text shown below the input..."/>
                </group>
              </page>

              <page string="Options" invisible="field_type not in ('selection', 'multiselect')">
                <field name="option_ids">
                  <list editable="bottom">
                    <field name="sequence" widget="handle"/>
                    <field name="label"/>
                    <field name="value"/>
                  </list>
                </field>
              </page>

              <page string="Conditional Display">
                <div class="alert alert-info" role="alert">
                  Show this question only when specific conditions are met. Leave empty to always show.
                </div>
                <group>
                  <field name="condition_logic" widget="radio" options="{'horizontal': true}"/>
                </group>
                <field name="condition_ids">
                  <list editable="bottom">
                    <field name="depends_on_question_id" 
                           domain="[('template_id', '=', parent.template_id), ('id', '!=', parent.id)]"/>
                    <field name="operator"/>
                    <field name="value"/>
                  </list>
                </field>
              </page>

              <page string="Validation">
                <group>
                  <field name="key" groups="base.group_no_one"/>
                  <field name="validation_regex" invisible="field_type not in ('char', 'text')"/>
                  <field name="min_value" invisible="field_type not in ('integer', 'float')"/>
                  <field name="max_value" invisible="field_type not in ('integer', 'float')"/>
                </group>
              </page>
            </notebook>

          </sheet>
        </form>
      </field>
    </record>

    <record id="action_x_form_question" model="ir.actions.act_window">
      <field name="name">Questions</field>
      <field name="res_model">x_form.question</field>
      <field name="view_mode">list,form</field>
    </record>

  </data>
</odoo>