<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <record id="view_x_form_step_list" model="ir.ui.view">
      <field name="name">x.form.step.list</field>
      <field name="model">x_form.step</field>
      <field name="arch" type="xml">
        <list multi_edit="1">
          <field name="sequence" widget="handle"/>
          <field name="code" optional="show"/>
          <field name="name"/>
          <field name="template_id"/>
          <field name="is_sensitive" widget="boolean_toggle" optional="show"/>
        </list>
      </field>
    </record>

    <record id="view_x_form_step_form" model="ir.ui.view">
      <field name="name">x.form.step.form</field>
      <field name="model">x_form.step</field>
      <field name="arch" type="xml">
        <form string="Section">
          <sheet>
            <div class="oe_title">
              <label for="name" class="oe_edit_only"/>
              <h1><field name="name" placeholder="e.g., Personal Information"/></h1>
            </div>

            <group>
              <group>
                <field name="code" placeholder="e.g., A1"/>
                <field name="template_id" required="1"/>
              </group>
              <group>
                <field name="is_sensitive" widget="boolean_toggle"/>
                <field name="sequence" groups="base.group_no_one"/>
              </group>
            </group>

            <notebook>
              <page string="Questions">
                <field name="question_ids" context="{'default_template_id': template_id}">
                  <list editable="bottom">
                    <field name="sequence" widget="handle"/>
                    <field name="label"/>
                    <field name="field_type"/>
                    <field name="required" widget="boolean_toggle"/>
                  </list>
                </field>
              </page>

              <page string="Conditional Display">
                <div class="alert alert-info" role="alert">
                  Configure this section to be hidden unless specific questions in previous sections are answered a certain way.
                </div>
                <group>
                  <field name="condition_logic" widget="radio" options="{'horizontal': true}"/>
                </group>
                <field name="condition_ids">
                  <list editable="bottom">
                    <field name="depends_on_question_id" 
                           domain="[('template_id', '=', parent.template_id)]"
                           options="{'no_create': True}"/>
                    <field name="operator"/>
                    <field name="value"/>
                  </list>
                </field>
              </page>
            </notebook>
          </sheet>
        </form>
      </field>
    </record>

    <record id="action_x_form_step" model="ir.actions.act_window">
      <field name="name">Sections</field>
      <field name="res_model">x_form.step</field>
      <field name="view_mode">list,form</field>
    </record>

  </data>
</odoo>