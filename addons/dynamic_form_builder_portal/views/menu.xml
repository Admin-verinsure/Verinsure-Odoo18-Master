              parent="menu_dynamic_forms_root"
              sequence="18"
              action="action_x_form_step"
              groups="dynamic_form_builder_portal.group_form_manager"/>

    <menuitem id="menu_form_submissions"
              name="Submissions"
              parent="menu_dynamic_forms_root"
              sequence="20"
