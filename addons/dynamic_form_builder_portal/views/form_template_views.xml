<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="view_x_form_template_list" model="ir.ui.view">
    <field name="name">x.form.template.list</field>
    <field name="model">x_form.template</field>
    <field name="arch" type="xml">
      <list>
        <field name="name"/>
        <field name="active" widget="boolean_toggle"/>
        <field name="version"/>
      </list>
    </field>
  </record>

  <record id="view_x_form_template_form" model="ir.ui.view">
    <field name="name">x.form.template.form</field>
    <field name="model">x_form.template</field>
    <field name="arch" type="xml">
      <form string="Form Template">
        <header>
          <button name="action_new_version" 
                  type="object" 
                  string="New Version" 
                  class="btn-secondary"
                  invisible="not id"/>
        </header>

        <sheet>
          <div class="oe_button_box" name="button_box">
            <button name="action_open_sections" type="object" class="oe_stat_button" icon="fa-sitemap">
              <field name="step_count" widget="statinfo" string="Sections"/>
            </button>
            <button name="action_open_questions" type="object" class="oe_stat_button" icon="fa-list">
              <field name="question_count" widget="statinfo" string="Questions"/>
            </button>
            <button name="action_open_submissions" type="object" class="oe_stat_button" icon="fa-inbox">
              <field name="submission_count" widget="statinfo" string="Submissions"/>
            </button>
          </div>

          <div class="oe_title">
            <label for="name" class="oe_edit_only"/>
            <h1>
              <field name="name" placeholder="e.g., Youth Program Volunteer Application"/>
            </h1>
          </div>

          <group>
            <group>
              <field name="active" widget="boolean_toggle"/>
              <field name="version" readonly="1"/>
            </group>
          </group>

          <notebook>
            <page string="Builder">
              <div class="alert alert-info" role="alert">
                <strong>Workflow:</strong>
                <ol class="mb-0">
                  <li>Create <b>Sections</b> (A default 'Main' section is created automatically).</li>
                  <li>Add <b>Questions</b> inside sections.</li>
                  <li>Use <b>Conditions</b> to show/hide questions based on answers.</li>
                </ol>
              </div>

              <div class="d-flex gap-2 mt-3">
                <button name="action_open_sections" 
                        type="object" 
                        string="Manage Sections" 
                        class="btn btn-primary" 
                        icon="fa-sitemap"/>
                
                <button name="action_open_questions" 
                        type="object" 
                        string="Manage Questions" 
                        class="btn btn-primary" 
                        icon="fa-list-ul"/>
                
                <button name="action_open_submissions" 
                        type="object" 
                        string="View Submissions" 
                        class="btn btn-secondary" 
                        icon="fa-table"/>
              </div>
            </page>

            <page string="Portal Content">
              <group>
                <field name="portal_intro" placeholder="Text displayed at the top of the form..."/>
                <field name="portal_success" placeholder="Message displayed after successful submission..."/>
              </group>
            </page>

            <page string="Internal Description">
              <field name="description" placeholder="Internal notes for administrators..."/>
            </page>
          </notebook>
        </sheet>

        <div class="oe_chatter">
          <field name="message_follower_ids" widget="mail_followers"/>
          <field name="activity_ids" widget="mail_activity"/>
          <field name="message_ids" widget="mail_thread"/>
        </div>
      </form>
    </field>
  </record>

  <record id="action_x_form_template" model="ir.actions.act_window">
    <field name="name">Form Templates</field>
    <field name="res_model">x_form.template</field>
    <field name="view_mode">list,form</field>
  </record>

</odoo>