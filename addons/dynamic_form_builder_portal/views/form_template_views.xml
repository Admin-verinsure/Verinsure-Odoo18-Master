<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="view_x_form_template_list" model="ir.ui.view">
    <field name="name">x.form.template.list</field>
    <field name="model">x_form.template</field>
    <field name="arch" type="xml">
      <list>
        <field name="name"/>
        <field name="active"/>
        <field name="version"/>
      </list>
    </field>
  </record>

  <record id="view_x_form_template_form" model="ir.ui.view">
    <field name="name">x.form.template.form</field>
    <field name="model">x_form.template</field>
    <field name="arch" type="xml">
      <form string="Form Template">
        <header>
          <button name="action_new_version" type="object" string="New Version" class="btn-secondary"/>
        </header>

        <sheet>
          <div class="oe_button_box" name="button_box">
            <button name="action_open_sections" type="object" class="oe_stat_button" icon="fa-sitemap">
              <field name="step_count" widget="statinfo" string="Sections"/>
            </button>
            <button name="action_open_questions" type="object" class="oe_stat_button" icon="fa-list">
              <field name="question_count" widget="statinfo" string="Questions"/>
            </button>
            <button name="action_open_submissions" type="object" class="oe_stat_button" icon="fa-inbox">
              <field name="submission_count" widget="statinfo" string="Submissions"/>
            </button>
          </div>

          <div class="oe_title">
            <h1>
              <field name="name" placeholder="e.g., Youth Program Volunteer Application"/>
            </h1>
          </div>

          <group>
            <field name="active"/>
            <field name="version" readonly="1"/>
          </group>

          <notebook>

            <page string="Builder">
              <div class="alert alert-info">
                <strong>Google-Forms style workflow:</strong>
                <ol class="mb-0">
                  <li>Create sections (optional). A default <em>Main</em> section is created automatically.</li>
                  <li>Add questions inside sections.</li>
                  <li>Use “Show conditionally” (Conditions tab) only when needed.</li>
                </ol>
              </div>

              <div class="mt-2 d-flex flex-wrap gap-2">
                <button name="action_open_sections" type="object" class="btn btn-primary">
                  Manage Sections
                </button>
                <button name="action_open_questions" type="object" class="btn btn-primary">
                  Manage Questions
                </button>
                <button name="action_open_submissions" type="object" class="btn btn-secondary">
                  View Submissions
                </button>
              </div>

              <div class="mt-3 text-muted">
                Tip: Keep it simple. Add conditions only for questions/sections that should appear based on answers.
              </div>
            </page>

            <page string="Portal Content">
              <group>
                <field name="portal_intro" widget="html"/>
                <field name="portal_success" widget="html"/>
              </group>
            </page>

            <page string="Description">
              <field name="description" widget="html"/>
            </page>

          </notebook>

        </sheet>

        <chatter/>
      </form>
    </field>
  </record>

  <record id="action_x_form_template" model="ir.actions.act_window">
    <field name="name">Form Templates</field>
    <field name="res_model">x_form.template</field>
    <field name="view_mode">list,form</field>
  </record>

</odoo>
