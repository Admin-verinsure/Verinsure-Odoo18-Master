<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <!-- LIST view (Odoo 18 uses <list>, not <tree>) -->
    <record id="view_x_form_template_list" model="ir.ui.view">
      <field name="name">x.form.template.list</field>
      <field name="model">x_form.template</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="active"/>
          <field name="version"/>
        </list>
      </field>
    </record>

    <record id="view_x_form_template_form" model="ir.ui.view">
      <field name="name">x.form.template.form</field>
      <field name="model">x_form.template</field>
      <field name="arch" type="xml">
        <form string="Form Template">
          <header>
            <button name="action_new_version" type="object" string="New Version" class="btn-secondary"/>
          </header>

          <sheet>
            <div class="oe_title">
              <h1><field name="name" placeholder="e.g., Youth Program Volunteer Application"/></h1>
            </div>

            <group>
              <field name="active"/>
              <field name="version" readonly="1"/>
            </group>

            <notebook>
              <page string="Description">
                <field name="description" widget="html"/>
              </page>

              <page string="Portal Content">
                <group>
                  <field name="portal_intro" widget="html"/>
                  <field name="portal_success" widget="html"/>
                </group>
              </page>

              <page string="Steps / Sections">
                <field name="step_ids" context="{'default_template_id': active_id}">
                  <list editable="bottom">
                    <field name="sequence" widget="handle"/>
                    <field name="code"/>
                    <field name="name"/>
                    <field name="is_sensitive"/>
                  </list>

                  <form>
                    <sheet>
                      <group>
                        <field name="sequence"/>
                        <field name="code"/>
                        <field name="name"/>
                        <field name="is_sensitive"/>
                        <field name="condition_logic"/>
                      </group>

                      <group string="Step Visibility Conditions">
                        <field name="condition_ids">
                          <list editable="bottom">
                            <field name="depends_on_question_id"/>
                            <field name="operator"/>
                            <field name="value"/>
                          </list>
                        </field>
                      </group>

                      <group string="Questions">
                        <field name="question_ids" context="{'default_step_id': active_id}">
                          <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="label"/>
                            <field name="field_type"/>
                            <field name="required"/>
                          </list>

                          <form>
                            <sheet>
                              <group>
                                <field name="sequence"/>
                                <field name="label"/>
                                <field name="key"/>
                                <field name="field_type"/>
                                <field name="required"/>
                                <field name="placeholder"/>
                                <field name="help"/>
                              </group>

                              <group string="Validation">
                                <field name="validation_regex"/>
                                <field name="min_value"/>
                                <field name="max_value"/>
                              </group>

                              <group string="Visibility Conditions">
                                <field name="condition_logic"/>
                                <field name="condition_ids">
                                  <list editable="bottom">
                                    <field name="depends_on_question_id"/>
                                    <field name="operator"/>
                                    <field name="value"/>
                                  </list>
                                </field>
                              </group>

                              <group string="Options" attrs="{'invisible': [('field_type','not in', ('selection','multiselect'))]}">
                                <field name="option_ids">
                                  <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="label"/>
                                    <field name="value"/>
                                  </list>
                                </field>
                              </group>
                            </sheet>
                          </form>

                        </field>
                      </group>

                    </sheet>
                  </form>
                </field>
              </page>
            </notebook>

          </sheet>

          <chatter/>
        </form>
      </field>
    </record>

    <record id="action_x_form_template" model="ir.actions.act_window">
      <field name="name">Form Templates</field>
      <field name="res_model">x_form.template</field>
      <field name="view_mode">list,form</field>
    </record>

  </data>
</odoo>
