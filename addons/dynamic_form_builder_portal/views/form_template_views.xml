<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <record id="view_x_form_template_tree" model="ir.ui.view">
      <field name="name">x.form.template.tree</field>
      <field name="model">x_form.template</field>
      <field name="arch" type="xml">
        <list decoration-muted="not active">
          <field name="name"/>
          <field name="active" widget="boolean_toggle"/>
          <field name="version"/>
        </list>
      </field>
    </record>

    <record id="view_x_form_template_form" model="ir.ui.view">
      <field name="name">x.form.template.form</field>
      <field name="model">x_form.template</field>
      <field name="arch" type="xml">
        <form string="Form Template">
          <header>
            <button name="action_new_version" type="object" string="New Version" class="btn-secondary"
                    invisible="not id"/>
          </header>
          <sheet>
            <div class="oe_title">
              <label for="name" class="oe_edit_only"/>
              <h1><field name="name" placeholder="e.g., Youth Program Volunteer Application"/></h1>
            </div>
            <group>
              <group>
                <field name="active" widget="boolean_toggle"/>
                <field name="version" readonly="1"/>
              </group>
            </group>
            <notebook>
              <page string="Builder">
                <div class="alert alert-info" role="alert">
                  <strong>How to build a form:</strong>
                  <ol class="mb-0">
                    <li>Create <em>Sections</em> (optional). A default “Main” section is created automatically.</li>
                    <li>Add <em>Questions</em> and choose field type (text, date, choice, file…).</li>
                    <li>For branching, open a section/question and add <em>Conditions</em>.</li>
                  </ol>
                </div>

                <field name="question_ids" context="{'default_template_id': active_id}">
                  <list editable="bottom" limit="20">
                    <field name="sequence" widget="handle"/>
                    <field name="step_id" options="{'no_create': True}"/>
                    <field name="label"/>
                    <field name="field_type"/>
                    <field name="required"/>
                  </list>
                </field>
              </page>

              <page string="Sections">
                <field name="step_ids" context="{'default_template_id': active_id}">
                  <list editable="bottom">
                    <field name="sequence" widget="handle"/>
                    <field name="code" optional="hide"/>
                    <field name="name"/>
                    <field name="is_sensitive" widget="boolean_toggle"/>
                  </list>
                </field>
              </page>

              <page string="Portal Content">
                <group>
                  <field name="portal_intro" widget="html" placeholder="Welcome message..."/>
                  <field name="portal_success" widget="html" placeholder="Thank you message..."/>
                </group>
              </page>

              <page string="Description">
                <field name="description" widget="html" placeholder="Internal notes..."/>
              </page>
            </notebook>
          </sheet>
          
          <div class="oe_chatter">
            <field name="message_follower_ids" widget="mail_followers"/>
            <field name="activity_ids" widget="mail_activity"/>
            <field name="message_ids" widget="mail_thread"/>
          </div>
        </form>
      </field>
    </record>

    <record id="action_x_form_template" model="ir.actions.act_window">
      <field name="name">Form Templates</field>
      <field name="res_model">x_form.template</field>
      <field name="view_mode">list,form</field>
    </record>


    <record id="view_x_form_step_list" model="ir.ui.view">
      <field name="name">x.form.step.list</field>
      <field name="model">x_form.step</field>
      <field name="arch" type="xml">
        <list>
          <field name="sequence" widget="handle"/>
          <field name="template_id"/>
          <field name="name"/>
          <field name="code" optional="hide"/>
          <field name="is_sensitive" widget="boolean_toggle"/>
        </list>
      </field>
    </record>

    <record id="view_x_form_step_form" model="ir.ui.view">
      <field name="name">x.form.step.form</field>
      <field name="model">x_form.step</field>
      <field name="arch" type="xml">
        <form string="Section">
          <sheet>
            <div class="oe_title">
              <label for="name" class="oe_edit_only"/>
              <h1><field name="name" placeholder="e.g., Personal Information"/></h1>
            </div>
            <group>
              <group>
                <field name="template_id" readonly="1"/>
                <field name="code"/>
              </group>
              <group>
                <field name="sequence"/>
                <field name="is_sensitive" widget="boolean_toggle"/>
              </group>
            </group>

            <notebook>
              <page string="Questions">
                <field name="question_ids" context="{'default_step_id': active_id}">
                  <list editable="bottom">
                    <field name="sequence" widget="handle"/>
                    <field name="label"/>
                    <field name="field_type"/>
                    <field name="required"/>
                  </list>
                </field>
              </page>

              <page string="Branching (Advanced)">
                <div class="alert alert-secondary" role="alert">
                  Add rules here to show/hide this section depending on previous answers.
                </div>
                <group>
                  <field name="condition_logic" widget="radio" options="{'horizontal': true}"/>
                </group>
                <field name="condition_ids">
                  <list editable="bottom">
                    <field name="depends_on_question_id"/>
                    <field name="operator"/>
                    <field name="value"/>
                  </list>
                </field>
              </page>
            </notebook>
          </sheet>
        </form>
      </field>
    </record>

    <record id="action_x_form_step" model="ir.actions.act_window">
      <field name="name">Sections</field>
      <field name="res_model">x_form.step</field>
      <field name="view_mode">list,form</field>
    </record>


    <record id="view_x_form_question_list" model="ir.ui.view">
      <field name="name">x.form.question.list</field>
      <field name="model">x_form.question</field>
      <field name="arch" type="xml">
        <list>
          <field name="sequence" widget="handle"/>
          <field name="template_id" optional="hide"/>
          <field name="step_id"/>
          <field name="label"/>
          <field name="field_type"/>
          <field name="required" widget="boolean_toggle"/>
        </list>
      </field>
    </record>

    <record id="view_x_form_question_form_simple" model="ir.ui.view">
      <field name="name">x.form.question.form</field>
      <field name="model">x_form.question</field>
      <field name="arch" type="xml">
        <form string="Question">
          <sheet>
            <div class="oe_title">
              <label for="label" class="oe_edit_only"/>
              <h1><field name="label" placeholder="e.g., What is your email?"/></h1>
            </div>
            <group>
              <group>
                <field name="step_id" required="1"/>
                <field name="field_type"/>
                <field name="required" widget="boolean_toggle"/>
              </group>
              <group>
                <field name="key" groups="base.group_no_one"/>
                <field name="placeholder"/>
                <field name="help"/>
                <field name="sequence"/>
              </group>
            </group>

            <notebook>
              <page string="Options" invisible="field_type not in ('selection', 'multiselect')">
                <field name="option_ids">
                  <list editable="bottom">
                    <field name="sequence" widget="handle"/>
                    <field name="label"/>
                    <field name="value"/>
                  </list>
                </field>
              </page>

              <page string="Show Conditionally (Advanced)">
                <div class="alert alert-secondary" role="alert">
                  “Show this question when…” rules. Leave empty to always show.
                </div>
                <group>
                  <field name="condition_logic" widget="radio" options="{'horizontal': true}"/>
                </group>
                <field name="condition_ids">
                  <list editable="bottom">
                    <field name="depends_on_question_id"/>
                    <field name="operator"/>
                    <field name="value"/>
                  </list>
                </field>
              </page>

              <page string="Validation">
                <group>
                  <field name="validation_regex"/>
                  <field name="min_value"/>
                  <field name="max_value"/>
                </group>
              </page>
            </notebook>
          </sheet>
        </form>
      </field>
    </record>

    <record id="action_x_form_question" model="ir.actions.act_window">
      <field name="name">Questions</field>
      <field name="res_model">x_form.question</field>
      <field name="view_mode">list,form</field>
    </record>

  </data>
</odoo>