<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <record id="portal_my_forms" model="ir.ui.view">
      <field name="name">portal_my_forms</field>
      <field name="type">qweb</field>
      <field name="key">dynamic_form_builder_portal.portal_my_forms</field>
      <field name="arch" type="xml">
        <t t-call="portal.portal_layout">
          <t t-set="breadcrumbs_searchbar" t-value="True"/>
          <t t-set="title">My Forms</t>

          <div class="o_df_portal_container">
            <div class="o_df_header mb-4">
              <h2 class="mb-1">My Forms</h2>
              <p class="text-muted mb-0">Start a new application or continue an existing draft.</p>
            </div>

            <div class="card shadow-sm rounded-4 mb-4">
              <div class="card-body">
                <form method="get" action="/my/forms/start">
                  <div class="row g-2 align-items-end">
                    <div class="col-12 col-md-8">
                      <label class="form-label fw-bold" for="template_select">Choose a form</label>
                      <select class="form-select" name="template_id" id="template_select" required="required">
                        <option value="" selected="selected" disabled="disabled">Select a form...</option>
                        <t t-foreach="templates" t-as="tpl">
                          <option t-att-value="tpl.id"><t t-esc="tpl.name"/></option>
                        </t>
                      </select>
                    </div>
                    <div class="col-12 col-md-4">
                      <button class="btn btn-primary w-100">Start Application</button>
                    </div>
                  </div>
                </form>
              </div>
            </div>

            <div class="mt-4">
              <h4 class="mb-3">Your Submissions</h4>
              <t t-if="submissions">
                <div class="list-group shadow-sm rounded-4 overflow-hidden">
                  <t t-foreach="submissions" t-as="s">
                    <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-3"
                       t-att-href="'/my/forms/%s' % s.id">
                      <div>
                        <div class="fw-bold text-primary"><t t-esc="s.template_id.name"/></div>
                        <div class="small text-muted mt-1">
                          Ref: <t t-esc="s.name"/> • Created: <span t-field="s.create_date" t-options='{"widget": "date"}'/>
                        </div>
                      </div>
                      <div class="text-end">
                        <span t-attf-class="badge rounded-pill border #{s.state == 'draft' and 'bg-info-subtle text-info-emphasis' or (s.state == 'approved' and 'bg-success-subtle text-success-emphasis' or 'bg-light text-dark')}">
                          <t t-esc="s.state" />
                        </span>
                      </div>
                    </a>
                  </t>
                </div>
              </t>
              <t t-else="">
                <div class="alert alert-light border rounded-4 text-center py-4">
                  <p class="mb-0 text-muted">No submissions found. Start a new one above!</p>
                </div>
              </t>
            </div>
          </div>
        </t>
      </field>
    </record>

    <record id="portal_form_fill" model="ir.ui.view">
      <field name="name">portal_form_fill</field>
      <field name="type">qweb</field>
      <field name="key">dynamic_form_builder_portal.portal_form_fill</field>
      <field name="arch" type="xml">
        <t t-call="portal.portal_layout">
          <t t-set="title"><t t-esc="submission.template_id.name"/></t>

          <div class="o_df_portal_container" id="o_df_root"
               t-att-data-submission-id="submission.id"
               t-att-data-csrf-token="request.csrf_token()">

            <div class="o_df_header mb-4">
              <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
                <div>
                  <h2 class="mb-1"><t t-esc="submission.template_id.name"/></h2>
                  <p class="text-muted mb-0">
                    Submission: <strong><t t-esc="submission.name"/></strong>
                    • Status: <span class="badge bg-light text-dark border"><t t-esc="submission.state"/></span>
                  </p>
                </div>
                <div class="d-flex gap-2">
                  <a class="btn btn-outline-secondary" href="/my/forms">Back</a>
                  
                  <form method="post" t-att-action="'/my/forms/%s/submit' % submission.id">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    <button class="btn btn-primary" t-att-disabled="submission.state != 'draft' and 'disabled' or None">
                      Submit Final
                    </button>
                  </form>
                </div>
              </div>
            </div>

            <t t-if="submission.template_id.portal_intro">
              <div class="card shadow-sm rounded-4 mb-4">
                <div class="card-body">
                  <t t-out="submission.template_id.portal_intro"/>
                </div>
              </div>
            </t>

            <div class="row g-4">
              <div class="col-12 col-lg-3">
                <div class="card shadow-sm rounded-4 o_df_steps sticky-top" style="top: 100px; z-index: 900;">
                  <div class="card-body p-0">
                    <div class="p-3 border-bottom fw-bold bg-light rounded-top-4">Sections</div>
                    <ol class="list-group list-group-flush list-group-numbered">
                      <t t-foreach="steps" t-as="st">
                        <li class="list-group-item d-flex justify-content-between align-items-center action-jump-to-step"
                            style="cursor: pointer;"
                            t-att-data-step-id="st.id">
                          <div class="ms-2 me-auto">
                            <div class="fw-semibold">
                              <t t-if="st.code"><t t-esc="st.code"/> - </t>
                              <t t-esc="st.name"/>
                            </div>
                            <small class="text-muted" t-if="st.is_sensitive">
                              <i class="fa fa-lock me-1"/>Sensitive
                            </small>
                          </div>
                        </li>
                      </t>
                    </ol>
                  </div>
                </div>
              </div>

              <div class="col-12 col-lg-9">
                <div class="card shadow-sm rounded-4 border-0">
                  <div class="card-body p-4">
                    
                    <t t-foreach="steps" t-as="st">
                      <section class="o_df_step mb-5" t-att-data-step-id="st.id">
                        
                        <div class="border-bottom pb-2 mb-4 d-flex align-items-center justify-content-between">
                          <h3 class="h4 mb-0 text-primary">
                            <t t-if="st.code"><span class="text-muted"><t t-esc="st.code"/>.</span> </t>
                            <t t-esc="st.name"/>
                          </h3>
                          <span t-if="st.is_sensitive" class="badge bg-warning-subtle text-warning-emphasis border rounded-pill">
                            <i class="fa fa-lock me-1"/>Confidential
                          </span>
                        </div>

                        <div class="o_df_questions">
                          <t t-foreach="st.question_ids.sorted('sequence')" t-as="q">
                            
                            <t t-if="visible_questions.get(q.id)">
                              <div class="o_df_question mb-4"
                                   t-att-data-question-id="q.id"
                                   t-att-data-type="q.field_type"
                                   t-att-data-condition-json="condition_json.get(q.id) or ''">

                                <label class="form-label fw-bold" t-att-for="'input_q_%s' % q.id">
                                  <t t-esc="q.label"/>
                                  <t t-if="q.required"><span class="text-danger" title="Required">*</span></t>
                                </label>
                                
                                <t t-if="q.help">
                                  <div class="form-text text-muted mb-2 mt-0"><i class="fa fa-info-circle me-1"/><t t-esc="q.help"/></div>
                                </t>

                                <t t-set="val" t-value="answers.get(q.id)"/>
                                <t t-set="input_name" t-value="'q_%s' % q.id"/>
                                <t t-set="input_id" t-value="'input_q_%s' % q.id"/>

                                <t t-if="q.field_type in ('char','email','phone','signature')">
                                  <input class="form-control"
                                         t-att-id="input_id"
                                         t-att-type="('email' if q.field_type=='email' else ('tel' if q.field_type=='phone' else 'text'))"
                                         t-att-name="input_name"
                                         t-att-placeholder="q.placeholder or ''"
                                         t-att-value="val or ''"
                                         t-att-data-required="q.required and '1' or '0'"/>
                                </t>

                                <t t-elif="q.field_type == 'text'">
                                  <textarea class="form-control" rows="4"
                                            t-att-id="input_id"
                                            t-att-name="input_name"
                                            t-att-placeholder="q.placeholder or ''"
                                            t-att-data-required="q.required and '1' or '0'"><t t-esc="val or ''"/></textarea>
                                </t>

                                <t t-elif="q.field_type == 'date'">
                                  <input class="form-control" type="date"
                                         t-att-id="input_id"
                                         t-att-name="input_name"
                                         t-att-value="val or ''"
                                         t-att-data-required="q.required and '1' or '0'"/>
                                </t>

                                <t t-elif="q.field_type in ('integer','float')">
                                  <input class="form-control" type="number"
                                         t-att-id="input_id"
                                         t-att-name="input_name"
                                         t-att-value="val or ''"
                                         t-att-step="('1' if q.field_type=='integer' else 'any')"
                                         t-att-data-required="q.required and '1' or '0'"/>
                                </t>

                                <t t-elif="q.field_type == 'bool'">
                                  <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox"
                                           t-att-id="input_id"
                                           t-att-name="input_name"
                                           t-att-checked="val and 'checked' or None"/>
                                    <label class="form-check-label" t-att-for="input_id">Yes / No</label>
                                  </div>
                                </t>

                                <t t-elif="q.field_type == 'selection'">
                                  <select class="form-select"
                                          t-att-id="input_id"
                                          t-att-name="input_name"
                                          t-att-data-required="q.required and '1' or '0'">
                                    <option value="">Select an option...</option>
                                    <t t-foreach="q.option_ids.sorted('sequence')" t-as="opt">
                                      <option t-att-value="opt.id"
                                              t-att-selected="(str(val) == str(opt.id) or val == opt.value) and 'selected' or None">
                                        <t t-esc="opt.label"/>
                                      </option>
                                    </t>
                                  </select>
                                </t>

                                <t t-elif="q.field_type == 'multiselect'">
                                  <t t-set="vals" t-value="val or []"/>
                                  <div class="row g-2">
                                    <t t-foreach="q.option_ids.sorted('sequence')" t-as="opt">
                                      <div class="col-12 col-sm-6">
                                        <div class="form-check">
                                          <input class="form-check-input" type="checkbox"
                                                 t-att-name="input_name"
                                                 t-att-id="'opt_%s' % opt.id"
                                                 t-att-value="opt.id"
                                                 t-att-checked="((opt.value in vals) or (opt.id in vals)) and 'checked' or None"/>
                                          <label class="form-check-label" t-att-for="'opt_%s' % opt.id">
                                            <t t-esc="opt.label"/>
                                          </label>
                                        </div>
                                      </div>
                                    </t>
                                  </div>
                                </t>

                                <t t-elif="q.field_type == 'file'">
                                  <input class="form-control" type="file"
                                         t-att-id="input_id"
                                         t-att-name="input_name"/>
                                  <t t-if="val">
                                    <div class="alert alert-info py-1 px-2 mt-2 d-inline-block small mb-0">
                                      <i class="fa fa-check-circle me-1"/>File uploaded
                                    </div>
                                  </t>
                                </t>

                                <div class="o_df_save_status small mt-1 text-muted fst-italic"
                                     style="min-height: 20px;"
                                     t-att-data-status-for="input_name">
                                </div>

                              </div>
                            </t> </t> </div>
                      </section>
                    </t> <div class="alert alert-secondary border-0 rounded-3 d-flex align-items-center" role="alert">
                      <i class="fa fa-floppy-o fa-lg me-3"/>
                      <div>
                        <strong>Auto-save enabled</strong>
                        <div class="small">Your answers are saved automatically as you type. You can close this page and return later.</div>
                      </div>
                    </div>

                  </div>
                </div>
              </div>
            </div>

          </div>
        </t>
      </field>
    </record>

  </data>
</odoo>