<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="group_form_manager" model="res.groups">
            <field name="name">Dynamic Forms: Manager</field>
            <field name="category_id" ref="base.module_category_website"/>
        </record>

        <record id="group_form_reviewer" model="res.groups">
            <field name="name">Dynamic Forms: Reviewer</field>
            <field name="category_id" ref="base.module_category_website"/>
        </record>

        <record id="group_form_sensitive_viewer" model="res.groups">
            <field name="name">Dynamic Forms: Sensitive Viewer</field>
            <field name="category_id" ref="base.module_category_website"/>
        </record>

        <!-- Portal: allow access to own submissions -->
        <record id="rule_submission_portal_own" model="ir.rule">
            <field name="name">Portal: own submissions</field>
            <field name="model_id" ref="model_x_form_submission"/>
            <field name="domain_force">[('partner_id','=',user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <record id="rule_answer_portal_own" model="ir.rule">
            <field name="name">Portal: own answers</field>
            <field name="model_id" ref="model_x_form_answer"/>
            <field name="domain_force">[('submission_id.partner_id','=',user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <!-- Sensitive answers: portal can access own, internal access only for Sensitive Viewer/Manager -->
        <record id="rule_sensitive_answer_portal_own" model="ir.rule">
            <field name="name">Portal: own sensitive answers</field>
            <field name="model_id" ref="model_x_form_sensitive_answer"/>
            <field name="domain_force">[('submission_id.partner_id','=',user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <record id="rule_sensitive_answer_internal" model="ir.rule">
            <field name="name">Internal: sensitive answers restricted</field>
            <field name="model_id" ref="model_x_form_sensitive_answer"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="groups" eval="[(4, ref('dynamic_form_builder_portal.group_form_sensitive_viewer')), (4, ref('dynamic_form_builder_portal.group_form_manager'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>

    </data>
</odoo>
