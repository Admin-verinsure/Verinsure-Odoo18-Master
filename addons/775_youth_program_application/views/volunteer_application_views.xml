<odoo>
    <record id="view_youth_volunteer_application_form" model="ir.ui.view">
        <field name="name">youth.volunteer.application.form</field>
        <field name="model">youth.volunteer.application</field>
        <field name="arch" type="xml">
            <form string="Volunteer Application" class="o_notebook_wizard">

                <header>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,reviewed"/>

                    <field name="form_step" widget="statusbar"
                           statusbar_visible="step_1a,step_1b,step_homestay,step_1c,step_2e"
                           invisible="state != 'draft'"/>

                    <button name="action_prev_step" type="object" string="Previous" class="btn-secondary"
                            invisible="state != 'draft' or form_step == 'step_1a'"/>
                    <button name="action_next_step" type="object" string="Next" class="btn-primary"
                            invisible="state != 'draft'"/>

                    <button name="action_submit" type="object" string="Submit" class="btn-success"
                            invisible="state != 'draft'"/>
                </header>

                <sheet>
                    <group>
                        <field name="partner_id"/>
                        <field name="position_applied_for"/>
                        <field name="full_name"/>
                        <field name="email"/>
                        <field name="mobile"/>
                    </group>

                    <group string="1A - Applicant" invisible="form_step != 'step_1a'">
                        <field name="address_line1"/>
                        <field name="address_line2"/>
                        <field name="city"/>
                        <field name="region"/>
                        <field name="postal_code"/>
                        <field name="how_long_at_address"/>
                        <field name="previous_addresses_notes"/>
                        <field name="date_of_birth"/>
                        <field name="id_provided"/>
                        <field name="id_number"/>
                        <field name="consent_ack"/>
                        <field name="waiver_ack"/>
                        <field name="applicant_signature_name"/>
                        <field name="applicant_signed_on"/>
                    </group>

                    <group string="1B - Privacy (Internal)" invisible="form_step != 'step_1b'" groups="base.group_user">
                        <field name="privacy_id"
                               nolabel="1"
                               readonly="1"
                               context="{'default_application_id': id}"
                               mode="list,form"/>
                    </group>

                    <group string="Home Stay (2B-2D)" invisible="form_step != 'step_homestay'">
                        <field name="is_homestay_volunteer"/>

                        <group invisible="not is_homestay_volunteer">
                            <field name="employment_current"/>
                            <field name="employment_previous"/>
                            <field name="rotary_youth_program_history"/>
                            <field name="youth_volunteer_history"/>
                            <separator string="References"/>

                            <group>
                                <field name="ref1_name"/>
                                <field name="ref1_relationship"/>
                                <field name="ref1_phone"/>
                                <field name="ref1_email"/>
                            </group>
                            <group>
                                <field name="ref2_name"/>
                                <field name="ref2_relationship"/>
                                <field name="ref2_phone"/>
                                <field name="ref2_email"/>
                            </group>
                            <group>
                                <field name="ref3_name"/>
                                <field name="ref3_relationship"/>
                                <field name="ref3_phone"/>
                                <field name="ref3_email"/>
                            </group>

                            <field name="qualifications_training"/>
                            <field name="homestay_confirmation_ack"/>
                            <field name="homestay_signature_name"/>
                            <field name="homestay_signed_on"/>
                        </group>

                        <div class="text-muted" invisible="is_homestay_volunteer">
                            Home Stay sections are skipped because “Home Stay volunteer” is not checked.
                        </div>
                    </group>

                    <group string="1C - Sponsor" invisible="form_step != 'step_1c'">
                        <field name="sponsor_name"/>
                        <field name="sponsor_club"/>
                        <field name="sponsor_years_known"/>
                        <field name="sponsor_role"/>
                        <field name="sponsor_role_other" invisible="sponsor_role != 'other'"/>
                        <field name="sponsor_signature_name"/>
                        <field name="sponsor_signed_on"/>
                    </group>

                    <group string="2E - District Use Only" invisible="form_step != 'step_2e'">
                        <field name="district_police_check"/>
                        <field name="district_reference_checks"/>
                        <field name="district_home_visit"/>
                        <field name="district_notes"/>
                        <field name="district_signed_by"/>
                        <field name="district_signed_on"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_youth_volunteer_application_tree" model="ir.ui.view">
        <field name="name">youth.volunteer.application.tree</field>
        <field name="model">youth.volunteer.application</field>
        <field name="arch" type="xml">
            <list>
                <field name="full_name"/>
                <field name="partner_id"/>
                <field name="state"/>
                <field name="is_homestay_volunteer"/>
                <field name="applicant_signed_on"/>
            </list>
        </field>
    </record>

    <record id="view_youth_volunteer_privacy_tree" model="ir.ui.view">
        <field name="name">youth.volunteer.application.privacy.tree</field>
        <field name="model">youth.volunteer.application.privacy</field>
        <field name="arch" type="xml">
            <list>
                <field name="application_id"/>
                <field name="rotary_member"/>
                <field name="club_name_year_joined"/>
                <field name="criminal_q1"/>
                <field name="criminal_q2"/>
            </list>
        </field>
    </record>

    <record id="view_youth_volunteer_privacy_form" model="ir.ui.view">
        <field name="name">youth.volunteer.application.privacy.form</field>
        <field name="model">youth.volunteer.application.privacy</field>
        <field name="arch" type="xml">
            <form string="Volunteer Privacy (1B)">
                <sheet>
                    <group>
                        <field name="application_id"/>
                        <field name="rotary_member"/>
                        <field name="club_name_year_joined"/>
                        <field name="linkedin_profile"/>
                        <field name="facebook_profile"/>
                        <field name="cv_attachment_id"/>
                    </group>

                    <group string="Criminal History">
                        <field name="criminal_q1"/>
                        <field name="criminal_q2"/>
                        <field name="criminal_explain"
                               invisible="not criminal_q1 and not criminal_q2"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_youth_volunteer_applications" model="ir.actions.act_window">
        <field name="name">Volunteer Applications</field>
        <field name="res_model">youth.volunteer.application</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_youth_root" name="Youth Programs" sequence="10" groups="base.group_user"
              web_icon="775_youth_program_application,static/description/icon.png"/>
    <menuitem id="menu_youth_volunteer_applications" name="Volunteer Applications"
              parent="menu_youth_root"
              action="action_youth_volunteer_applications"
              sequence="20"
              groups="base.group_user"/>
</odoo>