<odoo>
  <template id="portal_volunteer_application_form" name="Volunteer Application (Portal)">
    <t t-call="portal.portal_layout">
      <t t-set="title">Volunteer Application</t>

      <div class="container my-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h2 class="mb-0">Volunteer Application</h2>
          <span class="badge bg-secondary" t-esc="app.state"/>
        </div>

        <t t-if="app.state != 'draft'">
          <div class="alert alert-success">
            Your application has been submitted. Editing is disabled.
          </div>
        </t>

        <form action="/my/volunteer-application/save" method="post" enctype="multipart/form-data">
          <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

          <h4 class="mt-3">Section 1A — Application &amp; Assurances (required)</h4>
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Position applied for</label>
              <input class="form-control" name="position_applied_for" t-att-value="app.position_applied_for or ''"
                     t-att-disabled="app.state != 'draft'"/>
            </div>
            <div class="col-md-6">
              <label class="form-label">Full name</label>
              <input class="form-control" name="full_name" t-att-value="app.full_name or ''"
                     t-att-disabled="app.state != 'draft'"/>
            </div>

            <div class="col-md-6">
              <label class="form-label">Email</label>
              <input class="form-control" name="email" type="email" t-att-value="app.email or ''"
                     t-att-disabled="app.state != 'draft'"/>
            </div>
            <div class="col-md-3">
              <label class="form-label">Mobile</label>
              <input class="form-control" name="mobile" t-att-value="app.mobile or ''"
                     t-att-disabled="app.state != 'draft'"/>
            </div>
            <div class="col-md-3">
              <label class="form-label">Phone</label>
              <input class="form-control" name="phone" t-att-value="app.phone or ''"
                     t-att-disabled="app.state != 'draft'"/>
            </div>

            <div class="col-12">
              <label class="form-label">Address</label>
              <input class="form-control" name="address_line1" t-att-value="app.address_line1 or ''"
                     t-att-disabled="app.state != 'draft'"/>
            </div>
            <div class="col-12">
              <label class="form-label">Address (line 2)</label>
              <input class="form-control" name="address_line2" t-att-value="app.address_line2 or ''"
                     t-att-disabled="app.state != 'draft'"/>
            </div>
            <div class="col-md-4">
              <label class="form-label">City</label>
              <input class="form-control" name="city" t-att-value="app.city or ''"
                     t-att-disabled="app.state != 'draft'"/>
            </div>
            <div class="col-md-4">
              <label class="form-label">Region/State</label>
              <input class="form-control" name="region" t-att-value="app.region or ''"
                     t-att-disabled="app.state != 'draft'"/>
            </div>
            <div class="col-md-4">
              <label class="form-label">Postal code</label>
              <input class="form-control" name="postal_code" t-att-value="app.postal_code or ''"
                     t-att-disabled="app.state != 'draft'"/>
            </div>

            <div class="col-md-6">
              <label class="form-label">How long at this address</label>
              <input class="form-control" name="how_long_at_address" t-att-value="app.how_long_at_address or ''"
                     t-att-disabled="app.state != 'draft'"/>
            </div>

            <div class="col-md-6">
              <label class="form-label">Date of birth</label>
              <input class="form-control" name="date_of_birth" type="date"
                     t-att-value="app.date_of_birth or ''"
                     t-att-disabled="app.state != 'draft'"/>
            </div>

            <div class="col-md-6">
              <label class="form-label">Photo ID type</label>
              <select class="form-select" name="id_provided" t-att-disabled="app.state != 'draft'">
                <option value="">Select…</option>
                <option value="dl" t-att-selected="app.id_provided=='dl'">Drivers licence</option>
                <option value="passport" t-att-selected="app.id_provided=='passport'">Passport</option>
                <option value="other" t-att-selected="app.id_provided=='other'">Other</option>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">ID number</label>
              <input class="form-control" name="id_number" t-att-value="app.id_number or ''"
                     t-att-disabled="app.state != 'draft'"/>
            </div>

            <div class="col-12">
              <label class="form-label">Previous residences (details / note)</label>
              <textarea class="form-control" name="previous_addresses_notes" rows="3"
                        t-att-disabled="app.state != 'draft'"><t t-esc="app.previous_addresses_notes or ''"/></textarea>
            </div>
          </div>

          <hr class="my-4"/>

          <h4>Section 1B — Privacy Controlled (sensitive)</h4>
          <p class="text-muted">
            This section is stored separately with restricted access.
          </p>

          <div class="row g-3">
            <div class="col-md-4 form-check mt-2 ms-2">
              <input class="form-check-input" type="checkbox" id="rotary_member" name="rotary_member"
                     t-att-checked="priv.rotary_member and 'checked' or None"
                     t-att-disabled="app.state != 'draft'"/>
              <label class="form-check-label" for="rotary_member">Member of Rotary/Rotaract club?</label>
            </div>
            <div class="col-md-8">
              <label class="form-label">Club name and year joined</label>
              <input class="form-control" name="club_name_year_joined" t-att-value="priv.club_name_year_joined or ''"
                     t-att-disabled="app.state != 'draft'"/>
            </div>

            <div class="col-md-6">
              <label class="form-label">LinkedIn profile</label>
              <input class="form-control" name="linkedin_profile" t-att-value="priv.linkedin_profile or ''"
                     t-att-disabled="app.state != 'draft'"/>
            </div>
            <div class="col-md-6">
              <label class="form-label">Facebook profile</label>
              <input class="form-control" name="facebook_profile" t-att-value="priv.facebook_profile or ''"
                     t-att-disabled="app.state != 'draft'"/>
            </div>

            <div class="col-md-6">
              <label class="form-label">Upload CV (optional)</label>
              <input class="form-control" type="file" name="cv_file" t-att-disabled="app.state != 'draft'"/>
            </div>

            <div class="col-12">
              <div class="form-check">
                <input class="form-check-input" type="checkbox" id="criminal_q1" name="criminal_q1"
                       t-att-checked="priv.criminal_q1 and 'checked' or None"
                       t-att-disabled="app.state != 'draft'"/>
                <label class="form-check-label" for="criminal_q1">
                  Charged/convicted/pleaded guilty to any crimes?
                </label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="checkbox" id="criminal_q2" name="criminal_q2"
                       t-att-checked="priv.criminal_q2 and 'checked' or None"
                       t-att-disabled="app.state != 'draft'"/>
                <label class="form-check-label" for="criminal_q2">
                  Subject to any court order involving abuse/violence/harassment?
                </label>
              </div>
            </div>

            <div class="col-12" id="criminal_explain_block">
              <label class="form-label">If yes, please explain (dates, country, province/state)</label>
              <textarea class="form-control" name="criminal_explain" rows="3"
                        t-att-disabled="app.state != 'draft'"><t t-esc="priv.criminal_explain or ''"/></textarea>
            </div>
          </div>

          <hr class="my-4"/>

          <h4>Consent &amp; Waiver</h4>
          <div class="form-check">
            <input class="form-check-input" type="checkbox" id="consent_ack" name="consent_ack"
                   t-att-checked="app.consent_ack and 'checked' or None"
                   t-att-disabled="app.state != 'draft'"/>
            <label class="form-check-label" for="consent_ack">
              I acknowledge and consent to required information checks.
            </label>
          </div>
          <div class="form-check mb-3">
            <input class="form-check-input" type="checkbox" id="waiver_ack" name="waiver_ack"
                   t-att-checked="app.waiver_ack and 'checked' or None"
                   t-att-disabled="app.state != 'draft'"/>
            <label class="form-check-label" for="waiver_ack">
              I acknowledge the waiver.
            </label>
          </div>

          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Applicant signature (type full name)</label>
              <input class="form-control" name="applicant_signature_name" t-att-value="app.applicant_signature_name or ''"
                     t-att-disabled="app.state != 'draft'"/>
            </div>
            <div class="col-md-3">
              <label class="form-label">Date</label>
              <input class="form-control" type="date" name="applicant_signed_on" t-att-value="app.applicant_signed_on or ''"
                     t-att-disabled="app.state != 'draft'"/>
            </div>
          </div>

          <hr class="my-4"/>

          <h4>Home Stay (Sections 2B–2D)</h4>
          <div class="form-check mb-2">
            <input class="form-check-input" type="checkbox" id="is_homestay_volunteer" name="is_homestay_volunteer"
                   t-att-checked="app.is_homestay_volunteer and 'checked' or None"
                   t-att-disabled="app.state != 'draft'"/>
            <label class="form-check-label" for="is_homestay_volunteer">
              I am involved in Home Stay programmes (show extra sections)
            </label>
          </div>

          <div id="homestay_block" class="border rounded p-3">
            <div class="row g-3">
              <div class="col-12">
                <label class="form-label">Employment history — current role</label>
                <textarea class="form-control" name="employment_current" rows="3"
                          t-att-disabled="app.state != 'draft'"><t t-esc="app.employment_current or ''"/></textarea>
              </div>
              <div class="col-12">
                <label class="form-label">Employment history — previous roles</label>
                <textarea class="form-control" name="employment_previous" rows="3"
                          t-att-disabled="app.state != 'draft'"><t t-esc="app.employment_previous or ''"/></textarea>
              </div>
              <div class="col-12">
                <label class="form-label">Rotary youth program history</label>
                <textarea class="form-control" name="rotary_youth_program_history" rows="3"
                          t-att-disabled="app.state != 'draft'"><t t-esc="app.rotary_youth_program_history or ''"/></textarea>
              </div>
              <div class="col-12">
                <label class="form-label">Volunteer history with youth</label>
                <textarea class="form-control" name="youth_volunteer_history" rows="3"
                          t-att-disabled="app.state != 'draft'"><t t-esc="app.youth_volunteer_history or ''"/></textarea>
              </div>

              <div class="col-12">
                <h5 class="mt-2">References (3)</h5>
              </div>

              <div class="col-md-3"><input class="form-control" name="ref1_name" placeholder="Ref 1 Name"
                    t-att-value="app.ref1_name or ''" t-att-disabled="app.state != 'draft'"/></div>
              <div class="col-md-3"><input class="form-control" name="ref1_relationship" placeholder="Relationship"
                    t-att-value="app.ref1_relationship or ''" t-att-disabled="app.state != 'draft'"/></div>
              <div class="col-md-3"><input class="form-control" name="ref1_phone" placeholder="Phone"
                    t-att-value="app.ref1_phone or ''" t-att-disabled="app.state != 'draft'"/></div>
              <div class="col-md-3"><input class="form-control" name="ref1_email" placeholder="Email"
                    t-att-value="app.ref1_email or ''" t-att-disabled="app.state != 'draft'"/></div>

              <div class="col-md-3"><input class="form-control" name="ref2_name" placeholder="Ref 2 Name"
                    t-att-value="app.ref2_name or ''" t-att-disabled="app.state != 'draft'"/></div>
              <div class="col-md-3"><input class="form-control" name="ref2_relationship" placeholder="Relationship"
                    t-att-value="app.ref2_relationship or ''" t-att-disabled="app.state != 'draft'"/></div>
              <div class="col-md-3"><input class="form-control" name="ref2_phone" placeholder="Phone"
                    t-att-value="app.ref2_phone or ''" t-att-disabled="app.state != 'draft'"/></div>
              <div class="col-md-3"><input class="form-control" name="ref2_email" placeholder="Email"
                    t-att-value="app.ref2_email or ''" t-att-disabled="app.state != 'draft'"/></div>

              <div class="col-md-3"><input class="form-control" name="ref3_name" placeholder="Ref 3 Name"
                    t-att-value="app.ref3_name or ''" t-att-disabled="app.state != 'draft'"/></div>
              <div class="col-md-3"><input class="form-control" name="ref3_relationship" placeholder="Relationship"
                    t-att-value="app.ref3_relationship or ''" t-att-disabled="app.state != 'draft'"/></div>
              <div class="col-md-3"><input class="form-control" name="ref3_phone" placeholder="Phone"
                    t-att-value="app.ref3_phone or ''" t-att-disabled="app.state != 'draft'"/></div>
              <div class="col-md-3"><input class="form-control" name="ref3_email" placeholder="Email"
                    t-att-value="app.ref3_email or ''" t-att-disabled="app.state != 'draft'"/></div>

              <div class="col-12">
                <label class="form-label">Qualifications / training</label>
                <textarea class="form-control" name="qualifications_training" rows="3"
                          t-att-disabled="app.state != 'draft'"><t t-esc="app.qualifications_training or ''"/></textarea>
              </div>

              <div class="col-12">
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" id="homestay_confirmation_ack" name="homestay_confirmation_ack"
                         t-att-checked="app.homestay_confirmation_ack and 'checked' or None"
                         t-att-disabled="app.state != 'draft'"/>
                  <label class="form-check-label" for="homestay_confirmation_ack">
                    I confirm the Home Stay information provided is correct.
                  </label>
                </div>
              </div>

              <div class="col-md-6">
                <label class="form-label">Home Stay signature (type full name)</label>
                <input class="form-control" name="homestay_signature_name" t-att-value="app.homestay_signature_name or ''"
                       t-att-disabled="app.state != 'draft'"/>
              </div>
              <div class="col-md-3">
                <label class="form-label">Date</label>
                <input class="form-control" type="date" name="homestay_signed_on" t-att-value="app.homestay_signed_on or ''"
                       t-att-disabled="app.state != 'draft'"/>
              </div>
            </div>
          </div>

          <hr class="my-4"/>

          <h4>Section 1C — Sponsor (required)</h4>
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Sponsor name</label>
              <input class="form-control" name="sponsor_name" t-att-value="app.sponsor_name or ''"
                     t-att-disabled="app.state != 'draft'"/>
            </div>
            <div class="col-md-6">
              <label class="form-label">Sponsor club</label>
              <input class="form-control" name="sponsor_club" t-att-value="app.sponsor_club or ''"
                     t-att-disabled="app.state != 'draft'"/>
            </div>
            <div class="col-md-4">
              <label class="form-label">Years known</label>
              <input class="form-control" name="sponsor_years_known" t-att-value="app.sponsor_years_known or ''"
                     t-att-disabled="app.state != 'draft'"/>
            </div>
            <div class="col-md-4">
              <label class="form-label">Sponsor role</label>
              <select class="form-select" name="sponsor_role" t-att-disabled="app.state != 'draft'">
                <option value="">Select…</option>
                <option value="president" t-att-selected="app.sponsor_role=='president'">President</option>
                <option value="governor" t-att-selected="app.sponsor_role=='governor'">District Governor</option>
                <option value="chair" t-att-selected="app.sponsor_role=='chair'">District Chair</option>
                <option value="other" t-att-selected="app.sponsor_role=='other'">Other</option>
              </select>
            </div>
            <div class="col-md-4" id="sponsor_role_other_block">
              <label class="form-label">If other, specify</label>
              <input class="form-control" name="sponsor_role_other" t-att-value="app.sponsor_role_other or ''"
                     t-att-disabled="app.state != 'draft'"/>
            </div>
            <div class="col-md-6">
              <label class="form-label">Sponsor signature (type full name)</label>
              <input class="form-control" name="sponsor_signature_name" t-att-value="app.sponsor_signature_name or ''"
                     t-att-disabled="app.state != 'draft'"/>
            </div>
            <div class="col-md-3">
              <label class="form-label">Date</label>
              <input class="form-control" type="date" name="sponsor_signed_on" t-att-value="app.sponsor_signed_on or ''"
                     t-att-disabled="app.state != 'draft'"/>
            </div>
          </div>

          <div class="mt-4 d-flex gap-2">
            <t t-if="app.state == 'draft'">
              <button class="btn btn-primary" type="submit">Save</button>
            </t>
          </div>
        </form>

        <t t-if="app.state == 'draft'">
          <form action="/my/volunteer-application/submit" method="post" class="mt-3">
            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
            <button class="btn btn-success" type="submit">Submit (Lock)</button>
          </form>
        </t>

      </div>
    </t>
  </template>
</odoo>
