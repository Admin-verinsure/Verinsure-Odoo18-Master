<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_auto_reconciliation_wizard_form" model="ir.ui.view">
        <field name="name">auto.reconciliation.wizard.form</field>
        <field name="model">auto.reconciliation.wizard</field>
        <field name="arch" type="xml">
            <form string="Review Reconciliation Matches">
                <!-- CRITICAL FIX 3: Declare hidden fields used in invisible expressions.
                     Odoo 18 requires every field referenced in invisible= to be present
                     in the view arch, even if not visible. Without this, the view throws
                     an internal server error on load. -->
                <field name="state" invisible="1"/>
                <field name="skipped_count" invisible="1"/>
                <field name="match_pairs_json" invisible="1"/>

                <sheet>
                    <div class="oe_title">
                        <h2>Review &amp; Confirm Reconciliation</h2>
                        <p class="text-muted">
                            Company: <field name="company_id" readonly="1" nolabel="1"/>
                        </p>
                    </div>

                    <group>
                        <group>
                            <field name="total_preview_count"
                                   string="Matches Found at Preview"
                                   readonly="1"/>
                        </group>
                        <group>
                            <field name="skipped_count"
                                   string="Skipped (reconciled by background sync)"
                                   readonly="1"
                                   invisible="skipped_count == 0"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Matched Transactions">
                            <field name="line_ids" readonly="1">
                                <list>
                                    <field name="selected"/>
                                    <field name="reconciliation_type" widget="badge"
                                        decoration-info="reconciliation_type == 'bank_statement'"
                                        decoration-success="reconciliation_type == 'customer_payment'"
                                        decoration-warning="reconciliation_type == 'vendor_payment'"
                                        decoration-danger="reconciliation_type == 'intercompany'"/>
                                    <field name="description"/>
                                    <field name="partner_name"/>
                                    <field name="amount" widget="monetary"/>
                                </list>
                            </field>
                        </page>
                    </notebook>

                    <div class="alert alert-info" role="alert" invisible="state == 'confirmed'">
                        <i class="fa fa-info-circle"/> Review the matches above.
                        Clicking <strong>Confirm</strong> applies only these exact transactions.
                        Any already reconciled by a background sync will be safely skipped.
                    </div>
                    <div class="alert alert-success" role="alert" invisible="state != 'confirmed'">
                        <i class="fa fa-check-circle"/> Reconciliation applied successfully.
                    </div>
                </sheet>
                <footer>
                    <button name="action_confirm"
                            string="Confirm &amp; Reconcile"
                            type="object"
                            class="btn-primary"
                            icon="fa-check"
                            invisible="state == 'confirmed'"
                            confirm="This will apply the listed reconciliations. Items already reconciled by background sync will be skipped. Continue?"/>
                    <button name="action_cancel"
                            string="Close"
                            type="object"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
