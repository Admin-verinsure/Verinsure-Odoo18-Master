<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ── Akahu multi-company rules ───────────────────────────────────── -->
        <record id="akahu_credential_company_rule" model="ir.rule">
            <field name="name">Akahu Credential: Multi-company</field>
            <field name="model_id" ref="model_akahu_credential"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('account.group_account_manager'))]"/>
        </record>

        <record id="akahu_account_company_rule" model="ir.rule">
            <field name="name">Akahu Account: Multi-company</field>
            <field name="model_id" ref="model_akahu_account"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('account.group_account_user'))]"/>
        </record>

        <!-- ── Reconciliation multi-company rules ─────────────────────────── -->
        <record id="auto_reconciliation_config_company_rule" model="ir.rule">
            <field name="name">Reconciliation Config: Multi-company</field>
            <field name="model_id" ref="model_auto_reconciliation_config"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('account.group_account_user'))]"/>
        </record>

        <record id="auto_reconciliation_log_company_rule" model="ir.rule">
            <field name="name">Reconciliation Log: Multi-company</field>
            <field name="model_id" ref="model_auto_reconciliation_log"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('account.group_account_user'))]"/>
        </record>

    </data>
</odoo>
