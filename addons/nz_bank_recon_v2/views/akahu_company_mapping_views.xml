<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_akahu_company_mapping_list" model="ir.ui.view">
        <field name="name">akahu.company.mapping.list</field>
        <field name="model">akahu.company.mapping</field>
        <field name="arch" type="xml">
            <list string="Inter-company Mappings" editable="top">
                <field name="company_id"/>
                <field name="partner_id"/>
                <field name="counterpart_company_id"/>
                <field name="notes"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_akahu_company_mapping_form" model="ir.ui.view">
        <field name="name">akahu.company.mapping.form</field>
        <field name="model">akahu.company.mapping</field>
        <field name="arch" type="xml">
            <form string="Inter-company Mapping">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="display_name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="company_id"/>
                            <field name="partner_id"/>
                            <field name="counterpart_company_id"/>
                        </group>
                        <group>
                            <field name="active"/>
                            <field name="notes"/>
                        </group>
                    </group>
                    <div class="alert alert-info" role="alert">
                        <i class="fa fa-info-circle me-2"/>
                        <strong>How to set this up:</strong> For each company pair, create
                        two mappings — one in each direction. E.g. if Company A posts IC entries
                        against partner "Company B", create a mapping:
                        <em>Company A | Partner "Company B" → Company B</em>, and the mirror.
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_akahu_company_mapping" model="ir.actions.act_window">
        <field name="name">Inter-company Mappings</field>
        <field name="res_model">akahu.company.mapping</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
