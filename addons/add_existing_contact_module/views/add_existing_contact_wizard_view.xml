
<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_add_existing_contact_wizard_form" model="ir.ui.view">
        <field name="name">add.existing.contact.wizard.form</field>
        <field name="model">add.existing.contact.wizard</field>
        <field name="arch" type="xml">
            <form string="Add Existing Contacts">
                <group>
                    <field name="contact_ids" widget="many2many_tags"/>
                </group>

                <footer>
                    <button name="action_add_contacts"
                            string="Add Selected Contacts"
                            type="object"
                            class="btn-primary"/>

                    <button string="Cancel"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
