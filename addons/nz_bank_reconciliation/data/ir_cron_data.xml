<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!--
            SEC-02 FIX: Dedicated technical user for cron jobs.

            Both crons previously ran as base.user_admin (full ERP admin).
            We create a minimal technical user that belongs only to the groups
            the crons actually need:
              - account.group_account_manager  (read akahu.account / journal)
              - base.group_user                (minimum portal/internal access)

            This limits blast radius if a bug in the cron logic is exploited.

            noupdate="1" prevents this record from being reset on module upgrade
            once an admin has adjusted the user's groups in the live database.
        -->
        <record id="user_akahu_cron" model="res.users">
            <field name="name">Akahu Cron (technical)</field>
            <field name="login">akahu_cron_technical</field>
            <!-- Internal user, not a portal or public user -->
            <field name="groups_id" eval="[
                (4, ref('base.group_user')),
                (4, ref('account.group_account_manager')),
            ]"/>
            <!-- Disable password login — this account is used only by the cron scheduler -->
            <field name="active">True</field>
        </record>

        <!-- Akahu: Sync bank transactions every hour -->
        <record id="ir_cron_akahu_sync" model="ir.cron">
            <field name="name">Akahu: Sync Bank Transactions (Hourly)</field>
            <field name="model_id" ref="model_akahu_sync_engine"/>
            <field name="state">code</field>
            <field name="code">model.cron_sync_all()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="active">True</field>
            <!-- SEC-02: Run as dedicated technical user, not full admin -->
            <field name="user_id" ref="user_akahu_cron"/>
        </record>

        <!-- Auto Reconciliation: Run daily after transactions have synced -->
        <record id="ir_cron_auto_reconciliation" model="ir.cron">
            <field name="name">Auto Reconciliation: Scheduled Run (Daily)</field>
            <field name="model_id" ref="model_auto_reconciliation_engine"/>
            <field name="state">code</field>
            <field name="code">model.cron_run_auto_reconciliation()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
            <!-- SEC-02: Run as dedicated technical user, not full admin -->
            <field name="user_id" ref="user_akahu_cron"/>
        </record>

        <!-- LOG RETENTION (clause 2.4.1.e): Purge logs older than 90 days -->
        <record id="ir_cron_akahu_log_purge" model="ir.cron">
            <field name="name">Akahu: Purge Old Sync Logs (Weekly)</field>
            <field name="model_id" ref="model_akahu_sync_log"/>
            <field name="state">code</field>
            <field name="code">model.cron_purge_old_logs(days=90)</field>
            <field name="interval_number">1</field>
            <field name="interval_type">weeks</field>
            <field name="active">True</field>
            <field name="user_id" ref="user_akahu_cron"/>
        </record>

        <record id="ir_cron_recon_log_purge" model="ir.cron">
            <field name="name">Auto Reconciliation: Purge Old Logs (Weekly)</field>
            <field name="model_id" ref="model_auto_reconciliation_log"/>
            <field name="state">code</field>
            <field name="code">model.cron_purge_old_logs(days=90)</field>
            <field name="interval_number">1</field>
            <field name="interval_type">weeks</field>
            <field name="active">True</field>
            <field name="user_id" ref="user_akahu_cron"/>
        </record>

    </data>
</odoo>
