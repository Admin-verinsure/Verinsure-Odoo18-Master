<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_auto_reconciliation_wizard_form" model="ir.ui.view">
        <field name="name">auto.reconciliation.wizard.form</field>
        <field name="model">auto.reconciliation.wizard</field>
        <field name="arch" type="xml">
            <form string="Review Reconciliation Matches">
                <sheet>
                    <div class="oe_title">
                        <h2>Review &amp; Confirm Reconciliation</h2>
                        <p class="text-muted">
                            Company: <field name="company_id" readonly="1" nolabel="1"/>
                        </p>
                    </div>

                    <group>
                        <field name="total_preview_count"
                               string="Total Matches Found"
                               readonly="1"/>
                    </group>

                    <notebook>
                        <page string="Matched Transactions">
                            <field name="line_ids" readonly="1">
                                <list>
                                    <field name="selected"/>
                                    <field name="reconciliation_type" widget="badge"
                                        decoration-info="reconciliation_type == 'bank_statement'"
                                        decoration-success="reconciliation_type == 'customer_payment'"
                                        decoration-warning="reconciliation_type == 'vendor_payment'"
                                        decoration-danger="reconciliation_type == 'intercompany'"/>
                                    <field name="description"/>
                                    <field name="partner_name"/>
                                    <field name="amount" widget="monetary"/>
                                </list>
                            </field>
                        </page>
                    </notebook>

                    <div class="alert alert-info" role="alert">
                        <i class="fa fa-info-circle"/> Review the matches above. Click <strong>Confirm &amp; Reconcile</strong> to apply them, or <strong>Cancel</strong> to go back.
                    </div>
                </sheet>
                <footer>
                    <button name="action_confirm"
                            string="Confirm &amp; Reconcile"
                            type="object"
                            class="btn-primary"
                            icon="fa-check"
                            confirm="This will apply all reconciliations. This action cannot be undone easily. Continue?"/>
                    <button name="action_cancel"
                            string="Cancel"
                            type="object"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
