<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- SEC-03: Credential revocation confirmation wizard -->
        <record id="view_akahu_credential_revoke_wizard_form" model="ir.ui.view">
            <field name="name">akahu.credential.revoke.wizard.form</field>
            <field name="model">akahu.credential.revoke.wizard</field>
            <field name="arch" type="xml">
                <form string="Revoke Akahu Credentials">
                    <sheet>
                        <group>
                            <field name="credential_id" invisible="1"/>
                            <field name="company_name" string="Company" readonly="1"/>
                            <field name="linked_accounts_count"
                                   string="Bank accounts that will also lose their User Tokens"
                                   readonly="1"/>
                        </group>
                        <div class="alert alert-danger" role="alert">
                            <strong>⚠️ Warning:</strong>
                            This will permanently clear the App Token, App Secret,
                            and all linked User Access Tokens for
                            <field name="company_name" readonly="1" nolabel="1"
                                   class="d-inline font-weight-bold"/>.
                            Akahu sync will stop immediately and cannot resume
                            until fresh credentials are entered.
                        </div>
                        <group>
                            <field name="confirm"
                                   string="I understand — clear all tokens for this company"/>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_revoke"
                                string="Revoke All Tokens"
                                type="object"
                                class="btn-danger"
                                data-hotkey="q"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

    </data>
</odoo>
