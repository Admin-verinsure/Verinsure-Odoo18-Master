<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ===================================================================
         1. ACCOUNTING DASHBOARD — Kanban card buttons
         =================================================================== -->
    <record id="view_account_journal_dashboard_akahu" model="ir.ui.view">
        <field name="name">account.journal.dashboard.kanban.akahu</field>
        <field name="model">account.journal</field>
        <field name="inherit_id" ref="account.account_journal_dashboard_kanban_view"/>
        <field name="arch" type="xml">

            <!-- Load Akahu fields into the kanban dataset -->
            <xpath expr="//field[@name='bank_account_id']" position="after">
                <field name="has_akahu"/>
                <field name="akahu_last_synced"/>
                <field name="akahu_is_active"/>
            </xpath>

            <!-- Add Akahu buttons inside bank journal card actions -->
            <xpath expr="//div[@name='bank_cash_buttons']" position="inside">

                <!--
                    Show "Configure Bank Account" only when Akahu feed is active
                    but no akahu.account record is linked yet — guides user to finish setup.
                -->
                <t t-if="record.akahu_is_active.raw_value and !record.has_akahu.raw_value">
                    <button name="action_configure_akahu_account"
                            type="object"
                            class="btn btn-primary">
                        <i class="fa fa-bank me-1"/>
                        Configure Bank Account
                    </button>
                </t>

                <!-- Fully configured: show gear + fetch buttons -->
                <t t-if="record.akahu_is_active.raw_value and record.has_akahu.raw_value">

                    <button name="action_configure_akahu_account"
                            type="object"
                            class="btn btn-secondary"
                            title="Edit Akahu bank account configuration">
                        <i class="fa fa-cog me-1"/>
                        Bank Account
                    </button>

                    <button name="action_fetch_akahu_transactions"
                            type="object"
                            class="btn btn-primary">
                        <i class="fa fa-refresh me-1"/>
                        Fetch Transactions
                    </button>

                    <t t-if="record.akahu_last_synced.raw_value">
                        <span class="text-muted ms-2 small">
                            Last Sync: <t t-esc="record.akahu_last_synced.value"/>
                        </span>
                    </t>

                </t>

            </xpath>

        </field>
    </record>

    <!-- ===================================================================
         2. JOURNAL FORM — add Akahu radio option + conditional banner
         =================================================================== -->
    <record id="view_account_journal_form_akahu_feeds" model="ir.ui.view">
        <field name="name">account.journal.form.akahu.feeds</field>
        <field name="model">account.journal</field>
        <field name="inherit_id" ref="account.view_account_journal_form"/>
        <field name="arch" type="xml">

            <!--
                Inject akahu_is_active as a hidden field so it can drive
                visibility of the banner further down the form.
                Placed after bank_account_id which is always present on bank journals.
            -->
            <xpath expr="//field[@name='bank_account_id']" position="after">
                <field name="akahu_is_active" invisible="1"/>
            </xpath>

            <!--
                Replace the bank_statements_source field block entirely.

                Strategy in Odoo 18:
                  - The field already includes our new 'akahu' value via selection_add
                    in the Python model, so the radio widget renders all four options
                    automatically: Import (ofx) / Undefined Yet / Online (OCA) / Akahu (NZ)
                  - We place a conditional info banner directly AFTER the field.
                  - The banner is visible only when akahu is selected.
                  - No readonly tricks needed — the user owns the radio choice.
            -->
            <xpath expr="//field[@name='bank_statements_source']" position="after">
                <div class="alert alert-info d-flex align-items-center mt-2 mb-0"
                     role="alert"
                     invisible="bank_statements_source != 'akahu'">
                    <i class="fa fa-plug fa-lg me-3 text-info"/>
                    <div>
                        <strong>Akahu Bank Feed Active.</strong>
                        Transactions are fetched automatically via the Akahu (NZ Open Banking) integration.
                        The default Odoo Bank Feeds options above are inactive while Akahu is selected.
                    </div>
                </div>
            </xpath>

        </field>
    </record>

</odoo>
