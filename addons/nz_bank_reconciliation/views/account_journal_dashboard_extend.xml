<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_account_journal_dashboard_akahu" model="ir.ui.view">
        <field name="name">account.journal.dashboard.kanban.akahu</field>
        <field name="model">account.journal</field>
        <field name="inherit_id" ref="account.account_journal_dashboard_kanban_view"/>
        <field name="arch" type="xml">

            <!-- Load Akahu fields into the kanban dataset -->
            <xpath expr="//field[@name='bank_account_id']" position="after">
                <field name="has_akahu"/>
                <field name="akahu_last_synced"/>
                <field name="akahu_bank_feeds_disabled"/>
            </xpath>

            <!-- Only inject when Akahu IS configured on this journal.
                 When has_akahu is False we inject nothing — the native Odoo
                 Configure Bank Account button already handles that case. -->
            <xpath expr="//div[@name='bank_cash_buttons']" position="inside">
                <t t-if="record.has_akahu.raw_value">
                    <button name="action_configure_akahu_account"
                            type="object"
                            class="btn btn-secondary"
                            title="Edit Akahu bank account configuration">
                        <i class="fa fa-cog me-1"/>
                        Bank Account
                    </button>
                    <button name="action_fetch_akahu_transactions"
                            type="object"
                            class="btn btn-primary">
                        <i class="fa fa-refresh me-1"/>
                        Fetch Transactions
                    </button>
                    <t t-if="record.akahu_last_synced.raw_value">
                        <span class="text-muted ms-2 small">
                            Last Sync: <t t-esc="record.akahu_last_synced.value"/>
                        </span>
                    </t>
                </t>
            </xpath>

        </field>
    </record>

    <record id="view_account_journal_form_akahu_feeds" model="ir.ui.view">
        <field name="name">account.journal.form.akahu.feeds</field>
        <field name="model">account.journal</field>
        <field name="inherit_id" ref="account.view_account_journal_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='bank_account_id']" position="after">
                <field name="akahu_bank_feeds_disabled" invisible="1"/>
            </xpath>
            <xpath expr="//field[@name='bank_statements_source']" position="after">
                <div class="alert alert-info d-flex align-items-center mt-2 mb-0"
                     role="alert"
                     invisible="bank_statements_source != 'akahu'">
                    <i class="fa fa-plug fa-lg me-3"/>
                    <div>
                        <strong>Akahu Bank Feed Active.</strong>
                        Transactions are fetched automatically via the Akahu (NZ Open Banking) integration.
                        The default Odoo Bank Feeds options are inactive while Akahu is selected.
                    </div>
                </div>
            </xpath>
        </field>
    </record>

</odoo>
