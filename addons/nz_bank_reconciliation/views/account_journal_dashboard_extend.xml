<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_account_journal_dashboard_akahu" model="ir.ui.view">
        <field name="name">account.journal.dashboard.kanban.akahu</field>
        <field name="model">account.journal</field>
        <field name="inherit_id" ref="account.account_journal_dashboard_kanban_view"/>
        <field name="arch" type="xml">

            <!-- Load Akahu fields into the kanban dataset -->
            <xpath expr="//field[@name='bank_account_id']" position="after">
                <field name="has_akahu"/>
                <field name="akahu_last_synced"/>
                <field name="akahu_bank_feeds_disabled"/>
            </xpath>

            <!-- Add Akahu buttons in bank journal actions -->
            <xpath expr="//div[@name='bank_cash_buttons']" position="inside">

                <!-- Configure Bank Account button: shown when NO Akahu account is set up yet -->
                <t t-if="!record.has_akahu.raw_value">
                    <button name="action_configure_akahu_account"
                            type="object"
                            class="btn btn-primary">
                        <i class="fa fa-bank me-1"/>
                        Configure Bank Account
                    </button>
                </t>

                <!-- Fetch Transactions + last-sync info: shown when Akahu IS configured -->
                <t t-if="record.has_akahu.raw_value">

                    <!-- Re-configure button (secondary, always visible when configured) -->
                    <button name="action_configure_akahu_account"
                            type="object"
                            class="btn btn-secondary"
                            title="Edit Akahu bank account configuration">
                        <i class="fa fa-cog me-1"/>
                        Bank Account
                    </button>

                    <!-- Fetch Transactions button -->
                    <button name="action_fetch_akahu_transactions"
                            type="object"
                            class="btn btn-primary">
                        <i class="fa fa-refresh me-1"/>
                        Fetch Transactions
                    </button>

                    <t t-if="record.akahu_last_synced.raw_value">
                        <span class="text-muted ms-2 small">
                            Last Sync:
                            <t t-esc="record.akahu_last_synced.value"/>
                        </span>
                    </t>

                </t>

            </xpath>

            <!--
                Disable the native Odoo "Bank Feeds" (bank_statements_source) field
                when an active Akahu integration is configured for this journal.

                In Odoo 18 the bank feed provider selector lives inside
                account_journal_form (not the dashboard kanban), so we also
                inherit that form view to show a warning banner and make the
                field readonly when Akahu is active.
            -->

        </field>
    </record>

    <!--
        Inherit the Journal *form* view to:
          1. Load the akahu_bank_feeds_disabled field.
          2. Show an info banner explaining that Bank Feeds are managed by Akahu.
          3. Make the bank_statements_source selector invisible/readonly when Akahu
             is configured — preventing conflicts with the Odoo native bank feed.
    -->
    <record id="view_account_journal_form_akahu_feeds" model="ir.ui.view">
        <field name="name">account.journal.form.akahu.feeds</field>
        <field name="model">account.journal</field>
        <field name="inherit_id" ref="account.view_account_journal_form"/>
        <field name="arch" type="xml">

            <!-- Inject our computed field so it is available in the form -->
            <xpath expr="//field[@name='bank_account_id']" position="after">
                <field name="akahu_bank_feeds_disabled" invisible="1"/>
            </xpath>

            <!--
                In Odoo 18 the bank feed selector field is named
                `bank_statements_source`. We wrap it in a conditional block:
                  - When Akahu is active  → show a readonly info badge + hide the selector.
                  - When Akahu is absent  → show the selector as normal.
            -->
            <xpath expr="//field[@name='bank_statements_source']" position="before">
                <div class="alert alert-info d-flex align-items-center mb-2"
                     role="alert"
                     invisible="not akahu_bank_feeds_disabled">
                    <i class="fa fa-plug fa-lg me-2"/>
                    <span>
                        <strong>Akahu Bank Feed Active.</strong>
                        Transactions are fetched automatically via the Akahu integration.
                        The default Odoo Bank Feeds option is disabled to prevent duplicate imports.
                    </span>
                </div>
            </xpath>

            <!-- Make bank_statements_source readonly + visually indicate it is managed by Akahu -->
            <xpath expr="//field[@name='bank_statements_source']" position="attributes">
                <attribute name="readonly">akahu_bank_feeds_disabled</attribute>
                <attribute name="help">Managed by the Akahu integration when an active Akahu bank account is configured for this journal.</attribute>
            </xpath>

        </field>
    </record>

</odoo>
