<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_akahu_account_form" model="ir.ui.view">
        <field name="name">akahu.account.form</field>
        <field name="model">akahu.account</field>
        <field name="arch" type="xml">
            <form string="Akahu Bank Account">
                <header>
                    <button name="action_refresh_account_info"
                            string="Refresh Account Info"
                            type="object"
                            class="btn-secondary"
                            icon="fa-refresh"/>
                    <button name="action_sync_transactions"
                            string="Sync Transactions Now"
                            type="object"
                            class="btn-primary"
                            icon="fa-download"
                            attrs="{'invisible': [('akahu_status', '=', 'INACTIVE')]}"/>
                </header>
                <sheet>
                    <!-- INACTIVE warning banner -->
                    <div class="alert alert-danger d-flex align-items-center"
                         role="alert"
                         attrs="{'invisible': [('akahu_status', '!=', 'INACTIVE')]}">
                        <i class="fa fa-exclamation-triangle fa-2x me-3"/>
                        <div>
                            <strong>⚠️ This account is INACTIVE on Akahu.</strong><br/>
                            Akahu can no longer fetch transactions for this account.
                            The bank account owner must reconnect via the Akahu OAuth flow.
                            No new transactions will be synced until this is resolved.
                        </div>
                    </div>

                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>

                    <group>
                        <group string="Configuration">
                            <field name="company_id"/>
                            <field name="credential_id"/>
                            <field name="journal_id"/>
                            <field name="user_token"
                                   placeholder="user_token_xxxxxxxxxxxxxxxxxxxxxxx"/>
                            <field name="active"/>
                        </group>
                        <group string="Akahu Account Info (read-only)">
                            <field name="bank_name"/>
                            <field name="akahu_formatted_account"/>
                            <field name="akahu_account_name"/>
                            <field name="akahu_account_id"/>
                            <field name="akahu_status"
                                   widget="badge"
                                   decoration-success="akahu_status == 'ACTIVE'"
                                   decoration-danger="akahu_status == 'INACTIVE'"
                                   decoration-warning="akahu_status == 'UNKNOWN'"/>
                            <field name="balance_available"/>
                        </group>
                    </group>
                    <group string="Sync Status">
                        <group>
                            <field name="last_refreshed"/>
                            <field name="last_synced"/>
                        </group>
                        <group>
                            <field name="sync_cursor" readonly="1"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_akahu_account_list" model="ir.ui.view">
        <field name="name">akahu.account.list</field>
        <field name="model">akahu.account</field>
        <field name="arch" type="xml">
            <list string="Akahu Bank Accounts"
                  decoration-danger="akahu_status == 'INACTIVE'"
                  decoration-success="akahu_status == 'ACTIVE'"
                  decoration-muted="akahu_status == 'UNKNOWN'">
                <field name="company_id" optional="show"/>
                <field name="bank_name"/>
                <field name="akahu_account_name"/>
                <field name="akahu_formatted_account"/>
                <field name="journal_id"/>
                <field name="akahu_status"
                       widget="badge"
                       decoration-success="akahu_status == 'ACTIVE'"
                       decoration-danger="akahu_status == 'INACTIVE'"
                       decoration-warning="akahu_status == 'UNKNOWN'"/>
                <field name="balance_available"/>
                <field name="last_synced"/>
                <button name="action_sync_transactions"
                        type="object"
                        string="Sync"
                        icon="fa-download"
                        class="btn-sm btn-primary"
                        attrs="{'invisible': [('akahu_status', '=', 'INACTIVE')]}"/>
                <button name="action_refresh_account_info"
                        type="object"
                        string="Refresh"
                        icon="fa-refresh"
                        class="btn-sm btn-secondary"/>
            </list>
        </field>
    </record>

    <record id="action_akahu_account" model="ir.actions.act_window">
        <field name="name">Akahu Bank Accounts</field>
        <field name="res_model">akahu.account</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
