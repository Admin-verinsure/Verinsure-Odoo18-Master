<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_akahu_credential_form" model="ir.ui.view">
        <field name="name">akahu.credential.form</field>
        <field name="model">akahu.credential</field>
        <field name="arch" type="xml">
            <form string="Akahu API Credentials">
                <header>
                    <button name="action_test_connection"
                            string="Test Connection"
                            type="object"
                            class="btn-primary"
                            icon="fa-plug"/>
                    <!-- SEC-03: Token rotation / revocation (SOW clause 2.2.1.d) -->
                    <button name="action_revoke_credentials"
                            string="Revoke Credentials…"
                            type="object"
                            class="btn-danger"
                            icon="fa-trash"
                            confirm="This will open a confirmation step before clearing any credentials."
                            groups="base.group_erp_manager"/>
                </header>
                <sheet>
                    <!-- Error Ribbon -->
                    <widget name="web_ribbon"
                            title="Error"
                            bg_color="bg-danger"
                            invisible="connection_status != 'error'"/>

                    <!-- Connected Ribbon -->
                    <widget name="web_ribbon"
                            title="Connected"
                            bg_color="bg-success"
                            invisible="connection_status != 'ok'"/>

                    <div class="oe_title">
                        <h1><field name="company_id" readonly="1"/></h1>
                    </div>

                    <group string="Akahu App Credentials">
                        <group>
                            <field name="app_token"
                                   placeholder="app_token_xxxxxxxxxxxxxxxxxxxxxxx"/>
                            <field name="app_secret"
                                   placeholder="Your Akahu App Secret"/>
                        </group>

                        <group string="Connection Status">
                            <field name="connection_status"
                                   widget="badge"
                                   decoration-success="connection_status == 'ok'"
                                   decoration-danger="connection_status == 'error'"
                                   decoration-warning="connection_status == 'untested'"/>
                            <field name="last_tested"/>

                            <field name="error_message"
                                   invisible="not error_message"/>
                        </group>
                    </group>

                    <div class="alert alert-info" role="alert">
                        <i class="fa fa-info-circle me-2"/>
                        <strong>Where to find your credentials:</strong>
                        Log in at <a href="https://my.akahu.nz" target="_blank">my.akahu.nz</a>,
                        go to <strong>Developers → Your App</strong> to find your
                        App Token and App Secret. Keep your App Secret confidential.
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_akahu_credential_list" model="ir.ui.view">
        <field name="name">akahu.credential.list</field>
        <field name="model">akahu.credential</field>
        <field name="arch" type="xml">
            <list string="Akahu Credentials">
                <field name="company_id"/>
                <field name="app_token"/>
                <field name="connection_status"
                       widget="badge"
                       decoration-success="connection_status == 'ok'"
                       decoration-danger="connection_status == 'error'"
                       decoration-warning="connection_status == 'untested'"/>
                <field name="last_tested"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="action_akahu_credential" model="ir.actions.act_window">
        <field name="name">Akahu Credentials</field>
        <field name="res_model">akahu.credential</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>