<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_akahu_sync_log_list" model="ir.ui.view">
        <field name="name">akahu.sync.log.list</field>
        <field name="model">akahu.sync.log</field>
        <field name="arch" type="xml">
            <list string="Akahu Sync Logs"
                  decoration-success="status == 'success'"
                  decoration-danger="status == 'error'"
                  decoration-warning="status == 'partial'">
                <field name="name"/>
                <field name="company_id"/>
                <field name="akahu_account_id"/>
                <field name="transactions_fetched"/>
                <field name="transactions_imported"/>
                <field name="transactions_skipped"/>
                <field name="status" widget="badge"
                    decoration-success="status == 'success'"
                    decoration-danger="status == 'error'"/>
                <field name="create_date" string="Sync Time"/>
                <field name="error_message" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="action_akahu_sync_log" model="ir.actions.act_window">
        <field name="name">Akahu Sync Logs</field>
        <field name="res_model">akahu.sync.log</field>
        <field name="view_mode">list</field>
    </record>
</odoo>
