<odoo>
    <template id="customer_statement_pdf">
        <t t-call="web.external_layout">
            <t t-foreach="docs" t-as="w">
                <t t-set="data" t-value="w._get_statement_data()"/>

                <h2>Customer Statement</h2>
                <p><strong t-esc="data['partner'].name"/></p>

                <table class="table table-sm table-bordered">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Document</th>
                            <th>Type</th>
                            <th>Debit</th>
                            <th>Credit</th>
                            <th>Balance</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="data['lines']" t-as="l">
                            <tr>
                                <td><t t-esc="l['date']"/></td>
                                <td><t t-esc="l['name']"/></td>
                                <td><t t-esc="l['type']"/></td>
                                <td><t t-esc="l['debit']"/></td>
                                <td><t t-esc="l['credit']"/></td>
                                <td><t t-esc="l['balance']"/></td>
                            </tr>
                        </t>
                    </tbody>
                </table>

                <h3>Net Balance: <t t-esc="data['closing_balance']"/></h3>

            </t>
        </t>
    </template>

    <report id="action_customer_statement_pdf"
        model="customer.statement.wizard"
        string="Customer Statement"
        report_type="qweb-pdf"
        name="customer_statement_report.customer_statement_pdf"/>
</odoo>
