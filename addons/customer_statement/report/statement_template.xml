<odoo>
<template id="statement_template">
    <t t-call="web.external_layout">
        <div class="page">
            <h2>Customer Statement</h2>
            <p><t t-esc="doc.partner_id.name"/></p>
            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Type</th>
                        <th>Number</th>
                        <th>Debit</th>
                        <th>Credit</th>
                        <th>Balance</th>
                    </tr>
                </thead>
                <tbody>
                    <t t-set="balance" t-value="0"/>
                    <t t-foreach="doc._get_moves()" t-as="m">
                        <t t-set="debit" t-value="m.amount_total if m.move_type == 'out_invoice' else 0"/>
                        <t t-set="credit" t-value="m.amount_total if m.move_type == 'out_refund' else 0"/>
                        <t t-set="balance" t-value="balance + debit - credit"/>
                        <tr>
                            <td><t t-esc="m.invoice_date"/></td>
                            <td><t t-esc="m.move_type"/></td>
                            <td><t t-esc="m.name"/></td>
                            <td><t t-esc="debit"/></td>
                            <td><t t-esc="credit"/></td>
                            <td><t t-esc="balance"/></td>
                        </tr>
                    </t>
                </tbody>
            </table>
        </div>
    </t>
</template>
</odoo>
