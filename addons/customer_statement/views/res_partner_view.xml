<odoo>
    <record id="view_partner_form_statement" model="ir.ui.view">
        <field name="name">res.partner.statement.button</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <header position="inside">
                <button name="action_open_customer_statement"
                        type="object"
                        string="Customer Statement"
                        class="btn-primary"
                        invisible="customer_rank == 0"/>
            </header>
        </field>
    </record>
</odoo>