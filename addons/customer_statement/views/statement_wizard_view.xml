<odoo>
    <record id="view_customer_statement_wizard" model="ir.ui.view">
        <field name="name">customer.statement.wizard.form</field>
        <field name="model">customer.statement.wizard</field>
        <field name="arch" type="xml">
            <form string="Customer Statement">
                <group>
                    <field name="partner_id"/>
                    <field name="date_from"/>
                    <field name="date_to"/>
                </group>
                <footer>
                    <button string="PDF" type="object" name="action_generate_pdf" class="btn-primary"/>
                    <button string="Excel" type="object" name="action_generate_excel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
