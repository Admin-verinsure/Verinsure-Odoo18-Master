<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="email_template_customer_invoice" model="mail.template">
    <field name="name">Customer Invoice - Auto Send</field>
    <field name="model_id" ref="account.model_account_move"/>
    <field name="subject">Invoice ${object.name}</field>

    <field name="body_html" type="html">
      <div>
        <p>Hello ${object.partner_id.name or ''},</p>
        <p>Please find your invoice <strong>${object.name}</strong> attached.</p>
        <p>Amount due: ${format_amount(object.amount_total, object.currency_id)}</p>
        <p>Regards,<br/>${object.company_id.name}</p>
      </div>
    </field>

    <!-- addresses -->
    <field name="email_from">${(object.company_id.email or '')}</field>
    <field name="email_to">${object.partner_id.email}</field>
    <field name="lang">${object.partner_id.lang}</field>
    <field name="auto_delete" eval="True"/>

    <!-- attach the PDF -->
    <field name="report_template_id" ref="account.account_invoices_without_payment"/>
    <field name="report_filename">Invoice_${(object.name or '').replace('/','_')}</field>
  </record>
</odoo>
