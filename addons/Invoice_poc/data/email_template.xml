<!-- invoice_poc/data/email_template.xml -->
<odoo>
  <record id="email_template_customer_invoice" model="mail.template">
    <field name="name">Customer Invoice (Auto Send)</field>
    <field name="model_id" ref="account.model_account_move"/>
    <field name="subject">Invoice ${object.name} - ${object.company_id.name}</field>
    <field name="email_from">${(object.company_id.email or user.email) | safe}</field>
    <field name="email_to">${object.partner_id.email}</field>
    <field name="auto_delete" eval="True"/>
    <field name="body_html" type="html">
      <![CDATA[
        <p>Dear ${object.partner_id.name or 'Customer'},</p>
        <p>Please find your invoice <strong>${object.name}</strong> from
           <strong>${object.company_id.name}</strong>.</p>
        <p>Total due: <strong>${format_amount(object.amount_total, object.currency_id)}</strong><br/>
           Due date: <strong>${object.invoice_date_due or ''}</strong></p>

        <p>You can view it in Odoo:
          <a href="/odoo/action-account.action_move_out_invoice_type?res_id=${object.id}&amp;cids=${object.company_id.id}">
            Open Invoice
          </a>
        </p>

        <hr/>
        % if object.narration:
          <p><strong>Terms &amp; Notes</strong></p>
          ${object.narration | safe}
        % endif

        <p>Kind regards,<br/>${object.company_id.name}</p>
      ]]>
    </field>

    
  </record>
</odoo>
