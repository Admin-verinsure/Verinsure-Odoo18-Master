<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- 1️⃣ Landing Page – Choose Member or Non-Member -->
        <template id="ldap_reset_password.signup_is_member" name="Choose Signup Type">
            <t t-call="web.login_layout">
                <div class="container text-center mt-5">
                    <h2 class="fw-bold mb-4">Are you a Rotary International Member?</h2>
                    <div class="d-flex justify-content-center gap-4">
                        <a href="/web/signup" class="btn btn-success px-5 py-2">Yes</a>
                        <a href="/web/signup_non_member" class="btn btn-dark px-5 py-2">No</a>
                    </div>
                </div>
            </t>
        </template>

        <!-- 2️⃣ Member Signup Form -->
        <template id="ldap_reset_password.signup" name="Rotary Member Signup">
            <t t-call="web.login_layout">
                <div class="container mt-5" style="max-width:600px;">
                    <h3 class="text-center mb-4">Rotary Member Signup</h3>

                    <t t-if="error">
                        <div class="alert alert-danger text-center"><t t-esc="error"/></div>
                    </t>

                    <form method="post" action="/web/signup" class="oe_signup_form">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                        <div class="mb-3">
                            <label>First Name</label>
                            <input type="text" name="first_name" class="form-control" required="required" t-att-value="first_name"/>
                        </div>

                        <div class="mb-3">
                            <label>Last Name</label>
                            <input type="text" name="last_name" class="form-control" required="required" t-att-value="last_name"/>
                        </div>

                        <div class="mb-3">
                            <label>Email</label>
                            <input type="email" name="email" class="form-control" required="required" t-att-value="email"/>
                        </div>

                        <div class="mb-3">
                            <label>Rotary International Number (5–8 digits)</label>
                            <input type="text" name="rotary_id" class="form-control" required="required" t-att-value="rotary_id"/>
                        </div>

                        <div class="mb-3">
                            <label>Program Type</label>
                            <select name="program_type_id" class="form-control" required="required">
                                <option value="">-- Select Program Type --</option>
                                <t t-foreach="program_types" t-as="ptype">
                                    <option t-att-value="ptype.id"><t t-esc="ptype.name"/></option>
                                </t>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label>Club Name</label>
                            <select name="rotary_club_id" class="form-control" required="required">
                                <option value="">-- Select Club --</option>
                                <t t-foreach="clubs" t-as="club">
                                    <option t-att-value="club.id"><t t-esc="club.club_name or club.name"/></option>
                                </t>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label>Password</label>
                            <input type="password" name="password" class="form-control" required="required"/>
                        </div>

                        <div class="mb-3">
                            <label>Confirm Password</label>
                            <input type="password" name="confirm_password" class="form-control" required="required"/>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 mt-3">Sign up</button>

                        <div class="text-center mt-3">
                            <a href="/web/login">Already have an account?</a>
                        </div>
                    </form>
                </div>
            </t>
        </template>

        <!-- 3️⃣ Non-Member Signup Form -->
        <template id="ldap_reset_password.signup_non_member" name="Non-Member Signup">
            <t t-call="web.login_layout">
                <div class="container mt-5" style="max-width:600px;">
                    <h3 class="text-center mb-4">Non-Member Signup</h3>

                    <t t-if="error">
                        <div class="alert alert-danger text-center"><t t-esc="error"/></div>
                    </t>

                    <form method="post" action="/web/signup_non_member" class="oe_signup_form">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                        <div class="mb-3">
                            <label>First Name</label>
                            <input type="text" name="first_name" class="form-control" required="required" t-att-value="first_name"/>
                        </div>

                        <div class="mb-3">
                            <label>Last Name</label>
                            <input type="text" name="last_name" class="form-control" required="required" t-att-value="last_name"/>
                        </div>

                        <div class="mb-3">
                            <label>Email</label>
                            <input type="email" name="email" class="form-control" required="required" t-att-value="email"/>
                        </div>

                        <div class="mb-3">
                            <label>Program Type</label>
                            <select name="program_type_id" class="form-control" required="required">
                                <option value="">-- Select Program Type --</option>
                                <t t-foreach="program_types" t-as="ptype">
                                    <option t-att-value="ptype.id"><t t-esc="ptype.name"/></option>
                                </t>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label>Password</label>
                            <input type="password" name="password" class="form-control" required="required"/>
                        </div>

                        <div class="mb-3">
                            <label>Confirm Password</label>
                            <input type="password" name="confirm_password" class="form-control" required="required"/>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 mt-3">Sign up</button>

                        <div class="text-center mt-3">
                            <a href="/web/login">Already have an account?</a>
                        </div>
                    </form>
                </div>
            </t>
        </template>

        <!-- 4️⃣ Thank You Page -->
        <template id="ldap_reset_password.web_thanks" name="Signup Thank You">
            <t t-call="web.login_layout">
                <div class="container text-center mt-5">
                    <div class="alert alert-success">
                        <h4><t t-esc="message"/></h4>
                    </div>
                    <a href="/web/login" class="btn btn-primary mt-3">Go to Login</a>
                </div>
            </t>
        </template>

        <!-- 5️⃣ Error Page -->
        <template id="ldap_reset_password.web_error" name="Signup Error Page">
            <t t-call="web.login_layout">
                <div class="container text-center mt-5">
                    <div class="alert alert-danger">
                        <h4><t t-esc="message"/></h4>
                    </div>
                    <a href="/web/is_member" class="btn btn-secondary mt-3">Try Again</a>
                    <div class="mt-2">
                        <a href="/web/login">Back to Login</a>
                    </div>
                </div>
            </t>
        </template>

    </data>
</odoo>
