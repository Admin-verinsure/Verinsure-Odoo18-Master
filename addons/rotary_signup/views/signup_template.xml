<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data noupdate="0">

    <!-- 1) Landing – unchanged content, just simple centering -->
    <template id="ldap_reset_password.signup_is_member" name="Choose Signup Type">
      <t t-call="web.login_layout">
        <style type="text/css"><![CDATA[
          .simple-auth{max-width:640px;margin:48px auto}
          .simple-auth .title{margin-bottom:16px}
          .simple-auth .sub{color:#6b7280;margin-bottom:24px}
          .simple-auth .btn{border-radius:10px}
        ]]></style>

        <div class="container">
          <div class="simple-auth text-center">
            <h2 class="title fw-bold text-primary">Are you a Rotary International Member?</h2>
            <p class="sub">Choose your signup type to continue.</p>
            <div class="d-flex justify-content-center gap-3 flex-wrap">
              <a href="/web/signup" class="btn btn-dark px-5 py-2 fw-semibold">Yes, I’m a Member</a>
              <a href="/web/signup_non_member" class="btn btn-outline-secondary px-5 py-2 fw-semibold">No, I’m a Non-Member</a>
            </div>
          </div>
        </div>
      </t>
    </template>

    <!-- 2) Member Signup – same fields, simple look -->
    <template id="ldap_reset_password.signup" name="Rotary Member Signup">
      <t t-call="web.login_layout">
        <style type="text/css"><![CDATA[
          .simple-auth{max-width:640px;margin:48px auto}
          .simple-auth label{font-weight:600}
          .simple-auth .field{margin-bottom:16px}
          .simple-auth .btn-primary{background:#111;border-color:#111;border-radius:10px;padding:.7rem 1.5rem}
          .simple-auth .login-hint{margin-left:12px;color:#6b7280}
          .simple-auth .invalid-feedback{display:block}
        ]]></style>

        <div class="container">
          <div class="simple-auth">
            <h3 class="mb-3">Rotary Member Signup</h3>

            <t t-if="error">
              <div class="alert alert-danger mb-3"><t t-esc="error"/></div>
            </t>

            <form method="post" action="/web/signup" class="oe_signup_form needs-validation" novalidate="novalidate">
              <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

              <div class="field">
                <label>First Name</label>
                <input type="text" name="first_name" class="form-control" placeholder="e.g. John"
                       required="required" autocomplete="given-name" t-att-value="first_name"/>
              </div>

              <div class="field">
                <label>Last Name</label>
                <input type="text" name="last_name" class="form-control" placeholder="e.g. Smith"
                       required="required" autocomplete="family-name" t-att-value="last_name"/>
              </div>

              <div class="field">
                <label>Email</label>
                <input type="email" name="email" class="form-control" placeholder="e.g. example@example.com"
                       required="required" autocomplete="email" t-att-value="email"/>
              </div>

              <!-- Keep your extra member fields, just same minimal style -->
              <div class="field">
                <label>Rotary International Number</label>
                <input type="text" name="rotary_id" class="form-control" placeholder="5–8 digit Rotary ID"
                       required="required" t-att-value="rotary_id"/>
              </div>

              <div class="field">
                <label>Program Type</label>
                <select name="club_type" id="club_type" class="form-select" required="required">
                  <option value="">-- Select Program Type --</option>
                  <t t-set="club_types"
                     t-value="(env['res.partner']._fields.get('club_type') and env['res.partner']._fields['club_type'].selection) or []"/>
                  <t t-foreach="club_types" t-as="opt">
                    <option t-att-value="opt[0]" t-att-selected="request.params.get('club_type') == opt[0]">
                      <t t-esc="opt[1]"/>
                    </option>
                  </t>
                </select>
              </div>

              <div class="field">
                <label>Club Name</label>
                <select name="rotary_club_id" id="rotary_club_id" class="form-select" required="required">
                  <t t-set="sel_program" t-value="request.params.get('club_type')"/>
                  <t t-set="clubs"
                     t-value="sel_program
                              and env['res.partner'].sudo().search([('club_type', '=', sel_program), ('active', '=', True)], order='name')
                              or env['res.partner'].browse([])"/>
                  <t t-if="not sel_program">
                    <option value="">-- Select Program Type first --</option>
                  </t>
                  <t t-if="sel_program and not clubs">
                    <option value="">-- No clubs found for this program --</option>
                  </t>
                  <t t-foreach="clubs" t-as="c">
                    <option t-att-value="c.id"
                            t-att-selected="(request.params.get('rotary_club_id') and int(request.params.get('rotary_club_id') or 0) == c.id) or None">
                      <t t-esc="c.club_name or c.name"/>
                    </option>
                  </t>
                </select>
              </div>

              <div class="field">
                <label>Password</label>
                <input type="password" name="password" id="m_password" class="form-control"
                       required="required" autocomplete="new-password"/>
              </div>

              <div class="field">
                <label>Confirm Password</label>
                <input type="password" name="confirm_password" id="m_confirm" class="form-control"
                       required="required" autocomplete="new-password"/>
                <div class="invalid-feedback" id="m_msg" style="display:none">Passwords do not match</div>
              </div>

              <div class="d-flex align-items-center">
                <button type="submit" class="btn btn-primary">Sign up</button>
                <span class="login-hint">Already have an account? <a href="/web/login">Sign in</a></span>
              </div>
            </form>
          </div>
        </div>

        <script type="text/javascript"><![CDATA[
          (function () {
            var form = document.querySelector('.needs-validation');
            if (!form) return;
            var p = document.getElementById('m_password');
            var c = document.getElementById('m_confirm');
            var msg = document.getElementById('m_msg');

            function checkMatch() {
              if (p && c && p.value && c.value && p.value !== c.value) {
                c.setCustomValidity('no-match');
                if (msg) msg.style.display = '';
              } else {
                if (c) c.setCustomValidity('');
                if (msg) msg.style.display = 'none';
              }
            }
            if (p) p.addEventListener('input', checkMatch);
            if (c) c.addEventListener('input', checkMatch);

            form.addEventListener('submit', function (e) {
              checkMatch();
              if (!form.checkValidity()) { e.preventDefault(); e.stopPropagation(); }
              form.classList.add('was-validated');
            }, false);
          })();
        ]]></script>
      </t>
    </template>

