<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data noupdate="0">

    <!-- =========================
         Shared minimal styles + helpers
         (kept inline to avoid extra asset files)
    ========================== -->
    <template id="ldap_reset_password._inline_assets" name="Signup Inline Assets" inherit_id="web.login_layout">
      <xpath expr="//body" position="before">
        <t t-set="__signup_inline_css">
          <style>
            .auth-bg {
              min-height: 100vh;
              background: radial-gradient(1200px 500px at 10% -10%, rgba(99,102,241,.08), transparent 60%),
                          radial-gradient(800px 400px at 120% 20%, rgba(16,185,129,.08), transparent 60%),
                          linear-gradient(180deg, #f8fafc, #ffffff);
            }
            .auth-card {
              border-radius: 1rem;
              border: 0;
              box-shadow: 0 10px 30px rgba(15,23,42,.08);
            }
            .auth-title {
              letter-spacing: .2px;
            }
            .input-icon {
              position: absolute; left: .9rem; top: 50%; transform: translateY(-50%);
              opacity: .55; pointer-events: none;
            }
            .has-icon input, .has-icon select {
              padding-left: 2.25rem;
            }
            .pw-meter {
              height: 6px; border-radius: 8px; background: #e5e7eb; overflow: hidden;
            }
            .pw-meter > span {display:block; height:100%; width:0;}
            .pw-weak {background:#ef4444;}
            .pw-fair {background:#f59e0b;}
            .pw-good {background:#10b981;}
            .pw-strong {background:#22c55e;}
            .small-muted {font-size:.875rem; color:#6b7280;}
          </style>
        </t>
      </xpath>
    </template>

    <!-- =========================
         1) Landing: choose signup type
    ========================== -->
    <template id="ldap_reset_password.signup_is_member" name="Choose Signup Type">
      <t t-call="web.login_layout">
        <div class="auth-bg d-flex align-items-center py-5">
          <div class="container">
            <div class="card auth-card mx-auto" style="max-width: 680px;">
              <div class="card-body p-5 text-center">
                <h2 class="fw-bold auth-title text-primary mb-2">Are you a Rotary International Member?</h2>
                <p class="text-muted mb-4">Select the appropriate option to continue creating your account.</p>
                <div class="d-flex flex-wrap justify-content-center gap-3">
                  <a href="/web/signup" class="btn btn-success px-5 py-2 fw-semibold shadow-sm">
                    <i class="fa fa-user-check me-2"></i> Yes, I’m a Member
                  </a>
                  <a href="/web/signup_non_member" class="btn btn-outline-secondary px-5 py-2 fw-semibold shadow-sm">
                    <i class="fa fa-user me-2"></i> No, I’m a Non-Member
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </t>
    </template>

    <!-- =========================
         2) Member Signup
    ========================== -->
    <template id="ldap_reset_password.signup" name="Rotary Member Signup">
      <t t-call="web.login_layout">
        <div class="auth-bg d-flex align-items-center py-5">
          <div class="container">
            <div class="card auth-card mx-auto" style="max-width: 720px;">
              <div class="card-body p-5">
                <div class="text-center mb-4">
                  <h3 class="fw-bold auth-title text-primary mb-1">Rotary Member Signup</h3>
                  <p class="text-muted">Create your account to access member features.</p>
                </div>

                <t t-if="error">
                  <div class="alert alert-danger text-center mb-4">
                    <i class="fa fa-exclamation-circle me-2"></i><t t-esc="error"/>
                  </div>
                </t>

                <form method="post" action="/web/signup" class="oe_signup_form needs-validation" novalidate="novalidate">
                  <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                  <div class="row g-3">
                    <div class="col-md-6 position-relative">
                      <label class="form-label fw-semibold">First Name</label>
                      <div class="has-icon">
                        <i class="fa fa-user input-icon"></i>
                        <input type="text" name="first_name" class="form-control form-control-lg" placeholder="e.g. John"
                               required="required" autocomplete="given-name" t-att-value="first_name"/>
                      </div>
                      <div class="invalid-feedback">First name is required.</div>
                    </div>
                    <div class="col-md-6 position-relative">
                      <label class="form-label fw-semibold">Last Name</label>
                      <div class="has-icon">
                        <i class="fa fa-user input-icon"></i>
                        <input type="text" name="last_name" class="form-control form-control-lg" placeholder="e.g. Smith"
                               required="required" autocomplete="family-name" t-att-value="last_name"/>
                      </div>
                      <div class="invalid-feedback">Last name is required.</div>
                    </div>

                    <div class="col-12 position-relative">
                      <label class="form-label fw-semibold">Email Address</label>
                      <div class="has-icon">
                        <i class="fa fa-envelope input-icon"></i>
                        <input type="email" name="email" class="form-control form-control-lg" placeholder="e.g. example@example.com"
                               required="required" autocomplete="email" t-att-value="email"/>
                      </div>
                      <div class="invalid-feedback">Please enter a valid email.</div>
                    </div>

                    <div class="col-md-6 position-relative">
                      <label class="form-label fw-semibold">Rotary International Number</label>
                      <div class="has-icon">
                        <i class="fa fa-id-badge input-icon"></i>
                        <input type="text" name="rotary_id" class="form-control form-control-lg" placeholder="5–8 digit Rotary ID"
                               pattern="^\d{5,8}$" required="required" t-att-value="rotary_id"/>
                      </div>
                      <div class="small-muted mt-1">Digits only, 5–8 in length.</div>
                      <div class="invalid-feedback">Enter a valid Rotary ID (5–8 digits).</div>
                    </div>

                    <div class="col-md-6 position-relative">
                      <label class="form-label fw-semibold">Program Type</label>
                      <div class="has-icon">
                        <i class="fa fa-layer-group input-icon"></i>
                        <select name="club_type" id="club_type" class="form-select form-select-lg" required="required">
                          <option value="">-- Select Program Type --</option>
                          <t t-set="club_types"
                             t-value="(env['res.partner']._fields.get('club_type') and env['res.partner']._fields['club_type'].selection) or []"/>
                          <t t-foreach="club_types" t-as="opt">
                            <option t-att-value="opt[0]" t-att-selected="request.params.get('club_type') == opt[0]">
                              <t t-esc="opt[1]"/>
                            </option>
                          </t>
                        </select>
                      </div>
                      <div class="invalid-feedback">Please select a program type.</div>
                    </div>

                    <div class="col-12 position-relative">
                      <label class="form-label fw-semibold">Club Name</label>
                      <div class="has-icon">
                        <i class="fa fa-building input-icon"></i>
                        <select name="rotary_club_id" id="rotary_club_id" class="form-select form-select-lg" required="required">
                          <option value="">-- Select Program Type first --</option>
                        </select>
                      </div>
                      <div class="invalid-feedback">Please select your club.</div>
                    </div>

                    <div class="col-md-6 position-relative">
                      <label class="form-label fw-semibold">Password</label>
                      <div class="has-icon position-relative">
                        <i class="fa fa-lock input-icon"></i>
                        <input type="password" name="password" id="m_password" class="form-control form-control-lg"
                               required="required" autocomplete="new-password" placeholder="Minimum 8 characters"/>
                        <button type="button" class="btn btn-sm btn-outline-secondary position-absolute"
                                style="right:.5rem; top:50%; transform:translateY(-50%);" onclick="window.__togglePw('m_password', this)">
                          Show
                        </button>
                      </div>
                      <div class="pw-meter mt-2"><span id="m_pw_bar"></span></div>
                      <div class="small-muted mt-1">Use at least 8 characters and mix letters, numbers, or symbols.</div>
                      <div class="invalid-feedback">Please enter a password.</div>
                    </div>

                    <div class="col-md-6 position-relative">
                      <label class="form-label fw-semibold">Confirm Password</label>
                      <div class="has-icon position-relative">
                        <i class="fa fa-lock input-icon"></i>
                        <input type="password" name="confirm_password" id="m_confirm" class="form-control form-control-lg"
                               required="required" autocomplete="new-password" placeholder="Re-enter password"/>
                        <button type="button" class="btn btn-sm btn-outline-secondary position-absolute"
                                style="right:.5rem; top:50%; transform:translateY(-50%);" onclick="window.__togglePw('m_confirm', this)">
                          Show
                        </button>
                      </div>
                      <div class="invalid-feedback">Please confirm your password.</div>
                    </div>
                  </div>

                  <button type="submit" class="btn btn-primary btn-lg w-100 mt-4 shadow-sm">
                    <i class="fa fa-user-plus me-2"></i> Create My Account
                  </button>

                  <div class="text-center mt-3">
                    <small class="text-muted">Already have an account?</small>
                    <a href="/web/login" class="fw-semibold text-decoration-none ms-1">Sign in</a>
                  </div>
                </form>
              </div>
            </div>
          </div>
        </div>

        <!-- Page script (small, safe) -->
        <script type="text/javascript">
          (function () {
            // Bootstrap validation
            var forms = document.querySelectorAll('.needs-validation');
            Array.prototype.slice.call(forms).forEach(function (form) {
              form.addEventListener('submit', function (event) {
                // match passwords on client for instant feedback
                var p = form.querySelector('#m_password');
                var c = form.querySelector('#m_confirm');
                if (p && c && p.value !== c.value) {
                  c.setCustomValidity('Passwords do not match');
                } else if (c) {
                  c.setCustomValidity('');
                }
                if (!form.checkValidity()) {
                  event.preventDefault(); event.stopPropagation();
                }
                form.classList.add('was-validated');
              }, false);
            });

            // Password strength meter
            function score(pw) {
              if (!pw) return 0;
              var s = 0;
              if (pw.length >= 8) s++;
              if (/[A-Z]/.test(pw)) s++;
              if (/[a-z]/.test(pw)) s++;
              if (/\d/.test(pw)) s++;
              if (/[^A-Za-z0-9]/.test(pw)) s++;
              return Math.min(s, 4);
            }
            var pw = document.getElementById('m_password');
            var bar = document.getElementById('m_pw_bar');
            if (pw && bar) {
              pw.addEventListener('input', function () {
                var sc = score(pw.value);
                var widths = ['0%','25%','50%','75%','100%'];
                var classes = ['','pw-weak','pw-fair','pw-good','pw-strong'];
                bar.className = classes[sc];
                bar.style.width = widths[sc];
              });
            }

            // Show/hide password utility
            window.__togglePw = function (id, btn) {
              var el = document.getElementById(id);
              if (!el) return;
              if (el.type === 'password') { el.type = 'text'; btn.innerText = 'Hide'; }
              else { el.type = 'password'; btn.innerText = 'Show'; }
            };

            // Dynamic clubs by program
            var selProgram = document.getElementById('club_type');
            var selClub = document.getElementById('rotary_club_id');
            function loadClubs(programVal) {
              if (!programVal || !selClub) {
                if (selClub) selClub.innerHTML = '<option value="">-- Select Program Type first --</option>';
                return;
              }
              var payload = {jsonrpc: "2.0", method: "call", params: {program_type: programVal, context: {}}, id: Date.now()};
              fetch("/clubs/by_program", {
                method: "POST",
                headers: {"Content-Type": "application/json"},
                body: JSON.stringify(payload)
              }).then(function (r) { return r.json(); })
                .then(function (data) {
                  var items = (data && data.result) || [];
                  if (!Array.isArray(items)) items = [];
                  var html = items.length ? '' : '<option value="">-- No clubs found for this program --</option>';
                  items.forEach(function (c) {
                    html += '<option value="'+ c.id +'">'+ (c.name || 'Club') +'</option>';
                  });
                  selClub.innerHTML = html || '<option value="">-- Select a club --</option>';
                }).catch(function () {
                  selClub.innerHTML = '<option value="">-- Could not load clubs --</option>';
                });
            }
            if (selProgram) {
              selProgram.addEventListener('change', function () { loadClubs(this.value); });
              // initial fill if param present
              if (selProgram.value) loadClubs(selProgram.value);
            }
          })();
        </script>
      </t>
    </template>

    <!-- =========================
         3) Non-Member Signup
    ========================== -->
    <template id="ldap_reset_password.signup_non_member" name="Non-Member Signup">
      <t t-call="web.login_layout">
        <div class="auth-bg d-flex align-items-center py-5">
          <div class="container">
            <div class="card auth-card mx-auto" style="max-width: 720px;">
              <div class="card-body p-5">
                <div class="text-center mb-4">
                  <h3 class="fw-bold auth-title text-primary mb-1">Non-Member Signup</h3>
                  <p class="text-muted">Create a guest account to access the platform.</p>
                </div>

                <t t-if="error">
                  <div class="alert alert-danger text-center mb-4">
                    <i class="fa fa-exclamation-circle me-2"></i><t t-esc="error"/>
                  </div>
                </t>

                <form method="post" action="/web/signup_non_member" class="oe_signup_form needs-validation" novalidate="novalidate">
                  <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                  <div class="row g-3">
                    <div class="col-md-6 position-relative">
                      <label class="form-label fw-semibold">First Name</label>
                      <div class="has-icon">
                        <i class="fa fa-user input-icon"></i>
                        <input type="text" name="first_name" class="form-control form-control-lg" placeholder="e.g. John"
                               required="required" autocomplete="given-name" t-att-value="first_name"/>
                      </div>
                      <div class="invalid-feedback">First name is required.</div>
                    </div>
                    <div class="col-md-6 position-relative">
                      <label class="form-label fw-semibold">Last Name</label>
                      <div class="has-icon">
                        <i class="fa fa-user input-icon"></i>
                        <input type="text" name="last_name" class="form-control form-control-lg" placeholder="e.g. Smith"
                               required="required" autocomplete="family-name" t-att-value="last_name"/>
                      </div>
                      <div class="invalid-feedback">Last name is required.</div>
                    </div>

                    <div class="col-12 position-relative">
                      <label class="form-label fw-semibold">Email Address</label>
                      <div class="has-icon">
                        <i class="fa fa-envelope input-icon"></i>
                        <input type="email" name="email" class="form-control form-control-lg" placeholder="e.g. example@example.com"
                               required="required" autocomplete="email" t-att-value="email"/>
                      </div>
                      <div class="invalid-feedback">Please enter a valid email.</div>
                    </div>

                    <div class="col-md-6 position-relative">
                      <label class="form-label fw-semibold">Password</label>
                      <div class="has-icon position-relative">
                        <i class="fa fa-lock input-icon"></i>
                        <input type="password" name="password" id="n_password" class="form-control form-control-lg"
                               required="required" autocomplete="new-password" placeholder="Minimum 8 characters"/>
                        <button type="button" class="btn btn-sm btn-outline-secondary position-absolute"
                                style="right:.5rem; top:50%; transform:translateY(-50%);" onclick="window.__togglePw('n_password', this)">
                          Show
                        </button>
                      </div>
                      <div class="pw-meter mt-2"><span id="n_pw_bar"></span></div>
                      <div class="small-muted mt-1">Use at least 8 characters and mix letters, numbers, or symbols.</div>
                      <div class="invalid-feedback">Please enter a password.</div>
                    </div>

                    <div class="col-md-6 position-relative">
                      <label class="form-label fw-semibold">Confirm Password</label>
                      <div class="has-icon position-relative">
                        <i class="fa fa-lock input-icon"></i>
                        <input type="password" name="confirm_password" id="n_confirm" class="form-control form-control-lg"
                               required="required" autocomplete="new-password" placeholder="Re-enter password"/>
                        <button type="button" class="btn btn-sm btn-outline-secondary position-absolute"
                                style="right:.5rem; top:50%; transform:translateY(-50%);" onclick="window.__togglePw('n_confirm', this)">
                          Show
                        </button>
                      </div>
                      <div class="invalid-feedback">Please confirm your password.</div>
                    </div>
                  </div>

                  <button type="submit" class="btn btn-primary btn-lg w-100 mt-4 shadow-sm">
                    <i class="fa fa-user-plus me-2"></i> Create My Account
                  </button>

                  <div class="text-center mt-3">
                    <small class="text-muted">Already have an account?</small>
                    <a href="/web/login" class="fw-semibold text-decoration-none ms-1">Sign in</a>
                  </div>
                </form>
              </div>
            </div>
          </div>
        </div>

        <script type="text/javascript">
          (function () {
            // Bootstrap validation
            var forms = document.querySelectorAll('.needs-validation');
            Array.prototype.slice.call(forms).forEach(function (form) {
              form.addEventListener('submit', function (event) {
                var p = form.querySelector('#n_password');
                var c = form.querySelector('#n_confirm');
                if (p && c && p.value !== c.value) {
                  c.setCustomValidity('Passwords do not match');
                } else if (c) {
                  c.setCustomValidity('');
                }
                if (!form.checkValidity()) {
                  event.preventDefault(); event.stopPropagation();
                }
                form.classList.add('was-validated');
              }, false);
            });

            // Password strength (non-member)
            function score(pw) {
              if (!pw) return 0;
              var s = 0;
              if (pw.length >= 8) s++;
              if (/[A-Z]/.test(pw)) s++;
              if (/[a-z]/.test(pw)) s++;
              if (/\d/.test(pw)) s++;
              if (/[^A-Za-z0-9]/.test(pw)) s++;
              return Math.min(s, 4);
            }
            var pw = document.getElementById('n_password');
            var bar = document.getElementById('n_pw_bar');
            if (pw && bar) {
              pw.addEventListener('input', function () {
                var sc = score(pw.value);
                var widths = ['0%','25%','50%','75%','100%'];
                var classes = ['','pw-weak','pw-fair','pw-good','pw-strong'];
                bar.className = classes[sc];
                bar.style.width = widths[sc];
              });
            }
          })();
        </script>
      </t>
    </template>

    <!-- =========================
         4) Thank You
    ========================== -->
    <template id="ldap_reset_password.web_thanks" name="Signup Thank You">
      <t t-call="web.login_layout">
        <div class="auth-bg d-flex align-items-center py-5">
          <div class="container">
            <div class="card auth-card mx-auto text-center" style="max-width:620px;">
              <div class="card-body py-5">
                <div class="alert alert-success fs-5 fw-semibold mb-4">
                  <i class="fa fa-check-circle me-2"></i><t t-esc="message"/>
                </div>
                <a href="/web/login" class="btn btn-primary px-4 py-2 shadow-sm">
                  Go to Login
                </a>
              </div>
            </div>
          </div>
        </div>
      </t>
    </template>

    <!-- =========================
         5) Error Page
    ========================== -->
    <template id="ldap_reset_password.web_error" name="Signup Error">
      <t t-call="web.login_layout">
        <div class="auth-bg d-flex align-items-center py-5">
          <div class="container">
            <div class="card auth-card mx-auto text-center" style="max-width:620px;">
              <div class="card-body py-5">
                <div class="alert alert-danger fs-5 fw-semibold mb-4">
                  <i class="fa fa-times-circle me-2"></i><t t-esc="message"/>
                </div>
                <a href="/web/is_member" class="btn btn-secondary me-2">Try Again</a>
                <a href="/web/login" class="btn btn-outline-primary">Back to Login</a>
              </div>
            </div>
          </div>
        </div>
      </t>
    </template>

  </data>
</odoo>
