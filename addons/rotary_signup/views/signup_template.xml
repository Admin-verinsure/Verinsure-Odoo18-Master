    <!--
      =========================================================================
      4)  THANK YOU  (unchanged from original)
      =========================================================================
    -->
    <template id="ldap_reset_password.web_thanks" name="Signup Thank You">
      <t t-call="web.login_layout">
        <style type="text/css"><![CDATA[
          .simple-auth { max-width: 620px; margin: 64px auto; text-align:center; }
        ]]></style>
        <div class="container">
          <div class="simple-auth">
            <div class="alert alert-success fs-5 fw-semibold">
              <i class="fa fa-check-circle me-2"></i><t t-esc="message"/>
            </div>
            <a href="/web/login" class="btn btn-dark mt-3 px-4 py-2">Go to Login</a>
          </div>
        </div>
      </t>
    </template>

    <!--
      =========================================================================
      5)  ERROR  (unchanged from original)
      =========================================================================
    -->
    <template id="ldap_reset_password.web_error" name="Signup Error Page">
      <t t-call="web.login_layout">
        <style type="text/css"><![CDATA[
          .simple-auth { max-width: 620px; margin: 64px auto; text-align:center; }
          .simple-auth .btn { border-radius: 10px; }
        ]]></style>
        <div class="container">
          <div class="simple-auth">
            <div class="alert alert-danger fs-5 fw-semibold">
              <i class="fa fa-times-circle me-2"></i><t t-esc="message"/>
            </div>
            <a href="/web/is_member" class="btn btn-secondary mt-3 me-2">Try Again</a>
            <a href="/web/login" class="btn btn-outline-primary mt-3">Back to Login</a>
          </div>
        </div>
      </t>
    </template>

  </data>
</odoo>
