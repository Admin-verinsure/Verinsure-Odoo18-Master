<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!--
            reCAPTCHA v2 Checkbox Keys
            ─────────────────────────────────────────────────────────────────
            NEVER commit real keys to version control.
            After deploying, update these values via:
              Settings → Technical → Parameters → System Parameters
            ─────────────────────────────────────────────────────────────────
        -->
        <record id="recaptcha_site_key" model="ir.config_parameter">
            <field name="key">recaptcha.site_key</field>
            <field name="value">REPLACE_WITH_YOUR_SITE_KEY</field>
        </record>

        <record id="recaptcha_secret_key" model="ir.config_parameter">
            <field name="key">recaptcha.secret_key</field>
            <field name="value">REPLACE_WITH_YOUR_SECRET_KEY</field>
        </record>

        <!--
            Max failed CAPTCHA attempts per IP before soft-blocking (per hour).
            Increase to 10 in low-risk environments, lower to 3 if under attack.
        -->
        <record id="recaptcha_max_failures" model="ir.config_parameter">
            <field name="key">recaptcha.max_failures_per_hour</field>
            <field name="value">5</field>
        </record>
    </data>
</odoo>
