<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record id="res_config_settings_view_form" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.captcha.custom</field>
            <field name="model">res.config.settings</field>
            <field name="priority" eval="40"/>
            <field name="inherit_id" ref="base.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form" position="inside">
                	<app string="Signup reCAPTCHA V2" data-string="Signup reCAPTCHA V2" name="recaptcha_signup">
                		<h2>Signup reCAPTCHA V2 Settings</h2>
	                    
	              		<div class="row mt16 o_settings_container" id="recaptcha_signup_v2">
	                        <div class="col-12 col-lg-6 o_setting_box" id="use_recaptcha_signup_v2">
	                        
				                    <div class="o_setting_left_pane">
				                        <field name="recaptcha2_enabled"/>
				                    </div>
	                        
	                                <div class="o_setting_right_pane">
	                                	<label for="recaptcha2_enabled"/>
						                <div class="content-group" id="reacaptcha_v2_configuration_settings" invisible="recaptcha2_enabled == False">
						                    <div class="mt16 row">
						                        <label for="recaptcha2_public_key" class="col-3 o_light_label"/>
						                        <field name="recaptcha2_public_key" required="recaptcha2_enabled == True"/>
						                    </div>
						                    <div class="mt16 row">
						                        <label for="recaptcha2_private_key" class="col-3 o_light_label"/>
						                        <field name="recaptcha2_private_key" required="recaptcha2_enabled == True"/>
						                    </div>
						                    <div>
						                        <a href="https://www.google.com/recaptcha/admin/create" class="oe_link" target="_blank">
						                            <i class="oi oi-arrow-right"/> Generate reCAPTCHA v2 keys
						                        </a>
						                    </div>
						                </div>
	                                </div>
	                		</div>
	                    </div>
                	</app>
                </xpath>
            </field>
        </record>           	        
</odoo>