<odoo>
  <template id="custom_external_layout">
    <t t-call="web.html_container">
      <!-- Custom Header -->
      <div class="header d-flex justify-content-between align-items-center mb-2">
        <img t-if="company.logo" t-att-src="image_data_uri(company.logo)" alt="Logo" style="max-height:60px;"/>
        <div class="fw-bold text-end">
          <t t-esc="company.name"/>
        </div>
      </div>

      <!-- Article/Body wrapper -->
      <div class="article o_report_layout_standard">
        <t t-raw="0"/> <!-- This is where invoice_report.xml content is injected -->
      </div>

      <!-- Custom Footer -->
      <div class="footer mt-5 border-top pt-2 text-center text-muted">
        <span t-esc="company.report_footer or 'Thank you for your business!'"/>
      </div>
    </t>
  </template>
</odoo>
