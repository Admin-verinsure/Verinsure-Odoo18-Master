<odoo>
  <data>
    <!-- Inherit Odoo's standard external layout -->
    <template id="external_layout_standard" inherit_id="web.external_layout_standard">

      <!-- Remove company address -->
      <xpath expr="//div[@name='company_address']" position="replace"/>

      <!-- Change tagline style -->
      <xpath expr="//div[contains(@class, 'o_company_tagline')]" position="attributes">
        <attribute name="class">o_company_tagline mw-50 fw-bold text-primary</attribute>
      </xpath>

      <!-- Add custom note in footer -->
      <xpath expr="//div[contains(@class, 'o_footer_content')]" position="inside">
        <div class="text-center w-100 mt-1 text-muted">
          <small>Customized Layout - For Internal Use Only</small>
        </div>
      </xpath>

      <!-- Add a horizontal line after tagline -->
      <xpath expr="//div[contains(@class, 'o_company_tagline')]" position="after">
        <hr style="border: 1px solid #000; margin: 5px 0;"/>
      </xpath>

    </template>
  </data>
</odoo>
