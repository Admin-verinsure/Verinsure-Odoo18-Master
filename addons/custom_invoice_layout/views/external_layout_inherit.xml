<odoo>
  <data>
    <!-- Inherit the standard external layout -->
    <template id="external_layout_standard_inherit" inherit_id="web.external_layout_standard">

      <!-- Change tagline style -->
      <xpath expr="//div[@class='o_company_tagline']" position="attributes">
        <attribute name="class">o_company_tagline mw-50 fw-bold text-primary</attribute>
      </xpath>

      <!-- Add custom note in footer -->
      <xpath expr="//div[@class='o_footer_content d-flex border-top pt-2']" position="inside">
        <div class="text-center w-100 mt-1 text-muted">
          <small>Customized Layout - For Internal Use Only</small>
        </div>
      </xpath>

    </template>
  </data>
</odoo>
