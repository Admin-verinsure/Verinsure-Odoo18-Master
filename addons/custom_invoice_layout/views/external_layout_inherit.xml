<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <!-- Inherit external layout to remove company address -->
    <template id="external_layout_remove_address" inherit_id="web.external_layout">
      
      <!-- Remove the address block -->
      <xpath expr="//div[contains(@class,'company_address')]" position="replace">
        <!-- Empty block so address disappears -->
      </xpath>

      <!-- (Optional) Center the logo since address is gone -->
      <xpath expr="//div[contains(@class,'o_company_#{company.id}_layout')]/div[contains(@class,'d-flex')]" position="attributes">
        <attribute name="class">d-flex justify-content-center align-items-center</attribute>
      </xpath>

    </template>
  </data>
</odoo>
