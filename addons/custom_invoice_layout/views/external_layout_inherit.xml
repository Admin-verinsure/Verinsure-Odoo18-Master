<odoo>
  <data>
    <!-- Inherit Invoice Report -->
    <template id="remove_customer_address_invoice" inherit_id="account.report_invoice_document">
      
      <!-- Remove address when shipping address is different -->
      <xpath expr="//div[@name='address_not_same_as_shipping']/t[@t-set='address']/address" position="replace">
        <!-- Leave empty to remove -->
      </xpath>

      <!-- Remove address when shipping = customer -->
      <xpath expr="//div[@name='address_same_as_shipping']/t[@t-set='address']/address" position="replace">
        <!-- Leave empty -->
      </xpath>

      <!-- Remove address when no shipping -->
      <xpath expr="//div[@name='no_shipping']/t[@t-set='address']/address" position="replace">
        <!-- Leave empty -->
      </xpath>

    </template>
  </data>
</odoo>
