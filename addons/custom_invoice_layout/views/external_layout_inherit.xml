<odoo>
  <data>

    <!-- Inherit the standard invoice document -->
    <template id="custom_invoice_layout_inherit" inherit_id="account.report_invoice_document">

      <!-- Replace the default external layout -->
      <xpath expr="//t[@t-call='web.external_layout']" position="replace">
        <t t-call="custom_invoice_layout.external_layout_standard"/>
      </xpath>

    </template>

  </data>
</odoo>
