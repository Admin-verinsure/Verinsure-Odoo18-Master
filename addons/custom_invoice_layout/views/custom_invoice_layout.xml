<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ===========================
         Custom Invoice Layout
    ============================ -->
    <template id="report_multiple_invoice_new">
        <t t-call="web.external_layout">
            <t t-set="o" t-value="o.with_context(lang=lang)"/>
            <div class="page">
                <div class="row">
                    <div class="col-6">
                        <img t-if="o.company_id.logo" t-att-src="image_data_uri(o.company_id.logo)" style="max-height: 45px;" alt="Logo"/>
                    </div>
                    <div class="col-6 text-end">
                        <span t-field="o.company_id.partner_id"
                              t-options='{"widget": "contact", "fields": ["address", "name"], "no_marker": True}'/>
                    </div>
                </div>
                <div class="row"><div class="col-12"><hr/></div></div>

                <div class="row" style="margin-top: 20px;">
                    <div class="col-6">
                        <address t-field="o.partner_id"
                                 t-options='{"widget": "contact", "fields": ["address", "name"], "no_marker": True}'/>
                    </div>
                </div>

                <h2>
                    <span t-if="o.move_type == 'out_invoice' and o.state == 'posted'">Invoice</span>
                    <span t-else="" t-field="o.move_type"/>
                    <span t-if="o.name != '/'" t-field="o.name"/>
                </h2>

                <!-- Debug marker -->
                <h1 style="color: pink; font-size: 50px;">IS THIS CODE WORKING?</h1>

                <!-- Invoice metadata -->
                <table class="table table-sm table-borderless" style="width: 100%; margin-top: 32px; margin-bottom: 32px;">
                    <tr>
                        <td style="width: 25%;"><strong t-if="o.invoice_date">Invoice Date:</strong></td>
                        <td style="width: 25%;"><p t-if="o.invoice_date" t-field="o.invoice_date"/></td>
                        <td style="width: 25%;"><strong t-if="o.invoice_origin">Source:</strong></td>
                        <td style="width: 25%;"><p t-if="o.invoice_origin" t-field="o.invoice_origin"/></td>
                    </tr>
                    <tr>
                        <td><strong t-if="o.invoice_date_due and o.state == 'posted'">Due Date:</strong></td>
                        <td><p t-if="o.invoice_date_due and o.state == 'posted'" t-field="o.invoice_date_due"/></td>
                        <td><strong t-if="o.ref">Reference:</strong></td>
                        <td><p t-if="o.ref" t-field="o.ref"/></td>
                    </tr>
                </table>

                <!-- Invoice lines -->
                <table class="table table-sm o_main_table">
                    <thead>
                        <tr>
                            <th class="text-left">Description</th>
                            <th class="text-right">Quantity</th>
                            <th class="text-right">Unit Price</th>
                            <th class="text-left">Taxes</th>
                            <th class="text-right">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="o.invoice_line_ids" t-as="line">
                            <tr t-if="line.display_type not in ('line_section', 'line_note')">
                                <td><span t-field="line.name"/></td>
                                <td class="text-right"><span t-field="line.quantity"/></td>
                                <td class="text-right"><span t-field="line.price_unit"/></td>
                                <td class="text-left"><span t-esc="', '.join(map(lambda x: x.name, line.tax_ids))"/></td>
                                <td class="text-right"><span t-field="line.price_subtotal"/></td>
                            </tr>
                            <tr t-if="line.display_type == 'line_section'">
                                <td colspan="99"><span t-field="line.name"/></td>
                            </tr>
                        </t>
                    </tbody>
                </table>

                <!-- Totals -->
                <div class="row">
                    <div class="col-7"/>
                    <div class="col-5">
                        <table class="table table-sm">
                            <t t-call="account.document_tax_totals">
                                <t t-set="tax_totals" t-value="o.tax_totals"/>
                            </t>
                        </table>
                    </div>
                </div>

                <!-- Notes -->
                <p t-if="o.narration"><span t-field="o.narration"/></p>
                <p t-if="o.invoice_payment_term_id"><span t-field="o.invoice_payment_term_id.note"/></p>
            </div>
        </t>
    </template>

    <!-- ===========================
         Multiple Invoice Container
    ============================ -->
    <template id="report_multiple_invoice">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-set="lang" t-value="o.partner_id.lang"/>
                <t t-call="custom_invoice_layout.report_multiple_invoice_new" t-lang="lang"/>
            </t>
        </t>
    </template>

    <!-- ===========================
         Report Action
    ============================ -->
    <record id="report_multiple_invoice_copies" model="ir.actions.report">
        <field name="name">Multiple Invoice Copies</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_invoice_layout.report_multiple_invoice</field>
        <field name="report_file">custom_invoice_layout.report_multiple_invoice</field>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_type">report</field>
    </record>

    <!-- ===========================
         Inherit Standard Invoice
    ============================ -->
    <template id="custom_invoice_layout_inherit" inherit_id="account.report_invoice_document">
        <xpath expr="//t[@t-call='web.external_layout']" position="replace">
            <t t-call="custom_invoice_layout.report_multiple_invoice_new"/>
        </xpath>
    </template>

    <!-- ===========================
         Inherit NZ Invoice Layout
    ============================ -->
    <template id="custom_invoice_layout_inherit_nz" inherit_id="l10n_nz.report_invoice_document">
        <xpath expr="//t[@t-call='web.external_layout']" position="replace">
            <t t-call="custom_invoice_layout.report_multiple_invoice_new"/>
        </xpath>
    </template>
</odoo>
