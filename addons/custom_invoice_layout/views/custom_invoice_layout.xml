<odoo>
  <data>

    <!-- ========================= -->
    <!-- 1. Custom External Layout -->
    <!-- ========================= -->
    <template id="external_layout_invoice_standard" name="Custom External Layout">
      <t t-name="custom_invoice_layout.external_layout_invoice_standard">
        <!-- Header -->
        <div t-attf-class="header o_company_#{company.id}_layout">
          <div class="d-flex justify-content-between align-items-center mb-2">
            <!-- Logo -->
            <img t-if="company.logo"
                 class="o_company_logo_small"
                 t-att-src="image_data_uri(company.logo)"
                 alt="Logo"/>

            <!-- Tagline -->
            <div t-if="company.report_header"
                 t-field="company.report_header"
                 class="o_company_tagline fw-bold text-primary"/>
          </div>
        </div>

        <!-- Page container -->
        <div class="page">
          <div class="article o_report_layout_standard o_table_standard"
               t-att-data-oe-model="o and o._name"
               t-att-data-oe-id="o and o.id"
               t-att-data-oe-lang="o and o.env.context.get('lang')">
            <!-- Render the body content -->
            <t t-out="0"/>
          </div>
        </div>

        <!-- Footer -->
        <div t-attf-class="footer o_company_#{company.id}_layout {{report_type != 'pdf' and 'mt-auto'}}">
          <div class="o_footer_content d-flex border-top pt-2">
            <div class="flex-grow-1 text-start me-2" t-field="company.report_footer"/>
            <div class="text-end text-muted">
              <div t-if="report_type == 'pdf' and display_name_in_footer" t-out="o.name"/>
              <div t-if="report_type == 'pdf'" class="text-nowrap">
                Page <span class="page"/> / <span class="topage"/>
              </div>
            </div>
          </div>
        </div>
      </t>
    </template>

    <!-- ========================================== -->
    <!-- 2. Override Generic Invoice Report Layout  -->
    <!-- ========================================== -->
    <template id="custom_invoice_layout_inherit"
              inherit_id="account.report_invoice_document">
      <xpath expr="//t[@t-call='web.external_layout_standard']" position="replace">
        <t t-call="custom_invoice_layout.external_layout_invoice_standard"/>
      </xpath>
    </template>

    <!-- ========================================== -->
    <!-- 3. Override NZ Localized Invoice Report    -->
    <!-- ========================================== -->
    <template id="custom_invoice_layout_inherit_nz"
              inherit_id="l10n_nz.report_invoice_document">
      <!-- Replace default external layout with custom -->
      <xpath expr="//t[@t-call='web.external_layout_standard']" position="replace">
        <t t-call="custom_invoice_layout.external_layout_invoice_standard"/>
      </xpath>

      <!-- Add an extra custom header inside the page -->
      <xpath expr="//div[contains(@class,'page')]" position="inside">
        <div class="custom-header" style="margin-bottom:10px; text-align:center;">
          <strong>Custom NZ Invoice Header</strong>
        </div>
      </xpath>
    </template>

  </data>
</odoo>
