<odoo>
  <data>
    <template id="custom_invoice_title_inherit" inherit_id="account.report_invoice_document">
      <xpath expr="//div[contains(@class,'page')]/t[@t-set='layout_document_title']" position="replace">
        <t t-set="layout_document_title">
          <span t-if="not proforma"></span>
          <span t-else="">PROFORMA</span>
          <span t-if="o.move_type == 'out_invoice' and o.state == 'posted'">Custom Invoice</span>
          <span t-elif="o.move_type == 'out_invoice' and o.state == 'draft'">Draft Custom Invoice</span>
          <span t-elif="o.move_type == 'out_invoice' and o.state == 'cancel'">Cancelled Custom Invoice</span>
          <span t-elif="o.move_type == 'out_refund' and o.state == 'posted'">Custom Credit Note</span>
          <span t-elif="o.move_type == 'out_refund' and o.state == 'draft'">Draft Custom Credit Note</span>
        </t>
      </xpath>
    </template>
  </data>
</odoo>
