<odoo>
  <data noupdate="1">

    <!-- Override the DEFAULT Odoo invoice report to use your template -->
    <record id="account.account_invoices" model="ir.actions.report">
      <field name="name">Invoice</field>
      <field name="model">account.move</field>
      <field name="report_type">qweb-pdf</field>
      <field name="report_name">custom_invoice_layout.my_custom_invoice_template</field>
      <field name="report_file">custom_invoice_layout.my_custom_invoice_template</field>
      <field name="print_report_name">'Invoice - %s' % (object.name) if object.name else ''</field>
      <field name="binding_model_id" ref="account.model_account_move"/>
      <field name="binding_type">report</field>
    </record>

  </data>
</odoo>
