<odoo>
  <data noupdate="1">

    <!-- Override DEFAULT Odoo invoice report -->
    <record id="account.account_invoices" model="ir.actions.report">
      <field name="name">Invoice</field>
      <field name="model">account.move</field>
      <field name="report_type">qweb-pdf</field>
      <!-- Must match your custom template t-name -->
      <field name="report_name">custom_invoice_layout.my_custom_invoice_template</field>
      <field name="report_file">custom_invoice_layout.my_custom_invoice_template</field>
      <field name="print_report_name">'Invoice - %s' % (object.name or '')</field>
      <field name="binding_model_id" ref="account.model_account_move"/>
      <field name="binding_type">report</field>
    </record>

  </data>
</odoo>
