<odoo>
    <data noupdate="1">

        <!-- Define custom invoice report -->
        <record id="account_invoice_report_my_custom" model="ir.actions.report">
            <field name="name">My Custom Invoice</field>
            <field name="model">account.move</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">my_custom_invoice.my_custom_invoice_template</field>
            <field name="report_file">my_custom_invoice.my_custom_invoice_template</field>
            <field name="print_report_name">'Invoice - %s' % (object.name) if object.name else ''</field>
            <field name="binding_model_id" ref="account.model_account_move"/>
            <field name="binding_type">report</field>
        </record>

        <!-- Disable the original Odoo invoice binding -->
        <record id="account.report_invoice" model="ir.actions.report">
            <field name="binding_model_id" eval="False"/>
        </record>

    </data>
</odoo>
