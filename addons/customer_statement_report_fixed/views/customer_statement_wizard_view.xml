<odoo>
    <record id="view_customer_statement_wizard" model="ir.ui.view">
        <field name="name">customer.statement.wizard.form</field>
        <field name="model">customer.statement.wizard</field>
        <field name="arch" type="xml">
            <form string="Customer Statement">
                <group>
                    <field name="partner_id"/>
                    <field name="date_from"/>
                    <field name="date_to"/>
                    <field name="report_type"/>
                </group>
                <footer>
                    <button name="action_generate" type="object" string="Generate"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
                <group invisible="not file_data">
                    <field name="file_name" invisible="1"/>
                    <field name="file_data" filename="file_name"/>
                </group>
            </form>
        </field>
    </record>
</odoo>