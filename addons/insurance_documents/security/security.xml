<odoo>
    <record id="rule_insurance_document_visibility" model="ir.rule">
        <field name="name">Insurance Documents visibility by club or owner</field>
        <field name="model_id" ref="model_insurance_document"/>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="domain_force">
            [
              '|',
                '&amp;', ('club_id', '!=', False), ('club_id', 'in', user.x_club_ids.ids),
                '&amp;', ('club_id', '=', False), ('owner_user_id', '=', user.id)
            ]
        </field>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="0"/>
    </record>

    <record id="rule_insurance_policy_visibility" model="ir.rule">
        <field name="name">Insurance Policies visibility by club or creator</field>
        <field name="model_id" ref="insurance_management_cybro.model_insurance_details"/>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="domain_force">
            [
              '|',
                '&amp;', ('x_club_id', '!=', False), ('x_club_id', 'in', user.x_club_ids.ids),
                '&amp;', ('x_club_id', '=', False), ('create_uid', '=', user.id)
            ]
        </field>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="0"/>
    </record>
</odoo>
