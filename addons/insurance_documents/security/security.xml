<odoo>
    <record id="group_insurance_dms_full_access" model="res.groups">
        <field name="name">Insurance DMS Full Access</field>
        <field name="category_id" ref="base.module_category_hidden"/>
    </record>

    <!-- Policy visibility for normal users:
         - If x_club_group_id set: only members of that group can see the policy
         - If not set: only creator can see it
    -->
    <record id="rule_insurance_policy_visibility" model="ir.rule">
        <field name="name">Insurance policy visibility (club group or creator)</field>
        <field name="model_id" ref="insurance_management_cybro.model_insurance_details"/>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="domain_force">
            [
              '|',
                '&amp;', ('x_club_group_id', '!=', False), ('x_club_group_id', 'in', user.groups_id.ids),
                '&amp;', ('x_club_group_id', '=', False), ('create_uid', '=', user.id)
            ]
        </field>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="0"/>
    </record>

    <!-- Technical bypass: can see all policies -->
    <record id="rule_insurance_policy_full_access" model="ir.rule">
        <field name="name">Insurance policy full access (technical)</field>
        <field name="model_id" ref="insurance_management_cybro.model_insurance_details"/>
        <field name="groups" eval="[(4, ref('insurance_documents.group_insurance_dms_full_access'))]"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="0"/>
    </record>
</odoo>
