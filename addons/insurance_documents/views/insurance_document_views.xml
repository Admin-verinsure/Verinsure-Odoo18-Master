<odoo>
    <record id="action_insurance_documents" model="ir.actions.act_window">
        <field name="name">Documents</field>
        <field name="res_model">insurance.document</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{}</field>
    </record>

    <menuitem id="menu_insurance_documents"
              name="Documents"
              parent="insurance_management_cybro.insurance_management_menu_root"
              action="action_insurance_documents"
              sequence="10"
              groups="base.group_user"/>

    <record id="view_insurance_document_kanban" model="ir.ui.view">
        <field name="name">insurance.document.kanban</field>
        <field name="model">insurance.document</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_small_column">
                <field name="name"/>
                <field name="policy_id"/>
                <field name="club_id"/>
                <field name="owner_user_id"/>
                <field name="create_date"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card">
                            <div><strong><field name="name"/></strong></div>
                            <div t-if="record.policy_id.raw_value"><span>Policy: </span><field name="policy_id"/></div>
                            <div t-if="record.club_id.raw_value"><span>Club: </span><field name="club_id"/></div>
                            <div><span>By: </span><field name="owner_user_id"/></div>
                            <div class="mt8">
                                <field name="datas" filename="datas_fname"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_insurance_document_list" model="ir.ui.view">
        <field name="name">insurance.document.list</field>
        <field name="model">insurance.document</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="policy_id"/>
                <field name="club_id"/>
                <field name="owner_user_id"/>
                <field name="create_date"/>
                <field name="datas_fname" string="File Name"/>
            </list>
        </field>
    </record>

    <record id="view_insurance_document_form" model="ir.ui.view">
        <field name="name">insurance.document.form</field>
        <field name="model">insurance.document</field>
        <field name="arch" type="xml">
            <form string="Insurance Document">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="policy_id"/>
                        <field name="club_id"/>
                        <field name="owner_user_id" readonly="1"/>
                    </group>
                    <group>
                        <field name="datas" filename="datas_fname"/>
                        <field name="datas_fname" invisible="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
