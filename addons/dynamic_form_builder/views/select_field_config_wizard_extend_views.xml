<odoo>
  <record id="view_select_field_config_wizard_dynamic_inherit" model="ir.ui.view">
    <field name="name">select.field.config.wizard.dynamic.inherit</field>
    <field name="model">select.field.config.wizard</field>
    <field name="inherit_id" ref="zehntech_form_builder.view_select_field_config_wizard"/>
    <field name="arch" type="xml">
      <xpath expr="//form/group" position="after">
        <group string="Dynamic Options (DB)" name="dynamic_options_group">
          <field name="is_dynamic_options"/>
          <field name="dynamic_model_id"
                 invisible="is_dynamic_options != True"
                 required="is_dynamic_options == True"/>
          <field name="dynamic_domain"
                 placeholder="[('active','=',True)]"
                 invisible="is_dynamic_options != True"/>
          <field name="dynamic_label_field_id"
                 invisible="is_dynamic_options != True"/>
          <field name="dynamic_value_field_id"
                 invisible="is_dynamic_options != True"/>
          <field name="dynamic_limit"
                 invisible="is_dynamic_options != True"/>

          <!-- Odoo 18: label without 'for' is not allowed -->
          <div class="o_form_label">
            Tip: If Dynamic Options is enabled, manual Options can be left empty.
          </div>
        </group>
      </xpath>
    </field>
  </record>
</odoo>
