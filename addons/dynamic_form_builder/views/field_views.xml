<odoo>
  <record id="dynamic_form_field_view_form" model="ir.ui.view">
    <field name="name">dynamic.form.field.form</field>
    <field name="model">dynamic.form.field</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <group>
            <field name="label"/>
            <field name="field_type"/>
            <field name="option_source"
                   modifiers='{"invisible":[["field_type","!=","select"]]}'/>
            <field name="option_model_id"
                   modifiers='{"invisible":[["option_source","!=","model"]]}'/>
            <field name="option_domain"
                   modifiers='{"invisible":[["option_source","!=","model"]]}'/>
            <field name="option_label_field"
                   modifiers='{"invisible":[["option_source","!=","model"]]}'/>
            <field name="option_value_field"
                   modifiers='{"invisible":[["option_source","!=","model"]]}'/>
            <field name="option_values"
                   modifiers='{"invisible":[["option_source","!=","manual"]]}'/>
          </group>
        </sheet>
      </form>
    </field>
  </record>
</odoo>