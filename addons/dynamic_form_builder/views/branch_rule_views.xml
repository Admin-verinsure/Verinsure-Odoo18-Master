<odoo>
  <!-- LIST (was tree) -->
  <record id="view_form_branch_rule_list" model="ir.ui.view">
    <field name="name">form.builder.branch.rule.list</field>
    <field name="model">form.builder.branch.rule</field>
    <field name="type">list</field>
    <field name="arch" type="xml">
      <list>
        <field name="sequence"/>
        <field name="form_id"/>
        <field name="trigger_field_id"/>
        <field name="operator"/>
        <field name="value_text"/>
        <field name="target_form_id"/>
        <field name="fallback_form_id"/>
      </list>
    </field>
  </record>

  <!-- FORM -->
  <record id="view_form_branch_rule_form" model="ir.ui.view">
    <field name="name">form.builder.branch.rule.form</field>
    <field name="model">form.builder.branch.rule</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <group>
            <field name="sequence"/>
            <field name="form_id"/>
            <field name="trigger_field_id"/>
          </group>
          <group>
            <field name="operator"/>
            <field name="value_text"/>
          </group>
          <group>
            <field name="target_form_id"/>
            <field name="fallback_form_id"/>
          </group>
          <p class="text-muted">
            Branching evaluates rules in order. First match wins.
          </p>
        </sheet>
      </form>
    </field>
  </record>

  <!-- ACTION -->
  <record id="action_form_branch_rules" model="ir.actions.act_window">
    <field name="name">Branch Rules</field>
    <field name="res_model">form.builder.branch.rule</field>
    <field name="view_mode">list,form</field>
  </record>

  <!-- MENU -->
  <menuitem id="menu_form_branch_rules"
            name="Branch Rules"
            parent="zehntech_form_builder.menu_form_builder_root"
            action="action_form_branch_rules"
            sequence="45"/>
</odoo>
