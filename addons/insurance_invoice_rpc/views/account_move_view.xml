<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_inherit_insurance_details" model="ir.ui.view">
        <field name="name">account.move.form.inherit.insurance.details</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!-- Put Insurance link near 'ref' (reference) -->
            <xpath expr="//field[@name='ref']" position="after">
                <field name="insurance_details_id" readonly="1" options="{'no_create': True}"/>
            </xpath>
        </field>
    </record>
</odoo>
