<odoo>
    <record id="view_partner_form_external_guid" model="ir.ui.view">
        <field name="name">res.partner.form.external.guid</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='email']" position="after">
                <field name="external_guid"/>
            </xpath>

        </field>
    </record>
</odoo>