<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_invoice_poc_payload_tree" model="ir.ui.view">
            <field name="name">invoice.poc.payload.tree</field>
            <field name="model">invoice.poc.payload</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="ext_id"/>
                    <field name="state"/>
                    <field name="last_move_id"/>
                    <field name="create_date"/>
                </tree>
            </field>
        </record>

        <record id="view_invoice_poc_payload_form" model="ir.ui.view">
            <field name="name">invoice.poc.payload.form</field>
            <field name="model">invoice.poc.payload</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_create_policy_and_invoice"
                                type="object"
                                string="Create Policy &amp; Invoice"
                                class="btn-primary"
                                attrs="{'invisible': [('state','=','done')]}"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,done,error"/>
                    </header>
                    <sheet>
                        <group>
                            <field name="ext_id"/>
                            <field name="last_move_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="payload_json" widget="text"/>
                            <field name="error_message" readonly="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_invoice_poc_payload" model="ir.actions.act_window">
            <field name="name">Invoice POC Payloads</field>
            <field name="res_model">invoice.poc.payload</field>
            <field name="view_mode">tree,form</field>
        </record>

        <!-- Root menu -->
        <record id="menu_invoice_poc_root" model="ir.ui.menu">
            <field name="name">Insurance Invoice POC</field>
            <field name="sequence">10</field>
        </record>

        <!-- Payloads menu -->
        <record id="menu_invoice_poc_payload" model="ir.ui.menu">
            <field name="name">Payloads</field>
            <field name="parent_id" ref="insurance_policy_invoice_poc.menu_invoice_poc_root"/>
            <field name="action" ref="insurance_policy_invoice_poc.action_invoice_poc_payload"/>
            <field name="sequence">20</field>
        </record>
    </data>
</odoo>
