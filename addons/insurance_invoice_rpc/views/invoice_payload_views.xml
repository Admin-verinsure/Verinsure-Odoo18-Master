<odoo>
  <record id="view_invoice_poc_payload_tree" model="ir.ui.view">
    <field name="name">invoice.poc.payload.tree</field>
    <field name="model">invoice.poc.payload</field>
    <field name="arch" type="xml">
      <tree>
        <field name="ext_id"/>
        <field name="state"/>
        <field name="last_move_id"/>
        <field name="create_date"/>
      </tree>
    </field>
  </record>

  <record id="view_invoice_poc_payload_form" model="ir.ui.view">
    <field name="name">invoice.poc.payload.form</field>
    <field name="model">invoice.poc.payload</field>
    <field name="arch" type="xml">
      <form>
        <header>
          <button name="action_create_policy_and_invoice"
                  type="object"
                  string="Create Policy &amp; Invoice"
                  class="btn-primary"
                  attrs="{'invisible': [('state','=','done')]}"/>
          <field name="state" widget="statusbar" statusbar_visible="draft,done,error"/>
        </header>
        <sheet>
          <group>
            <field name="ext_id"/>
            <field name="last_move_id" readonly="1"/>
          </group>
          <group>
            <field name="payload_json" widget="text"/>
            <field name="error_message" readonly="1"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_invoice_poc_payload" model="ir.actions.act_window">
    <field name="name">Invoice POC Payloads</field>
    <field name="res_model">invoice.poc.payload</field>
    <field name="view_mode">tree,form</field>
  </record>

  <menuitem id="menu_invoice_poc_root" name="Insurance Invoice POC" sequence="10"/>
  <menuitem id="menu_invoice_poc_payload"
            name="Payloads"
            parent="menu_invoice_poc_root"
            action="action_invoice_poc_payload"
            sequence="20"/>
</odoo>
