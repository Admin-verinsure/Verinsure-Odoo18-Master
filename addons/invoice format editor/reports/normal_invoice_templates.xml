<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Normal Invoice Template (Safe Version) -->
    <template id="custom_template_report_invoice_normal">
        <t t-call="web.external_layout">
            <t t-set="model" t-value="'account.move'"/>
            <div>
                <!-- Company reference -->
                <t t-if="o and o.company_id">
                    <t t-set="company" t-value="o.company_id"/>
                </t>
                <t t-if="not o or not o.company_id">
                    <t t-set="company" t-value="res_company"/>
                </t>

                <!-- Customer address -->
                <div>
                    <div class="row">
                        <div style="width:50%;">
                            <div itemprop="address" class="address">
                                <div><span t-field="o.partner_id"/></div>
                                <div><span t-field="o.partner_id.street"/></div>
                                <div><span t-field="o.partner_id.street2"/></div>
                                <div><span t-field="o.partner_id.city"/></div>
                                <div><span t-field="o.partner_id.country_id"/></div>
                                <div><span t-field="o.partner_id.vat"/></div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Invoice Info -->
                <table class="table table-sm table-borderless mt-4" style="width:100%">
                    <tr>
                        <th t-if="o.invoice_date" class="text-center">Invoice Date</th>
                        <th t-if="o.invoice_date_due" class="text-center">Due Date</th>
                        <th t-if="o.invoice_payment_term_id" class="text-center">Payment Term</th>
                        <th t-if="o.user_id" class="text-center">Salesperson</th>
                        <th t-if="o.ref" class="text-center">Reference</th>
                        <th t-if="o.invoice_origin" class="text-center">Source</th>
                    </tr>
                    <tr>
                        <td t-if="o.invoice_date"><span t-field="o.invoice_date"/></td>
                        <td t-if="o.invoice_date_due"><span t-field="o.invoice_date_due"/></td>
                        <td t-if="o.invoice_payment_term_id"><span t-field="o.invoice_payment_term_id"/></td>
                        <td t-if="o.user_id"><span t-field="o.user_id"/></td>
                        <td t-if="o.ref"><span t-field="o.ref"/></td>
                        <td t-if="o.invoice_origin"><span t-field="o.invoice_origin"/></td>
                    </tr>
                </table>

                <!-- Invoice Number & Title -->
                <div class="page text-center">
                    <h2>
                        <span t-if="o.move_type == 'out_invoice' and o.state in ('draft','posted')">Invoice</span>
                        <span t-if="o.move_type == 'out_invoice' and o.state == 'proforma2'">Pro-Forma</span>
                        <span t-if="o.move_type == 'out_invoice' and o.state == 'cancel'">Cancelled Invoice</span>
                        <span t-if="o.move_type == 'out_refund'">Refund</span>
                        <span t-if="o.move_type == 'in_refund'">Vendor Refund</span>
                        <span t-if="o.move_type == 'in_invoice'">Vendor Bill</span>
                        <br/>
                        <span t-field="o.name"/>
                    </h2>
                </div>

                <!-- Product Lines -->
                <table class="table table-sm mt-4" style="width:100%">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Description</th>
                            <th class="text-end">Quantity</th>
                            <th class="text-end">Unit Price</th>
                            <th class="text-end">Discount (%)</th>
                            <th class="text-end">Taxes</th>
                            <th class="text-end">Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr t-foreach="o.invoice_line_ids" t-as="l">
                            <td><span t-field="l.product_id.name"/></td>
                            <td><span t-field="l.name"/></td>
                            <td class="text-end"><span t-field="l.quantity"/></td>
                            <td class="text-end"><span t-field="l.price_unit"/></td>
                            <td class="text-end" t-if="l.discount"><span t-field="l.discount"/></td>
                            <td class="text-end" t-if="l.tax_ids"><span t-esc="', '.join([t.name for t in l.tax_ids])"/></td>
                            <td class="text-end"><span t-field="l.price_subtotal" t-field-options="{'widget':'monetary','display_currency':o.currency_id}"/></td>
                        </tr>
                    </tbody>
                </table>

                <!-- Totals -->
                <div class="row mt-4">
                    <div class="col-6 ms-auto">
                        <table class="table table-sm">
                            <t t-set="tax_totals" t-value="o.tax_totals"/>
                            <t t-foreach="tax_totals['subtotals']" t-as="subtotal">
                                <tr>
                                    <td><strong><span t-esc="subtotal['name']"/></strong></td>
                                    <td class="text-end"><span t-esc="subtotal['base_amount_currency']"/></td>
                                </tr>
                            </t>
                            <tr class="o_total">
                                <td><strong>Total</strong></td>
                                <td class="text-end"><span t-esc="tax_totals['total_amount']"/></td>
                            </tr>
                        </table>
                    </div>
                </div>

                <!-- Terms -->
                <div class="mt-3">
                    <p t-if="not is_html_empty(o.narration)">
                        <strong>Terms &amp; Conditions:</strong><br/>
                        <span t-field="o.narration"/>
                    </p>
                </div>
            </div>
        </t>
    </template>
</odoo>
