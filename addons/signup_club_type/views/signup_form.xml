<odoo>
    <template id="custom_signup_form" inherit_id="auth_signup.fields">

        <!-- Insert Program Type dropdown before Club Name -->
        <xpath expr="//div[label[contains(text(),'Club Name')]]" position="before">
            <div class="form-group field-club_type">
                <label for="club_type">Program Type</label>
                <select name="club_type" id="club_type" class="form-control" required="required">
                    <option value="">-- Select Program Type --</option>
                    <option value="rotary">Rotary</option>
                    <option value="rotaract">Rotaract</option>
                    <option value="interact">Interact</option>
                    <option value="rota-kids">Rota-Kids</option>
                </select>
            </div>
        </xpath>

    </template>
</odoo>
