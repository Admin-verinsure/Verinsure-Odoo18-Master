<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="custom_signup_program_type_replace" inherit_id="ldap_reset_password.fields">
        
        
        <xpath expr="//div[@class='form-group'][select/@name='program_type']" position="replace">
            <div class="form-group">
                <label for="club_type">Program Type</label>
                <select name="club_type" id="club_type" class="form-control form-control-sm" required="required">
                    <option value="">-- Select Program Type --</option>
                    <t t-set="club_types" t-value="env['res.partner']._fields['club_type'].selection" />
                    <t t-if="club_types">
                        <t t-foreach="club_types" t-as="opt">
                            <option t-att-value="opt[0]" t-esc="opt[1]"/>
                        </t>
                    </t>
                </select>
            </div>
        </xpath>
<xpath expr="//div[@class='form-group'][select/@name='program_type']" position="after">
            <div class="form-group">
                <label for="rotary_club_id">Club Name</label>
                <select name="rotary_club_id" id="rotary_club_id" class="form-control form-control-sm" required="required">
                    <option value="">-- Select a Club Name--</option>
                    <t t-set="clubs" t-value="env['res.partner'].search([('club_name', '!=', False)])"/>
                    <t t-if="clubs">
                        <t t-foreach="clubs" t-as="club">
                            <option t-att-value="club.id" t-esc="club.club_name"/>
                        </t>
                    </t>
                </select>
            </div>
        </xpath>
        
    </template>
</odoo>
