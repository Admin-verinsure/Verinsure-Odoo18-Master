<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="custom_signup_program_type" inherit_id="auth_signup.fields">
        <xpath expr="//div[@class='mb-3 field-login']" position="after">
            <div class="mb-3 field-program-type">
                <label for="club_type">Program Type</label>
                <select name="club_type" id="club_type" class="form-select" required="required">
                    <option value="">Select Program</option>
                    <!-- Dynamically load selection values from res.partner.club_type -->
                    <t t-set="club_selection" t-value="request.env['res.partner'].sudo()._fields['club_type'].selection"/>
                    <t t-foreach="club_selection" t-as="opt">
                        <option t-att-value="opt[0]"><t t-esc="opt[1]"/></option>
                    </t>
                </select>
            </div>
        </xpath>
    </template>
</odoo>
