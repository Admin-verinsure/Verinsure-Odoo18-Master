<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- Inherit the same template you’re already customizing -->
  <template id="custom_signup_program_type_replace"
            inherit_id="ldap_reset_password.fields">

    <!-- Replace the original Program Type block -->
    <xpath expr="//div[@class='form-group'][select/@name='program_type']" position="replace">
      <!-- Small GET form to pick Program Type and refresh the page -->
      <form method="get" class="mb-2">
        <div class="form-group">
          <label for="club_type">Program Type</label>
          <select name="club_type" id="club_type" class="form-control form-control-sm" required="required">
            <option value="">-- Select Program Type --</option>

            <!-- Read the selection list from the res.partner field selection -->
            <t t-set="club_types" t-value="env['res.partner']._fields['club_type'].selection"/>
            <t t-if="club_types">
              <t t-foreach="club_types" t-as="opt">
                <option t-att-value="opt[0]"
                        t-att-selected="request.params.get('club_type') == opt[0]">
                  <t t-esc="opt[1]"/>
                </option>
              </t>
            </t>
          </select>
        </div>

        <!-- “Load Clubs” button triggers a GET refresh; no JS used -->
        <button type="submit" class="btn btn-secondary btn-sm">Load Clubs</button>
      </form>
    </xpath>

    <!-- Inject the Club Name select (populated from res.partner) -->
    <xpath expr="//form[contains(@class, 'oe_signup_form')]" position="inside">
      <!-- Determine selected program type from the request -->
      <t t-set="sel_program" t-value="request.params.get('club_type')"/>

      <!-- Server-side search in res.partner (DB) for clubs -->
      <!-- Adjust domain to your real markers: is_club/club_type/etc. -->
      <t t-set="clubs"
         t-value="sel_program and env['res.partner'].sudo().search([('is_club','=',True), ('club_type','=',sel_program)], order='name') or env['res.partner']browse([])"/>

      <div class="form-group">
        <label for="rotary_club_id">Club Name</label>
        <select class="form-control form-control-sm" name="rotary_club_id" id="rotary_club_id" required="required">
          <option value="">-- Select a Club Name --</option>
          <t t-foreach="clubs" t-as="c">
            <option t-att-value="c.id"
                    t-att-selected="str(c.id) == (request.params.get('rotary_club_id') or '')">
              <t t-esc="c.name"/>
            </option>
          </t>
        </select>
      </div>
    </xpath>

  </template>
</odoo>
