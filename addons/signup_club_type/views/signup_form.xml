<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="signup_program_type_fill" inherit_id="ldap_reset_password.signup">
        <!-- Target the div that contains label[@for='program_type'] and its select -->
        <xpath expr="//div[label[@for='program_type']]/select" position="inside">
            <t t-set="sel" t-value="request.env['res.partner']._fields['club_type'].selection"/>
            <t t-foreach="sel" t-as="opt">
                <option t-att-value="opt[0]">
                    <t t-esc="opt[1]"/>
                </option>
            </t>
        </xpath>
    </template>
</odoo>
