<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit the form fields of signup -->
    <template id="custom_signup_program_type" inherit_id="auth_signup.fields">
        <xpath expr="//div[@class='mb-3 field-login']" position="after">
            <div class="mb-3 field-program-type">
                <label for="program_type">Program Type</label>
                <select name="program_type" id="program_type" class="form-select" required="required">
                    <option value="">Select Program</option>
                    <option value="rotary">Rotary</option>
                    <option value="rotaract">Rotaract</option>
                    <option value="interact">Interact</option>
                    <option value="inner_wheel">Inner Wheel</option>
                </select>
            </div>
        </xpath>
    </template>
</odoo>
