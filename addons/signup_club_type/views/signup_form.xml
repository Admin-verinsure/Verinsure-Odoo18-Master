<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Extend signup fields template -->
    <template id="custom_signup_program_type_and_club" inherit_id="ldap_reset_password.fields">

        <!-- Replace Program Type dropdown -->
        <xpath expr="//div[@class='form-group'][select/@name='program_type']" position="replace">
            <div class="form-group">
                <label for="club_type">Program Type</label>
                <select name="club_type" id="club_type" class="form-control form-control-sm" required="required">
                    <option value="">-- Select Program Type --</option>
                    <t t-set="club_types" t-value="env['res.partner']._fields['club_type'].selection" />
                    <t t-if="club_types">
                        <t t-foreach="club_types" t-as="opt">
                            <option t-att-value="opt[0]" t-esc="opt[1]"/>
                        </t>
                    </t>
                </select>
            </div>

            <!-- Club Name dropdown filtered by selected club_type -->
            <div class="form-group">
                <label for="club_name">Club Name</label>
                <select name="club_name" id="club_name" class="form-control form-control-sm" required="required">
                    <option value="">-- Select Club Name --</option>
                    <t t-foreach="clubs" t-as="club">
                        <option t-att-value="club.id" t-esc="club.name"/>
                    </t>
                </select>
            </div>
        </xpath>

    </template>
</odoo>
