<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Keep your existing signup customization -->
    <template id="custom_signup_program_type_replace" inherit_id="ldap_reset_password.fields">
        <xpath expr="//div[@class='form-group'][select/@name='program_type']" position="replace">
            <div class="form-group">
                <label for="club_type">Program Type</label>
                <select name="club_type" id="club_type" class="form-control form-control-sm" required="required">
                    <option value="">-- Select Program Type --</option>
                    <t t-set="club_types" t-value="env['res.partner']._fields['club_type'].selection" />
                    <t t-if="club_types">
                        <t t-foreach="club_types" t-as="opt">
                            <option t-att-value="opt[0]" t-esc="opt[1]"/>
                        </t>
                    </t>
                </select>
            </div>
        </xpath>
    </template>

    <!-- Make rotary_membership_id editable on partner form -->
    <record id="view_partner_form_edit_rotary_id" model="ir.ui.view">
        <field name="name">view.partner.form.edit.rotary.id</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="rotary_project_map.view_partner_form_inherit_club_type"/>
        <field name="arch" type="xml">
            <field name="rotary_membership_id" position="attributes">
                <attribute name="readonly">0</attribute>
            </field>
        </field>
    </record>
</odoo>
