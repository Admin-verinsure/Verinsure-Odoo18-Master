<odoo>
    <record id="view_journal_auto_reconcile" model="ir.ui.view">
        <field name="name">account.journal.akahu.config</field>
        <field name="model">account.journal</field>
        <field name="inherit_id" ref="account.view_account_journal_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/notebook" position="inside">
                <page string="Akahu & Reconciliation">
                    <group>
                        <field name="akahu_enabled"/>
                        <field name="akahu_app_token"/>
                        <field name="akahu_account_id"/>
                    </group>
                    <group>
                        <field name="auto_reconcile_enabled"/>
                        <field name="auto_reconcile_days"/>
                        <field name="auto_reconcile_tolerance"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>