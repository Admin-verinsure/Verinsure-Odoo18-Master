<odoo>
    <record id="ir_cron_auto_reconcile" model="ir.cron">
        <field name="name">Auto Reconcile</field>
        <field name="model_id" ref="model_auto_reconcile_engine"/>
        <field name="state">code</field>
        <field name="code">model.run_auto_reconcile(int(env['ir.config_parameter'].sudo().get_param('akahu.journal_id') or 0))</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
        <field name="user_id" ref="base.user_root"/>
    </record>
</odoo>