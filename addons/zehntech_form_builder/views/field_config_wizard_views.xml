<odoo>
  <!-- Phone Field Wizard -->
  <record id="view_phone_field_config_wizard" model="ir.ui.view">
    <field name="name">phone.field.config.wizard.form</field>
    <field name="model">phone.field.config.wizard</field>
    <field name="arch" type="xml">
      <form string="Phone Field Configuration">
        <group>
          <field name="hover_text"/>
          <field name="min_length"/>
          <field name="max_length"/>
          <field name="show_country_selector" string="Show Country Code Selector"/>
        </group>
        <footer>
          <button name="action_save_phone_config" type="object" class="btn-primary" string="Save"/>
          <button string="Cancel" class="btn-secondary" special="cancel"/>
        </footer>
      </form>
    </field>
  </record>

  <!-- Text Field Wizard -->
  <record id="view_text_field_config_wizard" model="ir.ui.view">
    <field name="name">text.field.config.wizard.form</field>
    <field name="model">text.field.config.wizard</field>
    <field name="arch" type="xml">
      <form string="Text Field Configuration">
        <group>
          <field name="min_length"/>
          <field name="max_length"/>
          <field name="pattern" placeholder="e.g., [A-Za-z]+ for letters only"/>
        </group>
        <footer>
          <button name="action_save_text_config" type="object" class="btn-primary" string="Save"/>
          <button string="Cancel" class="btn-secondary" special="cancel"/>
        </footer>
      </form>
    </field>
  </record>

  <!-- Number Field Wizard -->
  <record id="view_number_field_config_wizard" model="ir.ui.view">
    <field name="name">number.field.config.wizard.form</field>
    <field name="model">number.field.config.wizard</field>
    <field name="arch" type="xml">
      <form string="Number Field Configuration">
        <group>
          <field name="min_value"/>
          <field name="max_value"/>
          <field name="step"/>
        </group>
        <footer>
          <button name="action_save_number_config" type="object" class="btn-primary" string="Save"/>
          <button string="Cancel" class="btn-secondary" special="cancel"/>
        </footer>
      </form>
    </field>
  </record>

  <!-- Textarea Field Wizard -->
  <record id="view_textarea_field_config_wizard" model="ir.ui.view">
    <field name="name">textarea.field.config.wizard.form</field>
    <field name="model">textarea.field.config.wizard</field>
    <field name="arch" type="xml">
      <form string="Textarea Field Configuration">
        <group>
          <field name="rows"/>
          <field name="max_chars"/>
        </group>
        <footer>
          <button name="action_save_textarea_config" type="object" class="btn-primary" string="Save"/>
          <button string="Cancel" class="btn-secondary" special="cancel"/>
        </footer>
      </form>
    </field>
  </record>

  <!-- Select Field Wizard -->
  <record id="view_select_field_config_wizard" model="ir.ui.view">
    <field name="name">select.field.config.wizard.form</field>
    <field name="model">select.field.config.wizard</field>
    <field name="arch" type="xml">
      <form string="Select Field Configuration">
        <group>
          <field name="option_values" widget="text" placeholder="Option 1&#10;Option 2&#10;Option 3"/>
          <field name="hover_text" placeholder="Hover text for this field"/>
        </group>
        <footer>
          <button name="action_save_select_config" type="object" class="btn-primary" string="Save"/>
          <button string="Cancel" class="btn-secondary" special="cancel"/>
        </footer>
      </form>
    </field>
  </record>

  <!-- Email Field Wizard -->
<record id="view_email_field_config_wizard" model="ir.ui.view">
  <field name="name">email.field.config.wizard.form</field>
  <field name="model">email.field.config.wizard</field>
  <field name="arch" type="xml">
    <form string="Email Field Configuration">
      <group>
        <field name="hover_text"/>
        <field name="validation_message"/>
        <field name="enable_domain_restriction"/>

        <!-- shown/required when enable_domain_restriction is True -->
        <field name="domain_restriction_type"
               invisible="enable_domain_restriction != True"
               required="enable_domain_restriction == True"/>

        <!-- shown/required when enable_domain_restriction is True -->
        <field name="allowed_domains"
               invisible="enable_domain_restriction != True"
               required="enable_domain_restriction == True"
               placeholder="gmail.com&#10;outlook.com&#10;company.com"/>

        <!-- shown when enable_domain_restriction is True -->
        <field name="domain_validation_message"
               invisible="enable_domain_restriction != True"/>
      </group>

      <footer>
        <button name="action_save_email_config" type="object" class="btn-primary" string="Save"/>
        <button string="Cancel" class="btn-secondary" special="cancel"/>
      </footer>
    </form>
  </field>
</record>


  <!-- Update existing Checkbox Field Wizard -->
  <record id="view_checkbox_field_config_wizard" model="ir.ui.view">
    <field name="name">checkbox.field.config.wizard.form</field>
    <field name="model">checkbox.field.config.wizard</field>
    <field name="arch" type="xml">
      <form string="Checkbox Field Configuration">
        <group>
          <field name="checkbox_options" widget="text" placeholder="Option 1&#10;Option 2&#10;Option 3"/>
          <field name="layout"/>
        </group>
        <footer>
          <button name="action_save_checkbox_config" type="object" class="btn-primary" string="Save"/>
          <button string="Cancel" class="btn-secondary" special="cancel"/>
        </footer>
      </form>
    </field>
  </record>

  <!-- Date Field Wizard -->
  <record id="view_date_field_config_wizard" model="ir.ui.view">
    <field name="name">date.field.config.wizard.form</field>
    <field name="model">date.field.config.wizard</field>
    <field name="arch" type="xml">
      <form string="Date Field Configuration">
        <group>
          <field name="min_date"/>
          <field name="max_date"/>
        </group>
        <footer>
          <button name="action_save_date_config" type="object" class="btn-primary" string="Save"/>
          <button string="Cancel" class="btn-secondary" special="cancel"/>
        </footer>
      </form>
    </field>
  </record>

  

  <!-- Time Field Wizard -->
<record id="view_time_field_config_wizard" model="ir.ui.view">
    <field name="name">time.field.config.wizard.form</field>
    <field name="model">time.field.config.wizard</field>
    <field name="arch" type="xml">
        <form string="Time Field Configuration">
            <group>
                <field name="default_time"/>
                <field name="custom_hour" invisible="default_time != 'custom'" required="default_time == 'custom'"/>
                <field name="custom_minute" invisible="default_time != 'custom'" required="default_time == 'custom'"/>
            </group>
            <footer>
                <button name="action_save_time_config" type="object" class="btn-primary" string="Save"/>
                <button string="Cancel" class="btn-secondary" special="cancel"/>
            </footer>
        </form>
    </field>
</record>



  <!-- Year Field Wizard -->
  <record id="view_year_field_config_wizard" model="ir.ui.view">
    <field name="name">year.field.config.wizard.form</field>
    <field name="model">year.field.config.wizard</field>
    <field name="arch" type="xml">
      <form string="Year Field Configuration">
        <group>
          <field name="min_year"/>
          <field name="max_year"/>
        </group>
        <footer>
          <button name="action_save_year_config" type="object" class="btn-primary" string="Save"/>
          <button string="Cancel" class="btn-secondary" special="cancel"/>
        </footer>
      </form>
    </field>
  </record>

  <!-- Update existing Rating Field Wizard -->
  <record id="view_rating_field_config_wizard" model="ir.ui.view">
    <field name="name">rating.field.config.wizard.form</field>
    <field name="model">rating.field.config.wizard</field>
    <field name="arch" type="xml">
      <form string="Rating Field Configuration">
        <group>
          <field name="max_stars"/>
          <field name="style"/>
          <field name="allow_clear"/>
        </group>
        <group string="Labels and Tooltips">
          <field name="tooltips" widget="text" placeholder="One tooltip per line for each rating"/>
        </group>
        <footer>
          <button name="action_save_rating_config" type="object" class="btn-primary" string="Save"/>
          <button string="Cancel" class="btn-secondary" special="cancel"/>
        </footer>
      </form>
    </field>
  </record>

  <!-- URL Field Wizard -->
<record id="view_url_field_config_wizard" model="ir.ui.view">
  <field name="name">url.field.config.wizard.form</field>
  <field name="model">url.field.config.wizard</field>
  <field name="arch" type="xml">
    <form string="URL Field Configuration">
      <group>
        <field name="allow_external"/>
        <field name="required_protocol"/>
        <field name="open_new_tab"/>
        <field name="validation_message" placeholder="Custom error message for invalid URLs"/>
      </group>
      <footer>
        <button name="action_save_url_config" type="object" class="btn-primary" string="Save"/>
        <button string="Cancel" class="btn-secondary" special="cancel"/>
      </footer>
    </form>
  </field>
</record>

<!-- Address Field Wizard -->
<record id="view_address_field_config_wizard" model="ir.ui.view">
  <field name="name">address.field.config.wizard.form</field>
  <field name="model">address.field.config.wizard</field>
  <field name="arch" type="xml">
    <form string="Address Field Configuration">
      <group>
        <group string="Address Components">
          <field name="enable_street"/>
          <field name="enable_city"/>
          <field name="enable_state"/>
          <field name="enable_zip"/>
          <field name="enable_country"/>
        </group>
        <group string="Default Settings">
          <field name="default_country"/>
          <field name="required_fields" placeholder="street,city,state,zip,country"/>
        </group>
      </group>
      <footer>
        <button name="action_save_address_config" type="object" class="btn-primary" string="Save"/>
        <button string="Cancel" class="btn-secondary" special="cancel"/>
      </footer>
    </form>
  </field>
</record>

<record id="view_month_field_config_wizard" model="ir.ui.view">
    <field name="name">month.field.config.wizard.form</field>
    <field name="model">month.field.config.wizard</field>
    <field name="arch" type="xml">
        <form string="Month Field Configuration">
            <group string="Default Value">
                <field name="default_value"/>
                <field name="custom_month" invisible="default_value != 'custom'" required="default_value == 'custom'"/>
                <field name="custom_year" invisible="default_value != 'custom'" required="default_value == 'custom'"/>
                <field name="relative_months" invisible="default_value != 'relative'"/>
            </group>

            <group string="Range Restrictions">
                <field name="enable_min_month"/>
                <field name="min_month_year" invisible="not enable_min_month"/>
                <field name="min_month_month" invisible="not enable_min_month"/>
                <field name="enable_max_month"/>
                <field name="max_month_year" invisible="not enable_max_month"/>
                <field name="max_month_month" invisible="not enable_max_month"/>
            </group>

            <group string="Display &amp; Validation">
                <field name="show_month_names"/>
                <field name="restrict_future"/>
                <field name="restrict_past"/>
                <field name="help_text"/>
            </group>

            <footer>
                <button name="action_save_month_config" type="object" class="btn-primary" string="Save"/>
                <button string="Cancel" class="btn-secondary" special="cancel"/>
            </footer>
        </form>
    </field>
</record>

<record id="view_password_field_config_wizard" model="ir.ui.view">
    <field name="name">password.field.config.wizard.form</field>
    <field name="model">password.field.config.wizard</field>
    <field name="arch" type="xml">
        <form string="Password Field Configuration">
            <group>
                <group string="Length Requirements">
                    <field name="min_length"/>
                    <field name="max_length"/>
                </group>
                <group string="Complexity Requirements">
                    <field name="require_uppercase"/>
                    <field name="require_lowercase"/>
                    <field name="require_number"/>
                    <field name="require_special"/>
                </group>
                <group string="Display Options">
                    <field name="show_strength"/>
                    <field name="show_toggle"/>
                </group>
                <group string="Validation">
                    <field name="validation_message"/>
                </group>
            </group>
            <footer>
                <button name="action_save_password_config" type="object" class="btn-primary" string="Save"/>
                <button string="Cancel" class="btn-secondary" special="cancel"/>
            </footer>
        </form>
    </field>
</record>

<record id="view_file_field_config_wizard" model="ir.ui.view">
    <field name="name">file.field.config.wizard.form</field>
    <field name="model">file.field.config.wizard</field>
    <field name="arch" type="xml">
        <form string="File Upload Configuration">
            <group>
                <field name="max_size"/>
                <field name="allowed_extensions" placeholder="pdf,doc,docx,jpg,png,xlsx"/>
                <field name="multiple"/>
                <!-- <field name="show_preview"/> -->
            </group>
            <footer>
                <button name="action_save_file_config" type="object" class="btn-primary" string="Save"/>
                <button string="Cancel" class="btn-secondary" special="cancel"/>
            </footer>
        </form>
    </field>
</record>


  <record id="view_captcha_field_config_wizard" model="ir.ui.view">
    <field name="name">captcha.field.config.wizard.form</field>
    <field name="model">captcha.field.config.wizard</field>
    <field name="arch" type="xml">
      <form string="CAPTCHA Field Configuration">
          <group>
              <field name="captcha_version" widget="radio"/>
              <div class="alert alert-info" role="alert">
                  <strong>Important:</strong> Make sure you create keys for the selected version at 
                  <a href="https://www.google.com/recaptcha/admin" target="_blank">Google reCAPTCHA Admin</a>
              </div>
              <field name="site_key"/>
              <field name="secret_key" password="True"/>
              <field name="theme"/>
              <field name="size"/>
          </group>
          <footer>
              <button name="action_save_captcha_config" type="object" class="btn-primary" string="Save"/>
              <button string="Cancel" class="btn-secondary" special="cancel"/>
          </footer>
      </form>
    </field>
  </record>


</odoo>