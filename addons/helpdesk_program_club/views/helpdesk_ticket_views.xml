<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Backend form: show Club Name after Email field -->
    <record id="ticket_helpdesk_view_form_club" model="ir.ui.view">
        <field name="name">ticket.helpdesk.form.club</field>
        <field name="model">ticket.helpdesk</field>
        <field name="inherit_id" ref="odoo_website_helpdesk.ticket_helpdesk_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='customer_id']" position="after">
                <!--
                    FIX: removed readonly="1" — the field was visible in the
                    form but always blank because readonly fields are skipped
                    when Odoo renders saved values that come from the website
                    submission. With readonly removed the value is both saved
                    and displayed correctly.
                -->
                <field name="helpdesk_club_id" string="Club Name"
                       options="{'no_create': True, 'no_open': True}"/>
            </xpath>
        </field>
    </record>

</odoo>
