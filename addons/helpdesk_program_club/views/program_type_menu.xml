<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- Program Type list view -->
  <record id="helpdesk_program_type_view_list" model="ir.ui.view">
    <field name="name">helpdesk.program.type.list</field>
    <field name="model">helpdesk.program.type</field>
    <field name="arch" type="xml">
      <list string="Program Types" editable="bottom">
        <field name="name"/>
        <field name="active"/>
      </list>
    </field>
  </record>

  <!-- Program Type form view -->
  <record id="helpdesk_program_type_view_form" model="ir.ui.view">
    <field name="name">helpdesk.program.type.form</field>
    <field name="model">helpdesk.program.type</field>
    <field name="arch" type="xml">
      <form string="Program Type">
        <sheet>
          <group>
            <field name="name"/>
            <field name="active"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <!-- Action -->
  <record id="helpdesk_program_type_action" model="ir.actions.act_window">
    <field name="name">Program Types</field>
    <field name="res_model">helpdesk.program.type</field>
    <field name="view_mode">list,form</field>
  </record>

  <!-- Menu under Helpdesk > Configuration -->
  <menuitem
    id="helpdesk_program_type_menu"
    name="Program Types"
    parent="helpdesk.helpdesk_menu_root"
    action="helpdesk_program_type_action"
    sequence="50"/>

</odoo>
