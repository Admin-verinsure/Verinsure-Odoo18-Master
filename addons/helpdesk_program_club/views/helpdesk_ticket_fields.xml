<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!--
    Show Program Type and Club on the backend helpdesk ticket form
    so agents can see what was submitted from the website.
    Inserted after the "Customer" field which is always present.
  -->
  <record id="helpdesk_ticket_form_program_club" model="ir.ui.view">
    <field name="name">helpdesk.ticket.form.program.club</field>
    <field name="model">helpdesk.ticket</field>
    <field name="inherit_id" ref="helpdesk.helpdesk_ticket_view_form"/>
    <field name="arch" type="xml">

      <!-- Insert after the partner_id (Customer) field -->
      <xpath expr="//field[@name='partner_id']" position="after">
        <field name="program_type" string="Program Type" readonly="1"/>
        <field name="club_id"      string="Club"         readonly="1"
               options="{'no_open': True, 'no_create': True}"/>
      </xpath>

    </field>
  </record>

</odoo>
