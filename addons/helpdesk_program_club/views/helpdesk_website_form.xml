<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!--
    ══════════════════════════════════════════════════════════════════
    PROGRAM TYPE + CLUB DROPDOWNS — Helpdesk ticket form
    ══════════════════════════════════════════════════════════════════

    CONFIRMED FROM BROWSER INSPECTOR:
      - data-oe-id="6350"              → the active view being rendered
      - data-oe-field="arch"           → fields are stored in view arch (DB)
      - Submit element:
          <div class="s_website_form_submit …">
            <a class="btn … s_website_form_send" href="#" role="button">
              Submit
            </a>

    XPATH:  target  <div class="… s_website_form_submit …">
            position="before" → our fields land just above the Submit div,
            inside the <form> element.

    inherit_id: we use odoo_website_helpdesk.ticket_form (the shared key).
    Odoo applies inherited templates on top of whichever view wins for that
    key (id=6350 in your DB), so our fields are injected into the live arch.
    ══════════════════════════════════════════════════════════════════
  -->

  <template
      id="helpdesk_page_add_program_club"
      name="Helpdesk page: Program Type + Club"
      inherit_id="odoo_website_helpdesk.ticket_form">

    <xpath expr="//div[hasclass('s_website_form_submit')]" position="before">

      <!-- ── Program Type ──────────────────────────────────────────────── -->
      <div class="form-group col-12 s_website_form_field s_website_form_custom s_website_form_required"
           data-type="selection"
           data-name="Field">
        <label class="col-form-label s_website_form_label"
               for="helpdesk_program_type"
               style="width: 200px">
          <span class="s_website_form_label_content">Program Type</span>
          <span class="s_website_form_mark"> *</span>
        </label>

        <t t-set="club_types"
           t-value="(env['res.partner']._fields.get('club_type')
                     and env['res.partner']._fields['club_type'].selection)
                    or []"/>

        <select name="helpdesk_program_type"
                id="helpdesk_program_type"
                class="form-select s_website_form_input"
                required="required">
          <option value="">-- Select Program Type --</option>
          <t t-foreach="club_types" t-as="opt">
            <option
                t-att-value="opt[0]"
                t-att-selected="request.params.get('helpdesk_program_type') == opt[0] or None">
              <t t-esc="opt[1]"/>
            </option>
          </t>
        </select>
      </div>

      <!-- ── Club ─────────────────────────────────────────────────────── -->
      <div class="form-group col-12 s_website_form_field s_website_form_custom s_website_form_required"
           data-type="many2one"
           data-name="Field">
        <label class="col-form-label s_website_form_label"
               for="helpdesk_club_id"
               style="width: 200px">
          <span class="s_website_form_label_content">Club</span>
          <span class="s_website_form_mark"> *</span>
        </label>

        <t t-set="sel_program"
           t-value="request.params.get('helpdesk_program_type', '')"/>
        <t t-set="clubs"
           t-value="sel_program
                    and env['res.partner'].sudo().search(
                          [('club_type', '=', sel_program), ('active', '=', True)],
                          order='name')
                    or env['res.partner'].browse([])"/>

        <select name="helpdesk_club_id"
                id="helpdesk_club_id"
                class="form-select s_website_form_input"
                required="required">
          <t t-if="not sel_program">
            <option value="">-- Select Program Type first --</option>
          </t>
          <t t-if="sel_program and not clubs">
            <option value="">-- No clubs found for this program --</option>
          </t>
          <t t-if="sel_program and clubs">
            <option value="">-- Select Club --</option>
            <t t-foreach="clubs" t-as="c">
              <option
                  t-att-value="c.id"
                  t-att-selected="(request.params.get('helpdesk_club_id')
                                   and int(request.params.get('helpdesk_club_id') or 0) == c.id)
                                  or None">
                <t t-esc="c.name"/>
              </option>
            </t>
          </t>
        </select>
      </div>

    </xpath>
  </template>

</odoo>
