<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_partner_form_geocode_auto" model="ir.ui.view">
    <field name="name">res.partner geocode auto (server)</field>
    <field name="model">res.partner</field>
    <field name="inherit_id" ref="base.view_partner_form"/>
    <field name="arch" type="xml">

      <!-- NOTE: we no longer insert any <field name="x_auto_geocode"/> here. -->

      <!-- Add a Location tab showing both built-in and club coords -->
      <xpath expr="//form/sheet/notebook" position="inside">
        <page string="Location">
          <group>
            <group>
              <field name="partner_latitude"  string="Latitude"/>
              <field name="partner_longitude" string="Longitude"/>
              <!-- Show club_* too if your rotary module is present -->
              <field name="club_latitude"     string="Club Latitude"     attrs="{'invisible': [('club_latitude','=', False)]}"/>
              <field name="club_longitude"    string="Club Longitude"    attrs="{'invisible': [('club_longitude','=', False)]}"/>
            </group>
            <group>
              <button name="action_locate_from_address"
                      type="object"
                      class="btn btn-secondary"
                      string="Locate from Address"/>
              <label string="Uses the postal address above."/>
            </group>
          </group>
        </page>
      </xpath>

    </field>
  </record>
</odoo>
