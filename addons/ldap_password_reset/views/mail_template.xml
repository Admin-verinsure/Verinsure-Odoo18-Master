<odoo>
  <data>
    <record id="mail_reset_ldap_password" model="mail.template">
      <field name="name">Reset LDAP Password Email</field>
      <field name="model_id" ref="base.model_res_users"/>
      <field name="subject">${ctx.get('subject') or 'Password Reset OTP'}</field>
      <field name="email_from">${ctx.get('email_from') or 'no-reply@example.com'}</field>
      <field name="email_to">${object.partner_id.email or ''}</field>
      <field name="body_html"><![CDATA[
          <p>Hello ${object.name or 'user'},</p>
          <p>Your One Time Password (OTP) is: <b>${ctx.get('otp_code')}</b></p>
          <p>This code expires in 15 minutes.</p>
      ]]></field>
    </record>
  </data>
</odoo>
