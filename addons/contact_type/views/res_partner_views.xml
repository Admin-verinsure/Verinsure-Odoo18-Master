<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Inherit Partner Form View -->
    <record id="view_partner_form_contact_type" model="ir.ui.view">
        <field name="name">res.partner.form.contact.type</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <field name="category_id" position="after">
                <field name="contact_type_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
            </field>
        </field>
    </record>

    <!-- Inherit Partner Tree View -->
    <record id="view_partner_tree_contact_type" model="ir.ui.view">
        <field name="name">res.partner.tree.contact.type</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_tree"/>
        <field name="arch" type="xml">
            <field name="country_id" position="after">
                <field name="contact_type_ids" widget="many2many_tags" optional="show" options="{'color_field': 'color'}"/>
            </field>
        </field>
    </record>

    <!-- Inherit Kanaban View -->
    <record id="view_partner_kanban_inherit_custom" model="ir.ui.view">
        <field name="name">res.partner.kanban.inherit.custom</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.res_partner_kanban_view"/>
        <field name="arch" type="xml">
            <!-- Locate the email field in the kanban template -->
             <xpath expr="//field[@name='email']" position="after">
                <field name="contact_type_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
            </xpath>
        </field>
    </record>

    <!-- Inherit Partner Search View -->
    <record id="view_res_partner_filter_contact_type" model="ir.ui.view">
        <field name="name">res.partner.search.contact.type</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_res_partner_filter"/>
        <field name="arch" type="xml">
            <field name="category_id" position="after">
                <field name="contact_type_ids" string="Contact Type"/>
            </field>
            <filter name="type_company" position="after">
                <separator/>
                <filter name="filter_customer_type" string="Customers" domain="[('contact_type_ids.name', 'ilike', 'customer')]"/>
                <filter name="filter_vendor_type" string="Vendors" domain="[('contact_type_ids.name', 'ilike', 'vendor')]"/>
                <filter name="filter_employee_type" string="Employee" domain="[('contact_type_ids.name', 'ilike', 'Employee')]"/>
                <separator/>
                <filter string="Contact Type" name="group_contact_type" context="{'group_by': 'contact_type_ids'}"/>
            </filter>
        </field>
    </record>

</odoo>