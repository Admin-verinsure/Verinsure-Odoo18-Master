<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree View -->
    <record id="view_partner_contact_type_tree" model="ir.ui.view">
        <field name="name">partner.contact.type.tree</field>
        <field name="model">partner.contact.type</field>
        <field name="arch" type="xml">
            <list string="Contact Types" default_order="sequence">
                <field name="sequence" widget="handle"/>
                <field name="contact_code"/>
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

   <!-- Form View -->
    <record id="view_partner_contact_type_form" model="ir.ui.view">
        <field name="name">partner.contact.type.form</field>
        <field name="model">partner.contact.type</field>
        <field name="arch" type="xml">
            <form string="Contact Type">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="contact_code"/>
                        </h1>
                    </div>

                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_partners" 
                                type="object" 
                                class="oe_stat_button" 
                                icon="fa-users"
                                context="{'search_default_contact_type_ids': id}">
                            <field name="partner_count" widget="statinfo" string="Partners"/>
                        </button>
                    </div>

                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active == True"/>

                    <group>
                        <group>
                            <field name="name" placeholder="e.g., Customer, Vendor, Lead..."/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="color" widget="color_picker"/>
                            <field name="active"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Description" name="description">
                            <field name="description" nolabel="1" placeholder="Describe this contact type..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_partner_contact_type_search" model="ir.ui.view">
        <field name="name">partner.contact.type.search</field>
        <field name="model">partner.contact.type</field>
        <field name="arch" type="xml">
            <search string="Contact Types">
                <field name="name" string="Name"/>
                <field name="contact_code" string="Code"/>
                <field name="description"/>
                
                <filter name="active" string="Active" domain="[('active','=',True)]"/>
                <filter name="inactive" string="Inactive" domain="[('active','=',False)]"/>
                
                <group expand="0" string="Group By">
                    <filter string="Active Status" name="group_active" context="{'group_by':'active'}"/>
                </group>
            </search>
        </field>
    </record>

   <!-- Kanban View -->
    <record id="view_partner_contact_type_kanban" model="ir.ui.view">
        <field name="name">partner.contact.type.kanban</field>
        <field name="model">partner.contact.type</field>
        <field name="arch" type="xml">
            <kanban default_group_by="active" class="o_kanban_small_column">
                <field name="color"/>
                <field name="partner_count"/>
                <field name="name"/>
                <field name="contact_code"/>
                <field name="active"/>
                <field name="description"/>
                
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_color_#{kanban_getcolor(record.color.raw_value)} oe_kanban_card oe_kanban_global_click">
                            
                            <!-- Dropdown menu -->
                            <div class="o_dropdown_kanban dropdown">
                                <a class="dropdown-toggle o-no-caret btn" role="button" data-toggle="dropdown"
                                href="#" aria-label="Dropdown menu" title="Dropdown menu">
                                    <span class="fa fa-ellipsis-v" title="More options"/>
                                </a>
                                <div class="dropdown-menu" role="menu">
                                    <t t-if="widget.editable">
                                        <a role="menuitem" type="edit" class="dropdown-item">Edit</a>
                                    </t>
                                    <t t-if="widget.deletable">
                                        <a role="menuitem" type="delete" class="dropdown-item">Delete</a>
                                    </t>
                                    <div class="dropdown-divider"/>
                                    <div class="dropdown-item">
                                        <a name="action_view_partners"
                                           type="object"
                                           context="{'search_default_contact_type_ids': id}">
                                           View Partners
                                        </a>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Card content -->
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                    <span class="badge badge-secondary float-right">
                                        <field name="contact_code"/>
                                    </span>
                                </div>
                                <div class="o_kanban_record_body">
                                    <field name="description"/>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <span class="badge badge-pill badge-info">
                                            <i class="fa fa-users" title="Number of Partners"></i>
                                            <field name="partner_count"/> Partners
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Action -->
    <record id="action_partner_contact_type" model="ir.actions.act_window">
        <field name="name">Contact Types</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">partner.contact.type</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_partner_contact_type_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first contact type!
            </p>
            <p>
                Contact types help you categorize your partners.<br/>
                You can create types like Customer, Vendor, etc.
            </p>
        </field>
    </record>

     <menuitem id="menu_partner_contact_type"
              name="Contact Types"
              parent="contacts.res_partner_menu_config"
              action="action_partner_contact_type"
              sequence="5"/>

</odoo>
