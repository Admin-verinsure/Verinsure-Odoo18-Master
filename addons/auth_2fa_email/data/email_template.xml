<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="mail_template_otp" model="mail.template">
            <field name="name">Two-Factor Authentication OTP</field>
            <field name="model_id" ref="base.model_res_users"/>
            <field name="subject">{{ _('Your Login Verification Code') }}</field>
            <field name="email_to">{{ object.email }}</field>
            <field name="body_html"><![CDATA[
<div style="font-family: 'Segoe UI', Arial, sans-serif; max-width: 480px; margin: 0 auto; background: #ffffff; border-radius: 8px; overflow: hidden; border: 1px solid #e5e7eb;">

    <!-- Header -->
    <div style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%); padding: 32px 40px; text-align: center;">
        <div style="font-size: 36px; margin-bottom: 8px;">🔐</div>
        <h1 style="color: #ffffff; font-size: 20px; font-weight: 600; margin: 0; letter-spacing: 0.5px;">
            Login Verification
        </h1>
    </div>

    <!-- Body -->
    <div style="padding: 36px 40px;">
        <p style="color: #374151; font-size: 15px; margin: 0 0 12px 0;">
            Hello <strong>{{ object.name }}</strong>,
        </p>
        <p style="color: #6b7280; font-size: 14px; margin: 0 0 28px 0;">
            Use the code below to complete your login. It expires in <strong>10 minutes</strong>.
        </p>

        <!-- OTP Box -->
        <div style="background: #f3f4f6; border-radius: 10px; padding: 24px; text-align: center; margin-bottom: 28px; border: 2px dashed #d1d5db;">
            <div style="font-size: 11px; color: #9ca3af; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 10px;">
                One-Time Password
            </div>
            <div style="font-size: 40px; font-weight: 800; letter-spacing: 10px; color: #111827; font-family: 'Courier New', monospace;">
                {{ ctx.get('otp_code', '') }}
            </div>
        </div>

        <p style="color: #9ca3af; font-size: 12px; margin: 0; line-height: 1.6;">
            ⚠️ If you did not attempt to log in, please ignore this email and consider changing your password.
            Never share this code with anyone.
        </p>
    </div>

    <!-- Footer -->
    <div style="background: #f9fafb; padding: 16px 40px; border-top: 1px solid #e5e7eb; text-align: center;">
        <p style="color: #d1d5db; font-size: 11px; margin: 0;">
            This is an automated security email. Please do not reply.
        </p>
    </div>
</div>
            ]]></field>
        </record>

    </data>
</odoo>
