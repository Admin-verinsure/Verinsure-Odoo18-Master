<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================
         OTP Verification Page (rendered at /web/login/otp)
         ================================================================ -->
    <template id="otp_page" name="2FA OTP Verification">
        <t t-call="web.layout">
            <t t-set="head">
                <link rel="stylesheet" href="/auth_2fa_email/static/src/css/otp_login.css"/>
            </t>
            <div class="o_login_page otp-page-wrapper">

                <div class="otp-card">

                    <!-- Brand / Logo area -->
                    <div class="otp-header">
                        <div class="otp-shield-icon">🔐</div>
                        <h1 class="otp-title">Two-Factor Authentication</h1>
                        <p class="otp-subtitle">
                            We sent a 6-digit code to
                            <strong>
                                <t t-esc="user_email"/>
                            </strong>
                        </p>
                    </div>

                    <!-- Alerts -->
                    <t t-if="error">
                        <div class="otp-alert otp-alert-error">
                            <span class="otp-alert-icon">✕</span>
                            <span><t t-esc="error"/></span>
                        </div>
                    </t>
                    <t t-if="success">
                        <div class="otp-alert otp-alert-success">
                            <span class="otp-alert-icon">✓</span>
                            <span><t t-esc="success"/></span>
                        </div>
                    </t>

                    <!-- OTP Form -->
                    <form method="POST" action="/web/login/otp" id="otp_form">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <input type="hidden" name="redirect" t-att-value="redirect"/>

                        <div class="otp-digits-wrapper">
                            <!-- 6 individual digit inputs for UX; JS merges them into hidden field -->
                            <input class="otp-digit" type="text" inputmode="numeric"
                                   maxlength="1" autocomplete="off" aria-label="Digit 1"/>
                            <input class="otp-digit" type="text" inputmode="numeric"
                                   maxlength="1" autocomplete="off" aria-label="Digit 2"/>
                            <input class="otp-digit" type="text" inputmode="numeric"
                                   maxlength="1" autocomplete="off" aria-label="Digit 3"/>
                            <span class="otp-digit-sep">—</span>
                            <input class="otp-digit" type="text" inputmode="numeric"
                                   maxlength="1" autocomplete="off" aria-label="Digit 4"/>
                            <input class="otp-digit" type="text" inputmode="numeric"
                                   maxlength="1" autocomplete="off" aria-label="Digit 5"/>
                            <input class="otp-digit" type="text" inputmode="numeric"
                                   maxlength="1" autocomplete="off" aria-label="Digit 6"/>
                            <!-- Hidden field that holds the assembled code -->
                            <input type="hidden" name="otp_code" id="otp_hidden"/>
                        </div>

                        <!-- Countdown timer -->
                        <div class="otp-timer" id="otp_timer">
                            Code expires in <span id="otp_countdown">10:00</span>
                        </div>

                        <button type="submit" class="otp-submit-btn" id="otp_submit_btn" disabled="disabled">
                            Verify &amp; Sign In
                        </button>
                    </form>

                    <!-- Resend & Back links -->
                    <div class="otp-links">
                        <a href="#" id="otp_resend_link"
                           t-attf-href="/web/login/otp/resend?redirect=#{redirect}">
                            Resend Code
                        </a>
                        <span class="otp-link-sep">·</span>
                        <a href="/web/login">Back to Login</a>
                    </div>

                </div><!-- /.otp-card -->

            </div>
        </t>
    </template>


    <!-- ================================================================
         Add 2FA toggle to the user Preferences / Settings form
         ================================================================ -->
    <record id="view_users_form_2fa" model="ir.ui.view">
        <field name="name">res.users.form.2fa</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='preferences']" position="inside">
                <group string="Security">
                    <field name="two_factor_enabled" widget="boolean_toggle"/>
                </group>
            </xpath>
        </field>
    </record>

    <!-- Also expose the field on the user's own Preferences dialog -->
    <record id="view_res_users_preferences_2fa" model="ir.ui.view">
        <field name="name">res.users.preferences.2fa</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.res_users_view_form_profile"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='tz']" position="after">
                <field name="two_factor_enabled" widget="boolean_toggle"
                       string="Enable Two-Factor Authentication (Email OTP)"/>
            </xpath>
        </field>
    </record>

</odoo>
