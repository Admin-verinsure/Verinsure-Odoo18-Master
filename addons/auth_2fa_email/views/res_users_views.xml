<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================
         OTP Page — matches Odoo 18 default login page look & feel.
         All CSS and JS inlined. No t-call to any layout so website.layout
         singleton crash never fires.
         Rendered via ir.ui.view._render_template() + sudo() in controller.
         ================================================================ -->
    <template id="otp_page" name="2FA OTP Verification">
        <html lang="en">
            <head>
                <meta charset="UTF-8"/>
                <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
                <title>Two-Factor Authentication — Odoo</title>
                <style>
/* Reset */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

/* Page — matches Odoo login bg */
html, body {
    height: 100%;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    font-size: 14px;
    color: #333;
    background-color: #f3ede8;
}

body {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: 16px;
}

/* Card — matches Odoo login card */
.o_login_card {
    background: #fff;
    border-radius: 8px;
    box-shadow: 0 1px 3px rgba(0,0,0,.12), 0 4px 20px rgba(0,0,0,.08);
    width: 100%;
    max-width: 384px;
    overflow: hidden;
}

/* Header strip */
.o_login_header {
    background: #714B67;
    padding: 28px 32px 24px;
    text-align: center;
}

.o_login_header .shield {
    font-size: 32px;
    display: block;
    margin-bottom: 10px;
}

.o_login_header h1 {
    color: #fff;
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 6px;
    letter-spacing: .2px;
}

.o_login_header p {
    color: rgba(255,255,255,.75);
    font-size: 13px;
    line-height: 1.5;
}

.o_login_header p strong {
    color: #fff;
    font-weight: 500;
}

/* Body */
.o_login_body {
    padding: 28px 32px 24px;
}

/* Alert */
.alert {
    padding: 10px 14px;
    border-radius: 5px;
    font-size: 13px;
    margin-bottom: 16px;
    display: flex;
    align-items: flex-start;
    gap: 8px;
    line-height: 1.45;
}

.alert-danger {
    background: #fef2f2;
    border: 1px solid #fecaca;
    color: #b91c1c;
}

.alert-success {
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
    color: #15803d;
}

/* Digit inputs */
.digit-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    margin-bottom: 8px;
}

.otp-digit {
    width: 44px;
    height: 52px;
    text-align: center;
    font-size: 22px;
    font-weight: 600;
    font-family: "Courier New", monospace;
    color: #333;
    background: #fff;
    border: 1px solid #ced4da;
    border-radius: 6px;
    outline: none;
    transition: border-color .15s, box-shadow .15s;
    caret-color: #714B67;
}

.otp-digit:focus {
    border-color: #714B67;
    box-shadow: 0 0 0 3px rgba(113,75,103,.2);
}

.otp-digit.filled {
    border-color: #714B67;
    background: #fdf8fc;
}

.otp-sep {
    color: #adb5bd;
    font-size: 20px;
    user-select: none;
    padding: 0 2px;
}

/* Timer */
.otp-timer {
    text-align: center;
    font-size: 12px;
    color: #6c757d;
    margin-bottom: 20px;
}

#otp_countdown { font-weight: 600; color: #495057; }
#otp_countdown.expiring { color: #dc3545; }

/* Submit button — matches Odoo primary btn */
.btn-primary {
    display: block;
    width: 100%;
    padding: 10px 16px;
    background: #714B67;
    color: #fff;
    font-size: 14px;
    font-weight: 500;
    border: none;
    border-radius: 5px;
    cursor: pointer;
    transition: background .15s, opacity .15s;
    margin-bottom: 16px;
    letter-spacing: .2px;
}

.btn-primary:hover:not(:disabled) { background: #5c3d55; }
.btn-primary:disabled { opacity: .55; cursor: not-allowed; }

/* Links */
.o_login_links {
    text-align: center;
    font-size: 13px;
    color: #6c757d;
}

.o_login_links a {
    color: #714B67;
    text-decoration: none;
}

.o_login_links a:hover { text-decoration: underline; }
.o_login_links .sep { margin: 0 8px; color: #dee2e6; }

/* Footer */
.o_login_footer {
    margin-top: 20px;
    font-size: 12px;
    color: #adb5bd;
    text-align: center;
}
                </style>
            </head>
            <body>

                <div class="o_login_card">

                    <!-- Header -->
                    <div class="o_login_header">
                        <span class="shield">&#128274;</span>
                        <h1>Two-Factor Authentication</h1>
                        <p>We sent a 6-digit code to <strong><t t-esc="user_email"/></strong></p>
                    </div>

                    <!-- Body -->
                    <div class="o_login_body">

                        <!-- Error / success alerts -->
                        <t t-if="error">
                            <div class="alert alert-danger">
                                <span>&#9888; </span><span><t t-esc="error"/></span>
                            </div>
                        </t>
                        <t t-if="success">
                            <div class="alert alert-success">
                                <span>&#10003; </span><span><t t-esc="success"/></span>
                            </div>
                        </t>

                        <!-- OTP Form -->
                        <form method="POST" action="/web/login/otp" id="otp_form" autocomplete="off">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <input type="hidden" name="redirect" t-att-value="redirect"/>
                            <input type="hidden" name="otp_code" id="otp_hidden"/>

                            <div class="digit-row">
                                <input class="otp-digit" type="text" inputmode="numeric" maxlength="1" aria-label="Digit 1"/>
                                <input class="otp-digit" type="text" inputmode="numeric" maxlength="1" aria-label="Digit 2"/>
                                <input class="otp-digit" type="text" inputmode="numeric" maxlength="1" aria-label="Digit 3"/>
                                <span class="otp-sep">&#8212;</span>
                                <input class="otp-digit" type="text" inputmode="numeric" maxlength="1" aria-label="Digit 4"/>
                                <input class="otp-digit" type="text" inputmode="numeric" maxlength="1" aria-label="Digit 5"/>
                                <input class="otp-digit" type="text" inputmode="numeric" maxlength="1" aria-label="Digit 6"/>
                            </div>

                            <div class="otp-timer">
                                Expires in <span id="otp_countdown">10:00</span>
                            </div>

                            <button type="submit" class="btn-primary" id="otp_submit_btn" disabled="disabled">
                                Verify &#38; Sign In
                            </button>
                        </form>

                        <div class="o_login_links">
                            <t t-set="resend_url" t-value="'/web/login/otp/resend?redirect=' + (redirect or '/odoo')"/>
                            <a t-att-href="resend_url">Resend Code</a>
                            <span class="sep">|</span>
                            <a href="/web/login">&#8592; Back to Login</a>
                        </div>

                    </div><!-- /.o_login_body -->
                </div><!-- /.o_login_card -->

                <div class="o_login_footer">Powered by Odoo</div>

                <script>
(function () {
    var digits   = Array.from(document.querySelectorAll('.otp-digit'));
    var hidden   = document.getElementById('otp_hidden');
    var btn      = document.getElementById('otp_submit_btn');
    var cdEl     = document.getElementById('otp_countdown');
    var secs     = 600;

    function sync() {
        var code = digits.map(function (d) { return d.value; }).join('');
        hidden.value = code;
        btn.disabled = !/^\d{6}$/.test(code);
        digits.forEach(function (d) { d.classList.toggle('filled', !!d.value); });
    }

    digits.forEach(function (inp, i) {
        inp.addEventListener('keydown', function (e) {
            if (e.key === 'Backspace') {
                if (inp.value) { inp.value = ''; }
                else if (i > 0) { digits[i - 1].focus(); digits[i - 1].value = ''; }
                sync(); e.preventDefault();
            } else if (e.key === 'ArrowLeft'  &amp;&amp; i > 0) { digits[i - 1].focus(); }
              else if (e.key === 'ArrowRight' &amp;&amp; i &lt; 5) { digits[i + 1].focus(); }
        });
        inp.addEventListener('input', function () {
            inp.value = inp.value.replace(/\D/g, '').slice(-1);
            if (inp.value &amp;&amp; i &lt; 5) { digits[i + 1].focus(); }
            sync();
        });
        inp.addEventListener('click', function () { inp.select(); });
        inp.addEventListener('paste', function (e) {
            e.preventDefault();
            var p = (e.clipboardData || window.clipboardData).getData('text').replace(/\D/g, '').slice(0, 6);
            p.split('').forEach(function (c, j) { if (digits[j]) digits[j].value = c; });
            digits[Math.min(p.length, 5)].focus();
            sync();
        });
    });

    digits[0].focus();

    // Countdown timer
    function tick() {
        secs--;
        if (secs &lt;= 0) {
            cdEl.textContent = '00:00';
            cdEl.classList.add('expiring');
            btn.disabled = true;
            return;
        }
        var m = String(Math.floor(secs / 60)).padStart(2, '0');
        var s = String(secs % 60).padStart(2, '0');
        cdEl.textContent = m + ':' + s;
        if (secs &lt;= 60) cdEl.classList.add('expiring');
        setTimeout(tick, 1000);
    }
    setTimeout(tick, 1000);
})();
                </script>
            </body>
        </html>
    </template>


    <!-- ================================================================
         Security tab on Settings > Users form
         ================================================================ -->
    <record id="view_users_form_2fa" model="ir.ui.view">
        <field name="name">res.users.form.2fa</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='preferences']" position="before">
                <page name="two_factor_auth" string="Security">
                    <group>
                        <field name="two_factor_enabled" widget="boolean_toggle"
                               string="Enable Two-Factor Authentication (Email OTP)"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
