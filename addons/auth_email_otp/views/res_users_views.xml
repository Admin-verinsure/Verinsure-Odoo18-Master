<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Add 2FA toggle to User Form -->
    <record id="view_users_form_2fa" model="ir.ui.view">
        <field name="name">res.users.form.2fa</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">

            <xpath expr="//page[@name='access_rights']" position="after">
                <page name="two_factor_auth"
                      string="Two-Factor Authentication"
                      groups="base.group_erp_manager">

                    <group string="Email 2FA Settings">
                        <field name="email_otp_enabled"
                               widget="boolean_toggle"/>

                        <div class="alert alert-info"
                             role="alert"
                             invisible="not email_otp_enabled">
                            <strong>Email 2FA is active.</strong>
                            This user will receive a One-Time Password by email during login.
                        </div>

                        <div class="alert alert-warning"
                             role="alert"
                             invisible="email_otp_enabled">
                            Email 2FA is currently disabled for this user.
                        </div>

                    </group>

                </page>
            </xpath>

        </field>
    </record>

    <!-- Add 2FA column to Users List -->
    <record id="view_users_list_2fa" model="ir.ui.view">
        <field name="name">res.users.list.2fa</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='login']" position="after">
                <field name="email_otp_enabled"
                       string="2FA"
                       optional="show"
                       groups="base.group_erp_manager"/>
            </xpath>
        </field>
    </record>

</odoo>