<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Odoo 18 syntax rules used throughout:
        ──────────────────────────────────────
        • <tree> → <list>  (tree tag deprecated/removed in v18)
        • attrs={}         → inline invisible="expr"  (attrs removed in v18)
        • optional="show"  → NOT used on list columns (causes ParseError in v18
                             when the parent list view tag is unknown)
        • hasclass()       → used for class-based XPath (robust across versions)

        TWO inherited views strategy:
        1. Priority 16 — injects into existing oe_button_box (when Sale /
           Accounting add their own buttons first).
        2. Priority 100 — fallback that creates the button box before the
           partner name field, which ALWAYS exists in base.view_partner_form.
    -->

    <!-- ── Primary: existing oe_button_box ───────────────────────────── -->
    <record id="view_partner_form_dms_btn_primary" model="ir.ui.view">
        <field name="name">res.partner.form.dms.btn.primary</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="priority">16</field>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('oe_button_box')]" position="inside">
                <button
                    name="action_open_dms_files"
                    type="object"
                    class="oe_stat_button o_partner_dms_btn"
                    icon="fa-folder-open-o"
                >
                    <field
                        name="dms_file_count"
                        widget="statinfo"
                        string="Documents"
                    />
                </button>
            </xpath>
        </field>
    </record>

    <!-- ── Fallback: inject button box before name field ─────────────── -->
    <record id="view_partner_form_dms_btn_fallback" model="ir.ui.view">
        <field name="name">res.partner.form.dms.btn.fallback</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="before">
                <div class="oe_button_box" name="button_box"
                     invisible="not id">
                    <button
                        name="action_open_dms_files"
                        type="object"
                        class="oe_stat_button o_partner_dms_btn"
                        icon="fa-folder-open-o"
                    >
                        <field
                            name="dms_file_count"
                            widget="statinfo"
                            string="Documents"
                        />
                    </button>
                </div>
            </xpath>
        </field>
    </record>

</odoo>
