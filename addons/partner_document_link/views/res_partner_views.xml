<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Inherit the standard res.partner form view and add a DMS smart button.

        Odoo 18 notes:
        - Use invisible="..." inline expressions (attrs removed in v18)
        - button type="object" calls a Python method on the model
        - widget="statinfo" renders the count + label in stat-button style
        - No security group restriction here so it works for all DMS setups;
          add groups="dms.group_dms_user" if your DMS version has that group
    -->

    <record id="view_partner_form_dms_button" model="ir.ui.view">
        <field name="name">res.partner.form.dms.button</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">

            <xpath expr="//div[@name='button_box']" position="inside">
                <button
                    name="action_open_dms_files"
                    type="object"
                    class="oe_stat_button o_partner_dms_btn"
                    icon="fa-folder-open-o"
                >
                    <field
                        name="dms_file_count"
                        widget="statinfo"
                        string="Documents"
                    />
                </button>
            </xpath>

        </field>
    </record>

</odoo>
