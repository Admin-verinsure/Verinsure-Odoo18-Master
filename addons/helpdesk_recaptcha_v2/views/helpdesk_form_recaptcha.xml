<?xml version="1.0" encoding="utf-8"?>
<!--
    helpdesk_form_recaptcha.xml
    ════════════════════════════
    Inherits the Helpdesk website form and injects reCAPTCHA v3 using
    Odoo 18's native `website.recaptcha` sub-template.

    Odoo 18 XPath notes
    ────────────────────
    • `website_helpdesk.website_helpdesk_form_view` is the correct
      external ID for the Helpdesk ticket form in Odoo 18.
    • `t-call="website.recaptcha"` renders the hidden g-recaptcha-response
      input AND the grecaptcha.execute() script call.  It reads
      recaptcha.site_key automatically from ir.config_parameter.
    • We do NOT add a separate <script> tag for api.js – website_recaptcha
      already does that in the page's <head> via its own ir.asset record.
    • The form already has a unique action; we add an id attribute via
      XPath "attributes" position so our JS can target it precisely.

    Error handling
    ──────────────
    The hidden #helpdesk_captcha_error div is shown by our JS when the
    controller returns {captcha_error: true}.  It is completely invisible
    until then (Bootstrap d-none).
-->
<odoo>
    <data>

        <template
            id="helpdesk_form_recaptcha"
            inherit_id="website_helpdesk.website_helpdesk_form_view"
            name="Helpdesk Form – reCAPTCHA v3">

            <!--
            ── STEP 1: Give the form a unique id so JS can target it ─────────
               position="attributes" appends/sets attributes on the matched node.
               We match the form by its data-model_name attribute which Odoo's
               website_form module always sets.
            -->
            <xpath
                expr="//form[@data-model_name='helpdesk.ticket']"
                position="attributes">
                <attribute name="id">helpdesk_recaptcha_form</attribute>
            </xpath>

            <!--
            ── STEP 2: Inject reCAPTCHA widget + error div ───────────────────
               Insert just before the row that contains the Submit button so
               the CAPTCHA appears at the bottom of the form, above the button.

               `t-call="website.recaptcha"` is provided by the
               website_recaptcha module (addons/website_recaptcha/views/).
               It renders:
                 • A hidden <input name="g-recaptcha-response"> field
                 • An inline <script> that calls grecaptcha.execute() on submit
               Nothing else needs to be done in XML for v3.
            -->
            <xpath
                expr="//form[@id='helpdesk_recaptcha_form']//div[hasclass('s_website_form_submit')]"
                position="before">

                <!-- Odoo 18 native reCAPTCHA v3 widget -->
                <t t-call="website.recaptcha"/>

                <!-- Error message – hidden by default, shown by JS on 400 response -->
                <div
                    id="helpdesk_captcha_error"
                    class="alert alert-danger d-none mt-2"
                    role="alert">
                    <i class="fa fa-exclamation-triangle me-1"/>
                    <span id="helpdesk_captcha_error_text">
                        CAPTCHA verification failed. Please try again.
                    </span>
                </div>

            </xpath>

        </template>

    </data>
</odoo>
