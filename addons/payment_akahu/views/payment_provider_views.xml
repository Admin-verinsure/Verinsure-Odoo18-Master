<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="payment_provider_form_akahu" model="ir.ui.view">
        <field name="name">Akahu Provider Form</field>
        <field name="model">payment.provider</field>
        <field name="inherit_id" ref="payment.payment_provider_form"/>
        <field name="arch" type="xml">

            <!-- Add fields after provider credentials group -->
            <group name="provider_credentials" position="after">
                <group invisible="code != 'akahu'">
                    <field name="akahu_app_token"/>
                    <field name="akahu_user_token"/>
                </group>
            </group>

        </field>
    </record>

</odoo>