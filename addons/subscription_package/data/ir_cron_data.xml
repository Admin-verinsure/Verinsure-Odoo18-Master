<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Cron Job: Check Close Limit and Send Renewal Alerts.
        NOTE: numbercall was removed in Odoo 17+; crons run indefinitely
        by default. Invoice creation is handled exclusively by
        run_auto_subscription_billing below.
    -->
    <record id="close_limit_cron" model="ir.cron">
        <field name="name">Check Close Limit</field>
        <field name="model_id" ref="model_subscription_package"/>
        <field name="state">code</field>
        <field name="code">model.close_limit_cron()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
    </record>

    <!--
        Cron Job: Automatic Subscription Billing.
        Owns all invoice creation for draft_invoice mode subscriptions.
        Runs daily. Skips manual-mode plans, closed subscriptions, and
        subscriptions that already have an invoice for the current period.
    -->
    <record id="auto_subscription_billing_cron" model="ir.cron">
        <field name="name">Auto Subscription Billing</field>
        <field name="model_id" ref="model_subscription_package"/>
        <field name="state">code</field>
        <field name="code">model.run_auto_subscription_billing()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
    </record>
</odoo>
