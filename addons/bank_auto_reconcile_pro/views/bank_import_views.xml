<odoo>
    <record id="view_bank_import_wizard" model="ir.ui.view">
        <field name="name">bank.import.wizard.form</field>
        <field name="model">bank.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Bank Transactions">
                <group>
                    <field name="journal_id"/>
                    <field name="file"/>
                </group>
                <footer>
                    <button string="Import"
                            type="object"
                            name="action_import"
                            class="btn-primary"/>
                    <button string="Cancel"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_bank_import_wizard" model="ir.actions.act_window">
        <field name="name">Import Bank Transactions</field>
        <field name="res_model">bank.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_bank_import"
              name="Bank Import"
              parent="account.menu_finance"
              action="action_bank_import_wizard"/>
</odoo>
