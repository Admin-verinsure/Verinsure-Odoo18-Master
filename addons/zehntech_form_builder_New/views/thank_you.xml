<odoo>
  <template id="form_thank_you_template" name="Thank You Page">
    <t t-call="web.layout">
      <style>
        .thank-you-page {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        background: linear-gradient(135deg, #f8fafc, #e2e8f0);
        }
        .thank-you-card {
        max-width: 500px;
        padding: 30px;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
        background-color: #ffffff;
        animation: fadeIn 1s ease-in-out;
        }
        .thank-you-icon {
        font-size: 60px;
        color: #28a745;
        margin-bottom: 20px;
        animation: bounce 1s infinite alternate;
        }
        @keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
        }
        @keyframes bounce {
        from { transform: scale(1); }
        to { transform: scale(1.1); }
        }
      </style>
      <script type="text/javascript"> window.FORM_LANGUAGE = '<t t-esc="user_lang or 'en'" />'; </script>

      <div class="thank-you-page">
        <div class="thank-you-card">
          <div class="thank-you-icon">
            <i class="fa fa-check-circle"></i>
          </div>
          <h1 class="text-success mb-3" id="thankYouTitle">Thank You!</h1>
          <p class="text-muted mb-4" id="thankYouMessage">
            <!-- <t t-esc="thank_you_message or 'Your form has been submitted successfully.'" /> -->
          </p>
          <t t-if="form_url">
            <a t-attf-href="#{form_url}" class="btn btn-primary btn-home" id="submitAnotherBtn">
              <span id="submitBtnText">Submit Another Response</span>
            </a>

          </t>
        </div>
      </div>

      <script src="/zehntech_form_builder/static/src/js/translations.js"></script>
      <script src="/zehntech_form_builder/static/src/js/public_translations.js"></script>

      <script type="text/javascript"> document.addEventListener('DOMContentLoaded', function() {
        const lang = window.FORM_LANGUAGE || 'en';

        const thankYouMsg = '<t t-esc="thank_you_message or 'Your form has been submitted successfully.'" />';
        document.getElementById('thankYouMessage').textContent = window._t(thankYouMsg);
        
        document.getElementById('thankYouTitle').textContent = window._t('Thank You!');
        document.getElementById('submitBtnText').textContent = window._t('Submit Another Response');
      
        });
      </script>
    </t>
  </template>
</odoo>