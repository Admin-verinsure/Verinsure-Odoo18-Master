<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- PDF Report Action -->
    <record id="action_customer_statement_pdf" model="ir.actions.report">
        <field name="name">Customer Statement</field>
        <field name="model">customer.statement.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">customer_statement_report.report_customer_statement</field>
        <field name="report_file">customer_statement_report.report_customer_statement</field>
        <field name="print_report_name">'Customer Statement - %s to %s' % (object.date_from, object.date_to)</field>
        <field name="paperformat_id" ref="base.paperformat_euro"/>
    </record>

</odoo>
