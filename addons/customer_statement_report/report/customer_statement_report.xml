<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- PDF Report Action -->
    <record id="action_customer_statement_pdf" model="ir.actions.report">
        <field name="name">Customer Statement</field>
        <field name="model">customer.statement.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">customer_statement_report.report_customer_statement_template</field>
        <field name="report_file">customer_statement_report.report_customer_statement_template</field>
        <field name="print_report_name">'Customer_Statement_%s' % object.partner_id.name</field>
        <field name="binding_model_id" ref="base.model_res_partner"/>
    </record>

</odoo>
