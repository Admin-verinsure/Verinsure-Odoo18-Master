<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="report_customer_statement">
    <t t-call="web.html_container">
        <t t-set="statements" t-value="doc.get_report_data()"/>
        <t t-foreach="statements" t-as="stmt">
            <t t-call="web.external_layout">
                <div class="page cs-page">

                    <!-- ══════════════════════════════════════════
                         REPORT HEADER
                    ══════════════════════════════════════════ -->
                    <div class="cs-report-header">
                        <div class="row mb-3">
                            <div class="col-7">
                                <h2 class="cs-title">
                                    <span class="cs-title-icon">📋</span>
                                    Account Statement
                                </h2>
                                <div class="cs-period-badge">
                                    Period: <strong>
                                        <t t-esc="doc.date_from.strftime('%d %b %Y')"/>
                                    </strong>
                                    &amp;nbsp;→&amp;nbsp;
                                    <strong>
                                        <t t-esc="doc.date_to.strftime('%d %b %Y')"/>
                                    </strong>
                                </div>
                                <div class="cs-meta mt-1">
                                    <span class="badge bg-light text-dark border me-1">
                                        <t t-esc="dict(doc.fields_get(['statement_type'])['statement_type']['selection']).get(doc.statement_type, doc.statement_type)"/>
                                    </span>
                                    <span class="badge bg-light text-dark border">
                                        Currency: <t t-esc="doc.currency_id.name"/>
                                    </span>
                                </div>
                            </div>
                            <div class="col-5 text-end">
                                <div class="cs-customer-block">
                                    <div class="cs-customer-label">BILL TO</div>
                                    <div class="cs-customer-name">
                                        <t t-esc="stmt['partner_name']"/>
                                    </div>
                                    <t t-if="stmt['partner_ref']">
                                        <div class="cs-customer-ref">Ref: <t t-esc="stmt['partner_ref']"/></div>
                                    </t>
                                    <t t-if="stmt['partner_street']">
                                        <div><t t-esc="stmt['partner_street']"/></div>
                                    </t>
                                    <t t-if="stmt['partner_city']">
                                        <div><t t-esc="stmt['partner_city']"/><t t-if="stmt['partner_country']">, <t t-esc="stmt['partner_country']"/></t></div>
                                    </t>
                                    <t t-if="stmt['partner_vat']">
                                        <div>VAT: <t t-esc="stmt['partner_vat']"/></div>
                                    </t>
                                    <t t-if="stmt['partner_email']">
                                        <div><t t-esc="stmt['partner_email']"/></div>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ══════════════════════════════════════════
                         SUMMARY BOXES
                    ══════════════════════════════════════════ -->
                    <div class="row cs-summary-row mb-4">
                        <div class="col-3">
                            <div class="cs-summary-box cs-box-neutral">
                                <div class="cs-box-label">Opening Balance</div>
                                <div class="cs-box-value">
                                    <t t-esc="stmt['currency'].symbol"/>
                                    <t t-esc="'%.2f' % stmt['opening_balance']"/>
                                </div>
                            </div>
                        </div>
                        <div class="col-3">
                            <div class="cs-summary-box cs-box-debit">
                                <div class="cs-box-label">Total Invoiced</div>
                                <div class="cs-box-value">
                                    <t t-esc="stmt['currency'].symbol"/>
                                    <t t-esc="'%.2f' % stmt['total_debit']"/>
                                </div>
                            </div>
                        </div>
                        <div class="col-3">
                            <div class="cs-summary-box cs-box-credit">
                                <div class="cs-box-label">Total Payments</div>
                                <div class="cs-box-value">
                                    <t t-esc="stmt['currency'].symbol"/>
                                    <t t-esc="'%.2f' % stmt['total_credit']"/>
                                </div>
                            </div>
                        </div>
                        <div class="col-3">
                            <div class="cs-summary-box cs-box-balance">
                                <div class="cs-box-label">Closing Balance</div>
                                <div class="cs-box-value">
                                    <t t-esc="stmt['currency'].symbol"/>
                                    <t t-esc="'%.2f' % stmt['closing_balance']"/>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ══════════════════════════════════════════
                         TRANSACTION TABLE
                    ══════════════════════════════════════════ -->
                    <t t-if="doc.statement_type != 'summary'">
                        <table class="table table-sm cs-table">
                            <thead>
                                <tr class="cs-table-header">
                                    <th style="width:10%">Date</th>
                                    <th style="width:14%">Reference</th>
                                    <th style="width:22%">Description</th>
                                    <th style="width:12%">Journal</th>
                                    <th style="width:10%">Due Date</th>
                                    <th style="width:10%;text-align:right">Invoiced</th>
                                    <th style="width:10%;text-align:right">Paid</th>
                                    <th style="width:12%;text-align:right">Balance</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Opening Balance Row -->
                                <t t-if="doc.show_opening_balance">
                                    <tr class="cs-opening-row">
                                        <td colspan="7"><strong>Opening Balance as of
                                            <t t-esc="doc.date_from.strftime('%d %b %Y')"/>
                                        </strong></td>
                                        <td class="text-end"><strong>
                                            <t t-esc="stmt['currency'].symbol"/>
                                            <t t-esc="'%.2f' % stmt['opening_balance']"/>
                                        </strong></td>
                                    </tr>
                                </t>

                                <!-- Transaction Lines -->
                                <t t-foreach="stmt['lines']" t-as="line">
                                    <tr t-attf-class="cs-line-row #{('cs-reconciled' if line['reconciled'] else '')}">
                                        <td>
                                            <t t-if="line['date']">
                                                <t t-esc="line['date'].strftime('%d/%m/%Y') if hasattr(line['date'], 'strftime') else line['date']"/>
                                            </t>
                                        </td>
                                        <td class="cs-ref-cell">
                                            <t t-esc="line['move_name']"/>
                                            <t t-if="line['invoice_origin']">
                                                <br/><small class="text-muted"><t t-esc="line['invoice_origin']"/></small>
                                            </t>
                                        </td>
                                        <td><t t-esc="line['label']"/></td>
                                        <td><small><t t-esc="line['journal']"/></small></td>
                                        <td>
                                            <t t-if="line['due_date']">
                                                <t t-esc="line['due_date'].strftime('%d/%m/%Y') if hasattr(line['due_date'], 'strftime') else line['due_date']"/>
                                            </t>
                                        </td>
                                        <td class="text-end cs-debit">
                                            <t t-if="line['debit'] > 0">
                                                <t t-esc="stmt['currency'].symbol"/>
                                                <t t-esc="'%.2f' % line['debit']"/>
                                            </t>
                                        </td>
                                        <td class="text-end cs-credit">
                                            <t t-if="line['credit'] > 0">
                                                <t t-esc="stmt['currency'].symbol"/>
                                                <t t-esc="'%.2f' % line['credit']"/>
                                            </t>
                                        </td>
                                        <td class="text-end cs-balance-cell">
                                            <strong>
                                                <t t-esc="stmt['currency'].symbol"/>
                                                <t t-esc="'%.2f' % line['balance']"/>
                                            </strong>
                                        </td>
                                    </tr>
                                </t>

                                <!-- No Lines -->
                                <t t-if="not stmt['lines']">
                                    <tr>
                                        <td colspan="8" class="text-center text-muted py-3">
                                            No transactions found for this period.
                                        </td>
                                    </tr>
                                </t>

                                <!-- Totals Row -->
                                <tr class="cs-totals-row">
                                    <td colspan="5"><strong>Period Totals</strong></td>
                                    <td class="text-end">
                                        <strong>
                                            <t t-esc="stmt['currency'].symbol"/>
                                            <t t-esc="'%.2f' % stmt['total_debit']"/>
                                        </strong>
                                    </td>
                                    <td class="text-end">
                                        <strong>
                                            <t t-esc="stmt['currency'].symbol"/>
                                            <t t-esc="'%.2f' % stmt['total_credit']"/>
                                        </strong>
                                    </td>
                                    <td class="text-end">
                                        <strong class="cs-closing-balance">
                                            <t t-esc="stmt['currency'].symbol"/>
                                            <t t-esc="'%.2f' % stmt['closing_balance']"/>
                                        </strong>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </t>

                    <!-- ══════════════════════════════════════════
                         AGING ANALYSIS
                    ══════════════════════════════════════════ -->
                    <t t-if="doc.show_aging and stmt['aging']">
                        <div class="cs-aging-section mt-4">
                            <h5 class="cs-section-title">Aging Analysis — Outstanding Receivables</h5>
                            <table class="table table-bordered cs-aging-table">
                                <thead>
                                    <tr class="cs-aging-header">
                                        <th>Current</th>
                                        <th>1–<t t-esc="doc.aging_bucket_1"/> days</th>
                                        <th><t t-esc="doc.aging_bucket_1 + 1"/>–<t t-esc="doc.aging_bucket_2"/> days</th>
                                        <th><t t-esc="doc.aging_bucket_2 + 1"/>–<t t-esc="doc.aging_bucket_3"/> days</th>
                                        <th>+<t t-esc="doc.aging_bucket_3"/> days</th>
                                        <th class="cs-aging-total">Total Outstanding</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr class="cs-aging-row">
                                        <td class="text-end">
                                            <t t-esc="stmt['currency'].symbol"/>
                                            <t t-esc="'%.2f' % stmt['aging']['current']"/>
                                        </td>
                                        <td class="text-end cs-aging-warn1">
                                            <t t-esc="stmt['currency'].symbol"/>
                                            <t t-esc="'%.2f' % stmt['aging']['bucket_1']"/>
                                        </td>
                                        <td class="text-end cs-aging-warn2">
                                            <t t-esc="stmt['currency'].symbol"/>
                                            <t t-esc="'%.2f' % stmt['aging']['bucket_2']"/>
                                        </td>
                                        <td class="text-end cs-aging-warn3">
                                            <t t-esc="stmt['currency'].symbol"/>
                                            <t t-esc="'%.2f' % stmt['aging']['bucket_3']"/>
                                        </td>
                                        <td class="text-end cs-aging-overdue">
                                            <t t-esc="stmt['currency'].symbol"/>
                                            <t t-esc="'%.2f' % stmt['aging']['bucket_4_plus']"/>
                                        </td>
                                        <td class="text-end cs-aging-total-val">
                                            <strong>
                                                <t t-esc="stmt['currency'].symbol"/>
                                                <t t-esc="'%.2f' % stmt['aging']['total']"/>
                                            </strong>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </t>

                    <!-- ══════════════════════════════════════════
                         FOOTER NOTE
                    ══════════════════════════════════════════ -->
                    <div class="cs-footer-note mt-4">
                        <div class="row">
                            <div class="col-8">
                                <p class="text-muted" style="font-size:9px;">
                                    This statement was generated on
                                    <t t-esc="context_timestamp(datetime.datetime.now()).strftime('%d %b %Y %H:%M')"/>
                                    and reflects transactions up to <t t-esc="doc.date_to.strftime('%d %b %Y')"/>.
                                    Please contact us if you have any queries regarding this statement.
                                </p>
                            </div>
                            <div class="col-4 text-end">
                                <div class="cs-balance-due">
                                    <div class="cs-balance-due-label">AMOUNT DUE</div>
                                    <div class="cs-balance-due-value">
                                        <t t-esc="stmt['currency'].symbol"/>
                                        <t t-esc="'%.2f' % stmt['closing_balance']"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </t>
        </t>
    </t>
</template>
</odoo>
