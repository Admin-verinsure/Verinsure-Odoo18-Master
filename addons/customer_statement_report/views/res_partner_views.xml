<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Inherit res.partner form to add Customer Statement smart button -->
    <record id="view_partner_form_customer_statement" model="ir.ui.view">
        <field name="name">res.partner.form.customer.statement</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">

            <!-- Smart button in the button box -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="%(customer_statement_report.action_customer_statement_wizard)d"
                        type="action"
                        class="oe_stat_button"
                        icon="fa-file-text-o"
                        attrs="{'invisible': [('customer_rank', '&lt;=', 0)]}"
                        context="{'default_partner_id': active_id}">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Customer</span>
                        <span class="o_stat_text">Statement</span>
                    </div>
                </button>
            </xpath>

        </field>
    </record>

</odoo>
