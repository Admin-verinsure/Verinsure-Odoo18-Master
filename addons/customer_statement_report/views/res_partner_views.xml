<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════════
         Add "Customer Statement" to the Action Menu on Partners
         (Customers list and form view)
    ═══════════════════════════════════════════════════════════ -->

    <!-- Action menu entry on Customers list view -->
    <record id="action_customer_statement_from_partners" model="ir.actions.act_window">
        <field name="name">Print Customer Statement</field>
        <field name="res_model">customer.statement.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="customer_statement_report.view_customer_statement_wizard_form"/>
        <field name="target">new</field>
        <field name="binding_model_id" ref="base.model_res_partner"/>
        <field name="binding_view_types">list,form</field>
        <field name="context">{}</field>
    </record>

</odoo>
