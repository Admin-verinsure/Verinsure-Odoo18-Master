<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    
    <template id="customer_report_template">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">

                <!-- ── Page styles ── -->
                <style>
                    .cs-title {
                        text-align: center;
                        font-size: 17px;
                        font-weight: 700;
                        letter-spacing: 1px;
                        margin-bottom: 16px;
                        color: #1F3864;
                    }
                    .cs-meta-table td {
                        padding: 2px 6px;
                        font-size: 10px;
                        vertical-align: top;
                    }
                    .cs-meta-label { font-weight: 700; color: #444; }

                    .cs-opening-row td {
                        background: #D6E4F0;
                        font-weight: 700;
                        font-size: 10px;
                        padding: 5px 8px;
                        border: 1px solid #A0BDD8;
                    }

                    .cs-ledger {
                        width: 100%;
                        border-collapse: collapse;
                        margin-top: 10px;
                        font-size: 9.5px;
                    }


                    .cs-ledger thead {
                        display: table-row-group;
                    }
                    .cs-ledger thead tr {
                        background: #1F3864;
                        color: #fff;
                    }
                    .cs-ledger thead th {
                        padding: 6px;
                        text-align: center;
                        border: 1px solid #1F3864;
                        font-weight: 700;
                    }

                    .cs-ledger tbody tr:nth-child(odd)  { background: #F5F8FB; }
                    .cs-ledger tbody tr:nth-child(even) { background: #fff; }
                    .cs-ledger tbody td {
                        padding: 4px 6px;
                        border: 1px solid #D0D0D0;
                        vertical-align: middle;
                    }

                    /* Net balance row — plain tbody row styled to look like tfoot */
                    .cs-ledger-total td {
                        background: #1F3864;
                        color: #fff;
                        font-weight: 700;
                        font-size: 11px;
                        padding: 6px 8px;
                        border: 1px solid #1F3864;
                    }

                    .txt-right  { text-align: right; }
                    .txt-center { text-align: center; }
                    .txt-left   { text-align: left; }
                    .type-invoice    { color: #375623; font-weight: 600; }
                    .type-creditnote { color: #C00000; font-weight: 600; }
                    .bal-negative    { color: #C00000; }
                    .bal-negative-white { color: #FF6B6B; }
                </style>

                <!-- ── Report Title ── -->
                <p class="cs-title">STATEMENT OF ACCOUNT</p>

                <!-- ── Header meta block ── -->
                <table class="cs-meta-table" style="width:100%;margin-bottom:12px;">
                    <tr>
                        <!-- Customer address -->
                        <td style="width:55%;vertical-align:top;">
                            <strong style="font-size:11px;">
                                <t t-out="partner['name']"/>
                            </strong><br/>
                            <t t-if="partner['street']">
                                <t t-out="partner['street']"/><br/>
                            </t>
                            <t t-if="partner['street2']">
                                <t t-out="partner['street2']"/><br/>
                            </t>
                            <t t-if="partner['city'] or partner['zip']">
                                <t t-out="partner['city']"/>
                                <t t-if="partner['city'] and partner['zip']">, </t>
                                <t t-out="partner['zip']"/><br/>
                            </t>
                            <t t-if="partner['state']">
                                <t t-out="partner['state']"/><br/>
                            </t>
                            <t t-if="partner['country']">
                                <t t-out="partner['country']"/>
                            </t>
                        </td>
                        <!-- Statement meta -->
                        <td style="width:45%;vertical-align:top;text-align:right;">
                            <table style="margin-left:auto;">
                                <tr>
                                    <td class="cs-meta-label">Period:</td>
                                    <td>
                                        <t t-out="start_date"/> — <t t-out="end_date"/>
                                    </td>
                                </tr>
                                                            <tr>
                                <td class="cs-meta-label">Currency:</td>
                                <td>
                                    <span class="currency-text">
                                        New Zealand Dollar  <t t-out="company_info['currency_symbol']"/>
                                    </span>
                                </td>
                            </tr>
                            </table>
                        </td>
                    </tr>
                </table>

                <!-- ── Ledger table ── -->
                <!-- NOTE: No <tfoot> — replaced with a tbody row so wkhtmltopdf
                     does NOT repeat the NET BALANCE on every page break -->
                <table class="cs-ledger">
                    <thead>
                        <tr>
                            <th style="width:11%;">Date</th>
                            <th style="width:22%;">Document No.</th>
                            <th style="width:13%;">Type</th>
                            <th style="width:14%;" class="txt-right">Debit</th>
                            <th style="width:14%;" class="txt-right">Credit</th>
                            <th style="width:14%;" class="txt-right">Balance</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Opening Balance row -->
                        <tr class="cs-opening-row">
                            <td colspan="5" class="txt-left">
                                Opening Balance (before period)
                            </td>
                            <td class="txt-right">
                                <t t-out="'%.2f' % opening_balance"/>
                            </td>
                        </tr>

                        <!-- Ledger lines -->
                        <t t-foreach="lines" t-as="line">
                            <tr>
                                <td class="txt-center">
                                    <t t-out="line['date']"/>
                                </td>
                                <td class="txt-left">
                                    <t t-out="line['name']"/>
                                </td>
                                <td class="txt-center">
                                    <span t-attf-class="#{line['move_type'] == 'out_invoice' and 'type-invoice' or 'type-creditnote'}">
                                        <t t-out="line['type_label']"/>
                                    </span>
                                </td>
                                <td class="txt-right">
                                    <t t-if="line['debit']">
                                        <t t-out="'%.2f' % line['debit']"/>
                                    </t>
                                </td>
                                <td class="txt-right" style="color:#C00000;">
                                    <t t-if="line['credit']">
                                        <t t-out="'%.2f' % line['credit']"/>
                                    </t>
                                </td>
                                <td class="txt-right">
                                    <span t-attf-class="#{line['running_balance'] &lt; 0 and 'bal-negative' or ''}">
                                        <t t-out="'%.2f' % line['running_balance']"/>
                                    </span>
                                </td>
                            </tr>
                        </t>

                        <!-- NET BALANCE row — plain tbody so it renders ONCE at the end only -->
                        <tr class="cs-ledger-total">
                            <td colspan="5" class="txt-right">
                                NET BALANCE DUE (<t t-out="company_info['currency_symbol']"/>)
                            </td>
                            <td class="txt-right"
                                t-attf-style="#{net_balance &lt; 0 and 'color:#FF6B6B;' or ''}">
                                <t t-out="'%.2f' % net_balance"/>
                            </td>
                        </tr>
                    </tbody>
                </table>

                <!-- ── Footer note ── -->
                <p style="font-size:8px;color:#888;margin-top:14px;text-align:center;">
                    This statement reflects all posted invoices and credit notes
                    for the selected period. Debit = Invoice amount outstanding;
                    Credit = Credit note amount. Balance shown is the net payable.
                </p>

            </t>
        </t>
    </template>

    <!-- ── Report Action ── -->
    <record id="customer_report_template_action" model="ir.actions.report">
        <field name="name">Customer Statement Report</field>
        <field name="model">customer.statement.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">tk_statements.customer_report_template</field>
        <field name="report_file">tk_statements.customer_report_template</field>
        <field name="binding_model_id" ref="model_customer_statement_wizard"/>
        <field name="binding_type">report</field>
    </record>
</odoo>
