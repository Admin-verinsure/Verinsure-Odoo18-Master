<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Report invoice template simplified (direct call to custom template) -->
    <template id="report_invoice_inherit" inherit_id="account.report_invoice">
        <xpath expr="//t[@t-call='web.html_container']" position="replace">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <!-- Always use our custom invoice layout -->
                    <t t-call="format_editor.custom_template_report_invoice_modern"
                       t-lang="o.partner_id.lang"/>
                </t>
            </t>
        </xpath>
    </template>
</odoo>
