<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <!-- Override the STANDARD layout’s header only -->
  <template id="external_layout_standard_custom"
            inherit_id="web.external_layout_standard"
            priority="30">
    <!-- The header is the first div under the template root -->
    <xpath expr="/t/div[1]" position="replace">
      <div class="header">
        <div style="text-align:right; margin-bottom:12px;">
          <div style="font-weight:700; font-size:16px;">Rotary Australia World Community Services</div>
          <div>Pty Limited</div>
          <div>25 / 1 Maitland Place</div>
          <div>Norwest NSW 2153</div>
          <div>Australia</div>
        </div>
      </div>
    </xpath>
  </template>
</odoo>
