<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <!-- Replace only the header inside the stock external layout -->
  <template id="external_layout_custom" inherit_id="web.external_layout" priority="20">
    <!-- Target the header container robustly -->
    <xpath expr="//div[contains(concat(' ', normalize-space(@class), ' '), ' header ')]" position="replace">
      <div class="header">
        <div style="text-align:right; margin-bottom:12px;">
          <div style="font-weight:700; font-size:16px;">Rotary Australia World Community Services</div>
          <div>Pty Limited</div>
          <div>25 / 1 Maitland Place</div>
          <div>Norwest NSW 2153</div>
          <div>Australia</div>
        </div>
      </div>
    </xpath>
  </template>
</odoo>
