<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Template to inherit the standard report layout to override only the header -->
    <template id="custom_invoice_header_inheritance" inherit_id="web.external_layout_standard">
        
        <!-- The following xpath expression targets the standard header and replaces it
             with your custom header content. This ensures the rest of the report
             (body and footer) remains untouched. -->
        <xpath expr="//div[@class='header']" position="replace">
            <div class="header">
                <!-- Your custom header content goes here -->
                <table style="width:100%; margin-bottom:20px; border-collapse:collapse;">
                    <tr>
                        <td style="width:50%; vertical-align:top;">
                            <img t-if="o.company_id.logo" t-att-src="image_data_uri(o.company_id.logo)"
                                 style="max-height:80px;" alt="Company Logo"/>
                        </td>
                        <td style="width:50%; text-align:right; vertical-align:top;">
                            <h3 style="margin:0;" t-field="o.company_id.name"/>
                            <div><span t-field="o.company_id.street"/></div>
                            <div><span t-field="o.company_id.city"/> <span t-field="o.company_id.zip"/></div>
                            <div><span t-field="o.company_id.country_id"/></div>
                        </td>
                    </tr>
                </table>
            </div>
        </xpath>
        
    </template>
</odoo>
