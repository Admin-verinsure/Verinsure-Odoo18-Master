<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <template id="custom_template_report_invoice_modern">
    <t t-call="web.external_layout">

      <!-- safe vars -->
      <t t-set="o" t-value="o or doc"/>
      <t t-set="company" t-value="company or (o and o.company_id)"/>

      <!-- hide the external header (no XPath) -->
      <t t-if="company">
        <style type="text/css"><![CDATA[
          .header.o_company_]]><t t-out="company.id"/><![CDATA[_layout{
            display:none !important; height:0 !important; padding:0 !important;
            margin:0 !important; border:0 !important; overflow:hidden !important;
          }
        ]]></style>
      </t>

      <div class="page" style="overflow:hidden;">

        <!-- ===== header in body ===== -->
        <table style="width:100%; margin-bottom:15px; border-collapse:collapse;">
          <tr>
            <td style="width:50%; vertical-align:middle;">
              <img t-if="company and company.logo"
                   t-att-src="image_data_uri(company.logo)"
                   style="max-height:80px;" alt="Company Logo"/>
            </td>
            <td style="width:50%; text-align:right; vertical-align:middle;">
              <div style="margin:0; font-weight:700; font-size:24px;" t-if="company">
                <span t-field="company.name"/>
              </div>
              <div t-if="company and company.country_id" style="font-size:13px;">
                <span t-field="company.country_id"/>
              </div>
            </td>
          </tr>
        </table>
        <hr style="border:1px solid #000; margin:0 0 10px 0;"/>

        <!-- title bar -->
        <div id="custom_title_bar" style="background:#efefef; padding:10px 14px; display:flex; align-items:center; justify-content:space-between; margin-bottom:8px;">
          <div style="font-size:32px; font-weight:700; color:#111;">
            <t t-if="o">
              <t t-if="o.move_type == 'out_invoice'">Invoice</t>
              <t t-elif="o.move_type == 'out_refund'">Refund</t>
              <t t-elif="o.move_type == 'in_invoice'">Vendor&#160;Bill</t>
              <t t-elif="o.move_type == 'in_refund'">Vendor&#160;Refund</t>
              <t t-else="">Invoice</t>
            </t>
          </div>
          <div style="font-weight:700; color:#111;">
            <t t-if="o"><span t-field="o.name"/></t>
          </div>
        </div>

        <!-- ===== remove legacy address + built-in title/info (no XPath) ===== -->
        <style type="text/css"><![CDATA[
          /* 1) In external_layout_standard, web.address_layout is the FIRST child in .article */
          .o_report_layout_standard.article > :first-child,
          .o_report_layout_standard .article > :first-child,
          .article > :first-child { display: none !important; }

          /* 2) Hide the built-in document title <h2> inside .article (external layout) */
          .o_report_layout_standard .article > h2,
          .article > h2:first-of-type { display: none !important; }

          /* 3) Hide the info row that follows that default title (Invoice Date/Due Date/Source/Customer Code) */
          .article > h2:first-of-type + .row,
          .article > h2:first-of-type + div.row,
          .article .o_invoice_info,
          .article [name="invoice_info"] { display: none !important; }

          /* 4) Extra guards across themes/variations */
          .article #informations,
          .article [name="informations"],
          .article [name="partner_address"],
          .article .o_address_format,
          .article .list-unstyled,
          .article .row.mt32.mb32 { display: none !important; }

          /* Ensure OUR title bar stays visible */
          #custom_title_bar * { display: initial !important; }
        ]]></style>

        <!-- ===== NEW address block (LEFT) ===== -->
        <div class="o_custom_billto" style="margin:12px 24px 18px 24px; display:flex; justify-content:flex-start;">
          <div style="max-width:420px; text-align:left; line-height:1.45; font-size:13.5px;">
            <div style="font-weight:700; font-size:15px;">
              <span t-field="o.partner_id.name"/>
            </div>

            <div t-if="o.partner_id.parent_id">
              <span t-field="o.partner_id.parent_id.name"/>
            </div>

            <div t-if="o.partner_id.street"><span t-field="o.partner_id.street"/></div>
            <div t-if="o.partner_id.street2"><span t-field="o.partner_id.street2"/></div>

            <div t-if="o.partner_id.city or o.partner_id.state_id or o.partner_id.zip">
              <t t-if="o.partner_id.city"><span t-field="o.partner_id.city"/></t>
              <t t-if="o.partner_id.state_id"> <span t-field="o.partner_id.state_id"/></t>
              <t t-if="o.partner_id.zip"> <span t-field="o.partner_id.zip"/></t>
            </div>

            <div t-if="o.partner_id.country_id"><span t-field="o.partner_id.country_id"/></div>

            <div t-if="o.partner_id.vat" style="margin-top:4px;">
              <span>Tax ID:&#160;</span><span t-field="o.partner_id.vat"/>
            </div>
          </div>
        </div>

        <!-- ===== render the invoice body ONCE (use caller's inner content) ===== -->
        <t t-out="0"/>

      </div>
    </t>
  </template>
</odoo>
