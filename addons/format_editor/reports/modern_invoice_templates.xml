<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Modern Invoice Template (table-based, PDF safe) -->
    <template id="custom_template_report_invoice_modern">
        <t t-set="o" t-value="o.with_context({'lang': o.partner_id.lang})"/>
        <t t-set="model" t-value="'account.move'"/>
        <t t-set="company" t-value="o.company_id"/>

        <div class="page" style="overflow: hidden; font-family: Arial, sans-serif;">

            <!-- Header with Logo + Company Info -->
            <table style="width:100%; margin-bottom:20px; border-collapse: collapse;">
                <tr>
                    <td style="width:50%; vertical-align:top;">
                        <img t-if="company.logo" t-att-src="image_data_uri(company.logo)"
                             style="max-height:80px;" alt="Company Logo"/>
                    </td>
                    <td style="width:50%; text-align:right; vertical-align:top; color:#000;">
                        <h4 style="margin:0;" t-field="company.name"/>
                        <div><span t-field="company.street"/></div>
                        <div><span t-field="company.city"/> <span t-field="company.zip"/></div>
                        <div><span t-field="company.country_id"/></div>
                    </td>
                </tr>
            </table>

            <!-- Invoice Title -->
            <table style="width:100%; margin-bottom:20px; border-collapse: collapse;">
                <tr>
                    <td style="background-color:#f0f0f0; padding:15px;">
                        <h2 style="margin:0; color:#000;">
                            <span t-if="o.move_type == 'out_invoice' and (o.state == 'draft' or o.state == 'posted')">Invoice</span>
                            <span t-if="o.move_type == 'out_invoice' and o.state == 'proforma2'">Pro-Forma</span>
                            <span t-if="o.move_type == 'out_invoice' and o.state == 'cancel'">Cancelled Invoice</span>
                            <span t-if="o.move_type == 'out_refund'">Refund</span>
                            <span t-if="o.move_type == 'in_refund'">Vendor Refund</span>
                            <span t-if="o.move_type == 'in_invoice'">Vendor Bill</span>
                            <span> </span>
                            <span t-field="o.name"/>
                        </h2>
                    </td>
                </tr>
            </table>

            <!-- Invoice Information -->
            <table style="width:100%; margin-bottom:20px; border-collapse: collapse;">
                <tr>
                    <td style="width:25%;" t-if="o.invoice_date">
                        <strong>Invoice Date:</strong><br/>
                        <span t-field="o.invoice_date"/>
                    </td>
                    <td style="width:25%;" t-if="o.invoice_date_due and o.move_type == 'out_invoice' and o.state == 'posted'">
                        <strong>Due Date:</strong><br/>
                        <span t-field="o.invoice_date_due"/>
                    </td>
                    <td style="width:25%;" t-if="o.invoice_payment_term_id">
                        <strong>Payment Term:</strong><br/>
                        <span t-field="o.invoice_payment_term_id"/>
                    </td>
                    <td style="width:25%;" t-if="o.user_id">
                        <strong>Sales Person:</strong><br/>
                        <span t-field="o.user_id"/>
                    </td>
                </tr>
            </table>

            <!-- Customer Address -->
            <table style="width:100%; margin-bottom:20px; border-collapse: collapse;">
                <tr>
                    <td style="width:50%; color:#000;">
                        <h5>Bill To:</h5>
                        <div><span t-if="o.partner_id" t-field="o.partner_id"/></div>
                        <div><span t-if="o.partner_id.street" t-field="o.partner_id.street"/></div>
                        <div><span t-if="o.partner_id.street2" t-field="o.partner_id.street2"/></div>
                        <div><span t-if="o.partner_id.city" t-field="o.partner_id.city"/></div>
                        <div><span t-if="o.partner_id.country_id" t-field="o.partner_id.country_id"/></div>
                        <div><span t-if="o.partner_id.vat">VAT: <span t-field="o.partner_id.vat"/></span></div>
                    </td>
                </tr>
            </table>

            <!-- Product Table -->
            <table style="width:100%; border-collapse: collapse; margin-bottom:20px;" border="1">
                <thead style="background:#f9f9f9;">
                    <tr>
                        <th>Description</th>
                        <th style="text-align:right;">Quantity</th>
                        <th style="text-align:right;">Unit Price</th>
                        <th style="text-align:right;">Taxes</th>
                        <th style="text-align:right;">Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    <tr t-foreach="o.invoice_line_ids" t-as="line" t-if="not line.display_type or line.display_type == 'product'">
                        <td><span t-field="line.name"/></td>
                        <td style="text-align:right;"><span t-field="line.quantity"/></td>
                        <td style="text-align:right;"><span t-field="line.price_unit"/></td>
                        <td style="text-align:right;"><span t-field="line.tax_ids"/></td>
                        <td style="text-align:right;"><span t-field="line.price_subtotal"/></td>
                    </tr>
                </tbody>
            </table>

            <!-- Totals -->
            <table style="width:40%; margin-left:auto; border-collapse: collapse; margin-bottom:20px;">
                <tr>
                    <td><strong>Total (excl. Tax):</strong></td>
                    <td style="text-align:right;"><span t-field="o.amount_untaxed"/></td>
                </tr>
                <tr>
                    <td><strong>Tax:</strong></td>
                    <td style="text-align:right;"><span t-field="o.amount_tax"/></td>
                </tr>
                <tr style="background:#f0f0f0;">
                    <td><strong>Grand Total:</strong></td>
                    <td style="text-align:right;"><span t-field="o.amount_total"/></td>
                </tr>
            </table>

            <!-- Notes Section -->
            <t t-if="o.invoice_line_ids.filtered(lambda l: l.display_type == 'note')">
                <h5>Notes</h5>
                <div style="white-space: pre-line;">
                    <t t-foreach="o.invoice_line_ids.filtered(lambda l: l.display_type == 'note')" t-as="note_line">
                        <p t-field="note_line.name"/>
                    </t>
                </div>
            </t>
            <t t-if="o.narration">
                <h5>Additional Information</h5>
                <div style="white-space: pre-line;" t-field="o.narration"/>
            </t>

            <!-- Footer -->
            <div style="margin-top:40px; padding-top:10px; border-top:1px solid #ccc; font-size:12px; color:#666; text-align:center;">
                <span t-if="company.report_footer" t-field="company.report_footer"/>
            </div>

        </div>
    </template>
</odoo>
