<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Modern Invoice Template with Custom Header -->
    <template id="custom_template_report_invoice_modern">
        <!-- Use external layout -->
        <t t-call="web.external_layout">
            
            <!-- Set invoice object -->
            <t t-set="o" t-value="doc"/>
            
            <!-- PAGE START -->
            <div class="page">
                
                <!-- === Custom Header === -->
                <div class="header o_custom_header" style="background-color:#f2f2f2;padding:10px;">
                    <div class="row">
                        <div class="col-6">
                            <h2 style="margin:0;color:#000;">
                                <span t-if="o.move_type == 'out_invoice'">Invoice</span>
                                <span t-if="o.move_type == 'out_refund'">Refund</span>
                                <span t-if="o.move_type == 'in_invoice'">Vendor Bill</span>
                                <span t-if="o.move_type == 'in_refund'">Vendor Refund</span>
                            </h2>
                        </div>
                        <div class="col-6 text-end">
                            <span t-field="o.name" style="font-weight:bold;"/>
                        </div>
                    </div>
                </div>
                
                <!-- === Original Invoice Content === -->
                <t t-call="account.report_invoice_document"/>
                
            </div>
            <!-- PAGE END -->
            
        </t>
    </template>
</odoo>
