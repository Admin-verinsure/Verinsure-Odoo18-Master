<odoo>
<!-- 1) Replace only the header in the base external layout -->
<template id="external_layout_standard_header_custom"
            inherit_id="web.external_layout_standard"
            priority="90">
<!-- The header you showed is created with a dynamic t-attf-class, so match safely -->
<xpath expr="//div[contains(@t-attf-class, 'header o_company_')]" position="replace">
<div t-attf-class="header o_company_#{company.id}_layout" t-att-style="report_header_style">
<!-- your custom header markup -->
<div class="row">
<div class="col-6">
<img t-if="company.logo" class="o_company_logo_big"
                 t-att-src="image_data_uri(company.logo)" alt="Logo"/>
<h3 class="mt-2">Custom Header</h3>
</div>
<div class="col-6 text-end">
<div t-field="company.company_details"/>
<t t-if="company.vat or forced_vat">
<div>
<t t-esc="company.country_id.vat_label or 'Tax ID'"/>:
<span t-esc="forced_vat or company.vat"/>
</div>
</t>
</div>
</div>
</div>
</xpath>
</template>
</odoo>