<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Template to inherit the standard invoice document to override only the header -->
    <template id="custom_invoice_header_inheritance" inherit_id="account.report_invoice_document">
        
        <!-- The following xpath expression correctly targets the header div from the inherited
             template, ensuring only the header is modified while the rest of the report
             remains untouched. This is more robust than targeting a generic table. -->
        <xpath expr="//div[contains(@class, 'header')]" position="replace">
            <!-- Your custom header content goes here -->
            <div class="header">
                <table style="width:100%; margin-bottom:20px; border-collapse:collapse;">
                    <tr>
                        <td style="width:50%; vertical-align:top;">
                            <img t-if="o.company_id.logo" t-att-src="image_data_uri(o.company_id.logo)"
                                 style="max-height:80px;" alt="Company Logo"/>
                        </td>
                        <td style="width:50%; text-align:right; vertical-align:top;">
                            <h3 style="margin:0;" t-field="o.company_id.name"/>
                            <div><span t-field="o.company_id.street"/></div>
                            <div><span t-field="o.company_id.city"/> <span t-field="o.company_id.zip"/></div>
                            <div><span t-field="o.company_id.country_id"/></div>
                        </td>
                    </tr>
                </table>
            </div>
        </xpath>
        
    </template>
</odoo>
