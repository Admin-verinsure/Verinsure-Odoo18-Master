<odoo>
<!-- Odoo 15–17 often uses web.external_layout or web.external_layout_standard.
       Pick the one your DB has (check in Debug: Technical > User Interface > Views). -->
<template id="external_layout_inherit"
            inherit_id="web.external_layout_standard">  <!-- or web.external_layout -->
<!-- Replace the entire header block -->
<xpath expr="//div[contains(@class,'header')]" position="replace">
<div t-attf-class="header o_company_#{company.id}_layout" t-att-style="report_header_style">
<div class="row">
<div class="col-6">
<!-- Your custom logo / banner / whatever -->
<img t-if="company.logo" class="o_company_logo_big"
                 t-att-src="image_data_uri(company.logo)" alt="Logo"/>
<!-- Example: secondary tagline -->
<div t-if="company.report_header" class="fw-bold mt-1" t-esc="company.report_header"/>
</div>
 
          <div class="col-6 text-end">
<!-- Example: simplified address & Tax ID -->
<t t-if="not company.is_company_details_empty">
<div t-field="company.company_details"/>
</t>
<t t-if="company.vat or forced_vat">
<div>
<t t-esc="company.country_id.vat_label or 'Tax ID'"/>:
<span t-esc="forced_vat or company.vat"/>
</div>
</t>
</div>
</div>
</div>
</xpath>
</template>
</odoo>