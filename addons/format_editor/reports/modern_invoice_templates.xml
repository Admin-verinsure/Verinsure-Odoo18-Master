<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================= -->
    <!-- Custom External Layout Wrapper -->
    <!-- ============================= -->
    <template id="custom_external_layout_invoice" name="Custom External Layout Invoice">
        <!-- Call the original external layout -->
        <t t-call="web.external_layout_standard">
            
            <!-- Custom header injected here -->
            <t t-set="header_content">
                <div class="o_custom_header" style="background-color:#f0f0f0;padding:10px;text-align:center;">
                    <h2 style="margin:0;color:#333;">
                        <span t-if="o.move_type == 'out_invoice'">Invoice</span>
                        <span t-if="o.move_type == 'out_refund'">Refund</span>
                        <span t-if="o.move_type == 'in_invoice'">Vendor Bill</span>
                        <span t-if="o.move_type == 'in_refund'">Vendor Refund</span>
                        <span t-if="o.state == 'draft'">(Draft)</span>
                        <br/>
                        <span t-field="o.name"/>
                    </h2>
                </div>
            </t>

            <!-- Render custom header -->
            <t t-raw="header_content"/>
        </t>
    </template>

    <!-- ========================================= -->
    <!-- Invoice Report Template Using Wrapper Layout -->
    <!-- ========================================= -->
    <template id="report_invoice_custom" inherit_id="account.report_invoice">
        <t t-set="o" t-value="doc"/>
        <t t-call="format_editor.custom_external_layout_invoice"/>
    </template>

</odoo>
