<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Modern Invoice Template -->
    <template id="custom_template_report_invoice_modern">
        <t t-call="web.external_layout">
            <t t-set="o" t-value="o.with_context({'lang': o.partner_id.lang})"/>
            <t t-set="model" t-value="'account.move'"/>

            <div class="page" style="overflow: hidden;">

                <!-- ===== Invoice Header ===== -->
                <div class="row" style="margin-top:20px;">
                    <div style="background-color:#f0f0f0; padding:2%; color:#000;">
                        <h2 style="color:#000;">
                            <span t-if="o.move_type == 'out_invoice' and (o.state == 'draft' or o.state == 'posted')">Invoice</span>
                            <span t-if="o.move_type == 'out_invoice' and o.state == 'proforma2'">Pro-forma</span>
                            <span t-if="o.move_type == 'out_invoice' and o.state == 'cancel'">Cancelled Invoice</span>
                            <span t-if="o.move_type == 'out_refund'">Refund</span>
                            <span t-if="o.move_type == 'in_refund'">Vendor Refund</span>
                            <span t-if="o.move_type == 'in_invoice'">Vendor Bill</span>
                            <span> - <span t-field="o.name"/></span>
                        </h2>
                    </div>
                </div>

                <!-- ===== Invoice Information ===== -->
                <div id="invoice_information" class="mt32 mb32">
                    <div class="row">
                        <div class="col-3" t-if="o.invoice_date">
                            <strong>Invoice Date:</strong>
                            <p class="m-0" t-field="o.invoice_date"/>
                        </div>
                        <div class="col-3" t-if="o.invoice_date_due and o.move_type == 'out_invoice' and o.state == 'posted'">
                            <strong>Due Date:</strong>
                            <p class="m-0" t-field="o.invoice_date_due"/>
                        </div>
                        <div class="col-3" t-if="o.invoice_payment_term_id">
                            <strong>Payment Term:</strong>
                            <p class="m-0" t-field="o.invoice_payment_term_id"/>
                        </div>
                        <div class="col-3" t-if="o.user_id">
                            <strong>Sales Person:</strong>
                            <p class="m-0" t-field="o.user_id"/>
                        </div>
                        <div class="col-3" t-if="o.ref">
                            <strong>Customer Reference:</strong>
                            <p class="m-0" t-field="o.ref"/>
                        </div>
                        <div class="col-3" t-if="o.source_id">
                            <strong>Source:</strong>
                            <p class="m-0" t-field="o.source_id"/>
                        </div>
                    </div>
                </div>

                <!-- ===== Customer Address ===== -->
                <div id="customer_address" class="mb32">
                    <div class="row">
                        <div class="col-6">
                            <div itemprop="address" class="address">
                                <div><span t-if="o.partner_id" t-field="o.partner_id"/></div>
                                <div><span t-if="o.partner_id.street" t-field="o.partner_id.street"/></div>
                                <div><span t-if="o.partner_id.street2" t-field="o.partner_id.street2"/></div>
                                <div><span t-if="o.partner_id.city" t-field="o.partner_id.city"/></div>
                                <div><span t-if="o.partner_id.country_id" t-field="o.partner_id.country_id"/></div>
                                <div><span t-if="o.partner_id.vat" t-field="o.partner_id.vat"/></div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ===== Product Table ===== -->
                <div class="row">
                    <div class="col-12">
                        <table class="table table-sm o_main_table" style="width:100%; border:1px solid #000;">
                            <thead>
                                <tr style="background-color:#e0e0e0; color:#000;">
                                    <th>Description</th>
                                    <th class="text-end">Quantity</th>
                                    <th class="text-end">Unit Price</th>
                                    <th class="text-end">Taxes</th>
                                    <th class="text-end">Subtotal</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="o.invoice_line_ids" t-as="line">
                                    <td>
                                        <span t-field="line.name"/>
                                        <span t-if="line.product_id"> - <span t-field="line.product_id.display_name"/></span>
                                    </td>
                                    <td class="text-end">
                                        <span t-field="line.quantity"/>
                                        <span t-if="line.product_uom_id">
                                            <span t-field="line.product_uom_id.name"/>
                                        </span>
                                    </td>
                                    <td class="text-end">
                                        <span t-field="line.price_unit"/>
                                    </td>
                                    <td class="text-end">
                                        <span t-esc="', '.join(line.tax_ids.mapped('name'))"/>
                                    </td>
                                    <td class="text-end">
                                        <span t-field="line.price_subtotal"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- ===== Totals ===== -->
                <div class="row mt32">
                    <div class="col-6"/>
                    <div class="col-6">
                        <table class="table table-sm" style="width:100%;">
                            <tbody>
                                <tr t-foreach="o.amount_by_group" t-as="amount_by_group">
                                    <td><span t-esc="amount_by_group[0]"/></td>
                                    <td class="text-end"><span t-esc="amount_by_group[1]"/></td>
                                </tr>
                                <tr>
                                    <td><strong>Total</strong></td>
                                    <td class="text-end"><strong t-field="o.amount_total"/></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>
        </t>
    </template>
</odoo>
