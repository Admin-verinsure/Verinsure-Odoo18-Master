<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <!-- Override external layout to remove default header -->
  <template id="custom_external_layout_no_header"
            inherit_id="web.external_layout_standard"
            name="External Layout Without Header">
    <xpath expr="//div[contains(@class,'header')]" position="replace">
      <!-- Empty header -->
      <div class="header"/>
    </xpath>
  </template>

  <!-- Your custom modern invoice template -->
  <template id="custom_template_report_invoice_modern">
    <t t-call="custom_external_layout_no_header">
      <t t-set="o" t-value="o or doc"/>
      <t t-set="company" t-value="company or (o and o.company_id)"/>

      <div class="page" style="overflow:hidden;">

        <!-- Custom header now inside body -->
        <div class="o_custom_header" style="padding:0 24px 8px 24px;">
          <table style="width:100%; margin-bottom:20px; border-collapse:collapse;">
            <tr>
              <td style="width:50%; vertical-align:top;">
                <img t-if="company and company.logo"
                     t-att-src="image_data_uri(company.logo)"
                     style="max-height:80px;" alt="Company Logo"/>
              </td>
              <td style="width:50%; text-align:right; vertical-align:top;">
                <h3 style="margin:0;" t-if="company" t-field="company.name"/>
                <div t-if="company and company.street"><span t-field="company.street"/></div>
                <div t-if="company and (company.city or company.zip)">
                  <span t-field="company.city"/> <span t-field="company.zip"/>
                </div>
                <div t-if="company and company.country_id"><span t-field="company.country_id"/></div>
              </td>
            </tr>
          </table>

          <div style="background:#efefef; padding:10px 14px; display:flex; align-items:center; justify-content:space-between;">
            <div style="font-size:32px; font-weight:700; color:#111;">
              <t t-if="o">
                <t t-if="o.move_type == 'out_invoice'">Invoice</t>
                <t t-elif="o.move_type == 'out_refund'">Refund</t>
                <t t-elif="o.move_type == 'in_invoice'">Vendor Bill</t>
                <t t-elif="o.move_type == 'in_refund'">Vendor Refund</t>
                <t t-else="">Invoice</t>
              </t>
            </div>
            <div style="font-weight:700; color:#111;">
              <t t-if="o"><span t-field="o.name"/></t>
            </div>
          </div>
        </div>

        <!-- Continue with normal invoice content -->
        <t t-call="account.report_invoice_document"/>
      </div>
    </t>
  </template>
</odoo>
