<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Custom Invoice Template with Header Override -->
    <template id="custom_template_report_invoice_header">
        <!-- Call the older safe external layout -->
        <t t-call="web.external_layout">
            
            <!-- Set invoice object -->
            <t t-set="o" t-value="o.with_context({'lang': o.partner_id.lang})"/>
            <t t-set="model" t-value="'account.move'"/>

            <div class="page" style="overflow: hidden;">

                <!-- ===== Custom Header ===== -->
                <div class="header o_custom_header" 
                     style="background-color:#F5F5F5; padding:2%; color:#000;">
                    <h2>
                        <span t-if="o.move_type == 'out_invoice'">Invoice</span>
                        <span t-if="o.move_type == 'out_refund'">Refund</span>
                        <span t-if="o.move_type == 'in_invoice'">Vendor Bill</span>
                        <span t-if="o.move_type == 'in_refund'">Vendor Refund</span>
                        <span t-if="o.state == 'draft'">(Draft)</span>
                        <br/>
                        <span t-field="o.name"/>
                    </h2>
                </div>
                <!-- ===== End Custom Header ===== -->

                <!-- ===== Rest of Invoice Content ===== -->
                <t t-raw="0"/>
                <!-- You can include the body blocks from your older template here -->
                <!-- For example, invoice info, customer address, product table, totals, etc. -->

            </div>
        </t>
    </template>
</odoo>
