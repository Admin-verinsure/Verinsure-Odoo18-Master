<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <template id="custom_template_report_invoice_modern">
    <t t-call="web.external_layout">

      <!-- Make o / company safe -->
      <t t-set="o" t-value="o or doc"/>
      <t t-set="company" t-value="company or (o and o.company_id)"/>

      <!-- Kill ONLY the standard external header (no XPath, CSS-only) -->
      <t t-if="company">
        <style type="text/css">
          /* Hide external layout header for this company only */
          .header.o_company_<t t-out="company.id"/>_layout{
            display:none !important; height:0 !important; padding:0 !important;
            margin:0 !important; border:0 !important; overflow:hidden !important;
          }
        </style>
      </t>

      <div class="page" style="overflow:hidden;">

        <!-- Your header moved into the BODY (note: no class="header") -->
        <div class="o_custom_header" style="padding:0 24px 8px 24px;">
          <table style="width:100%; margin-bottom:20px; border-collapse:collapse;">
            <tr>
              <td style="width:50%; vertical-align:top;">
                <img t-if="company and company.logo"
                     t-att-src="image_data_uri(company.logo)"
                     style="max-height:80px;" alt="Company Logo"/>
              </td>
              <td style="width:50%; text-align:right; vertical-align:top;">
                <h3 style="margin:0;" t-if="company" t-field="company.name"/>
                <div t-if="company and company.street"><span t-field="company.street"/></div>
                <div t-if="company and (company.city or company.zip)">
                  <span t-field="company.city"/> <span t-field="company.zip"/>
                </div>
                <div t-if="company and company.country_id"><span t-field="company.country_id"/></div>
              </td>
            </tr>
          </table>

          <!-- Grey title bar -->
          <div style="background:#efefef; padding:10px 14px; display:flex; align-items:center; justify-content:space-between;">
            <div style="font-size:32px; font-weight:700; color:#111;">
              <t t-if="o">
                <t t-if="o.move_type == 'out_invoice'">Invoice</t>
                <t t-elif="o.move_type == 'out_refund'">Refund</t>
                <t t-elif="o.move_type == 'in_invoice'">Vendor&#160;Bill</t>
                <t t-elif="o.move_type == 'in_refund'">Vendor&#160;Refund</t>
                <t t-else="">Invoice</t>
              </t>
            </div>
            <div style="font-weight:700; color:#111;">
              <t t-if="o"><span t-field="o.name"/></t>
            </div>
          </div>
        </div>
<!-- Address styling fixes (no XPath) -->
<style type="text/css">
  /* Scope to report body only */
  .o_report_layout, .o_report_layout_standard, .o_table_standard {
    /* nothing */
  }

  /* Standard contact widget containers */
  .o_report_layout .address,
  .o_report_layout .o_address_format {
    text-align: right;          /* keep right alignment as in your layout */
    line-height: 1.4;           /* tighter, consistent line height */
    font-size: 13.5px;          /* slightly smaller for multi-line names */
    word-break: normal;         /* avoid aggressive breaking */
    overflow-wrap: anywhere;    /* but still prevent overflow if needed */
    hyphens: manual;            /* no auto-hyphenation weirdness */
  }

  /* Remove extra gaps that sometimes appear between lines/spans */
  .o_report_layout .o_address_format div,
  .o_report_layout .o_address_format span {
    margin: 0 !important;
    padding: 0 !important;
  }

  /* Name bolder, but not oversized */
  .o_report_layout .o_address_format .o_name,
  .o_report_layout .o_address_format .name,
  .o_report_layout .address .name {
    font-weight: 600;
    font-size: 14px;
    display: block;
    margin-bottom: 2px;
  }

  /* Tidy each line’s spacing */
  .o_report_layout .o_address_format br {
    line-height: 1.3;
  }

  /* Kill empty spans that produce blank lines */
  .o_report_layout .o_address_format span:empty,
  .o_report_layout .address span:empty {
    display: none !important;
  }

  
  .o_report_layout .row.mt32.mb32 .col-6:last-child {
    padding-left: 24px;
  }
</style>

        <!-- Standard invoice body (addresses, lines, totals, etc.) -->
        <t t-call="account.report_invoice_document"/>

      </div>
    </t>
  </template>
</odoo>
