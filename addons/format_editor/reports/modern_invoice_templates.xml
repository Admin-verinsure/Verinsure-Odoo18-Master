<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Override external layout to remove extra company name -->
    <template id="custom_external_layout" inherit_id="web.external_layout_standard">
        <xpath expr="//div[contains(@class,'header')]" position="replace">
            <div class="header">
                <div class="text-center">
                    <img t-if="company.logo" t-att-src="image_data_uri(company.logo)" 
                         style="max-height:80px;" alt="Company Logo"/>
                </div>
            </div>
        </xpath>
    </template>

    <!-- Modern Invoice Template -->
    <template id="custom_template_report_invoice_modern">
        <t t-call="web.external_layout">
            <t t-set="o" t-value="o.with_context({'lang': o.partner_id.lang})"/>
            <t t-set="company" t-value="o.company_id"/>

            <div class="page" style="font-family: 'DejaVu Sans', sans-serif;">

                <!-- Invoice Title -->
                <h2 style="background:#f0f0f0; padding:10px;">
                    <span t-if="o.move_type == 'out_invoice' and (o.state in ['draft','posted'])">Invoice</span>
                    <span t-if="o.move_type == 'out_invoice' and o.state == 'proforma2'">Pro-Forma</span>
                    <span t-if="o.move_type == 'out_invoice' and o.state == 'cancel'">Cancelled Invoice</span>
                    <span t-if="o.move_type == 'out_refund'">Refund</span>
                    <span t-if="o.move_type == 'in_refund'">Vendor Refund</span>
                    <span t-if="o.move_type == 'in_invoice'">Vendor Bill</span>
                    <span> </span>
                    <span t-field="o.name"/>
                </h2>

                <!-- Invoice Info -->
                <table style="width:100%; margin-bottom:20px;">
                    <tr>
                        <td t-if="o.invoice_date"><strong>Date:</strong> <span t-field="o.invoice_date"/></td>
                        <td t-if="o.invoice_date_due"><strong>Due:</strong> <span t-field="o.invoice_date_due"/></td>
                        <td t-if="o.invoice_payment_term_id"><strong>Payment Term:</strong> <span t-field="o.invoice_payment_term_id"/></td>
                        <td t-if="o.user_id"><strong>Salesperson:</strong> <span t-field="o.user_id"/></td>
                    </tr>
                </table>

                <!-- Customer -->
                <h5>Bill To:</h5>
                <div><span t-field="o.partner_id"/></div>
                <div><span t-field="o.partner_id.street"/></div>
                <div><span t-field="o.partner_id.city"/> <span t-field="o.partner_id.zip"/></div>
                <div><span t-field="o.partner_id.country_id"/></div>
                <div><span t-if="o.partner_id.vat">VAT: <span t-field="o.partner_id.vat"/></span></div>

                <!-- Product Table -->
                <table style="width:100%; margin-top:20px;" border="1">
                    <thead style="background:#f9f9f9;">
                        <tr>
                            <th>Description</th>
                            <th style="text-align:right;">Qty</th>
                            <th style="text-align:right;">Unit Price</th>
                            <th style="text-align:right;">Taxes</th>
                            <th style="text-align:right;">Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr t-foreach="o.invoice_line_ids" t-as="line"
                            t-if="not line.display_type or line.display_type == 'product'">
                            <td><span t-field="line.name"/></td>
                            <td style="text-align:right;"><span t-field="line.quantity"/></td>
                            <td style="text-align:right;">
                                <span t-field="line.price_unit"
                                      t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                            </td>
                            <td style="text-align:right;"><span t-field="line.tax_ids"/></td>
                            <td style="text-align:right;">
                                <span t-field="line.price_subtotal"
                                      t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                            </td>
                        </tr>
                    </tbody>
                </table>

                <!-- Totals -->
                <table style="width:40%; margin-left:auto; margin-top:20px;">
                    <tr>
                        <td><strong>Total (excl. Tax):</strong></td>
                        <td style="text-align:right;">
                            <span t-field="o.amount_untaxed"
                                  t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                        </td>
                    </tr>
                    <tr>
                        <td><strong>Tax:</strong></td>
                        <td style="text-align:right;">
                            <span t-field="o.amount_tax"
                                  t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                        </td>
                    </tr>
                    <tr style="background:#f0f0f0;">
                        <td><strong>Grand Total:</strong></td>
                        <td style="text-align:right;">
                            <span t-field="o.amount_total"
                                  t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                        </td>
                    </tr>
                </table>

                <!-- Notes (grouped properly) -->
                <t t-set="note_lines" t-value="o.invoice_line_ids.filtered(lambda l: l.display_type == 'note')"/>
                <t t-if="note_lines">
                    <h5>Notes</h5>
                    <div style="white-space: pre-line;">
                        <t t-foreach="note_lines" t-as="note_line">
                            <p t-field="note_line.name"/>
                        </t>
                    </div>
                </t>

                <!-- Additional Info -->
                <t t-if="o.narration">
                    <h5>Additional Information</h5>
                    <div style="white-space: pre-line;" t-field="o.narration"/>
                </t>

                <!-- Footer -->
                <div style="margin-top:40px; padding-top:10px; border-top:1px solid #ccc;
                            font-size:12px; color:#666; text-align:center;">
                    <span t-if="company.report_footer" t-field="company.report_footer"/>
                </div>

            </div>
        </t>
    </template>
</odoo>
