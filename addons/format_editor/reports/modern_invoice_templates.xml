<template id="custom_template_report_invoice_modern">
    <t t-call="web.external_layout">
        <t t-set="o" t-value="o.with_context({'lang':o.partner_id.lang})"/>
        <t t-set="model" t-value="'account.move'"/>

        <div class="page">

            <!-- Header with logo + company name -->
            <table style="width:100%; margin-bottom:20px; border-collapse:collapse;">
                <tr>
                    <td style="width:50%; vertical-align:top;">
                        <img t-if="company.logo"
                             t-att-src="image_data_uri(company.logo)"
                             style="max-height:80px;" alt="Company Logo"/>
                    </td>
                    <td style="width:50%; text-align:right; vertical-align:top;">
                        <h3 style="margin:0;" t-field="company.name"/>
                        <div><span t-field="company.street"/></div>
                        <div><span t-field="company.city"/> <span t-field="company.zip"/></div>
                        <div><span t-field="company.country_id"/></div>
                    </td>
                </tr>
            </table>

            <hr style="margin: 10px 0;"/>

            <!-- Invoice title + number -->
            <div style="background:#f2f2f2; padding:10px; margin-bottom:20px;">
                <h2 style="margin:0; display:inline-block;">Invoice</h2>
                <span style="float:right; font-weight:bold;" t-field="o.name"/>
            </div>

            <!-- Customer address on LEFT -->
            <div style="margin-bottom:20px;">
                <h4>Bill To:</h4>
                <div class="address" style="line-height:1.5;">
                    <span t-field="o.partner_id.name"/><br/>
                    <span t-field="o.partner_id.street"/><br/>
                    <span t-field="o.partner_id.city"/> <span t-field="o.partner_id.zip"/><br/>
                    <span t-field="o.partner_id.country_id"/>
                </div>
            </div>

            <!-- Rest of invoice body -->
            <t t-raw="0"/>

        </div>
    </t>
</template>
