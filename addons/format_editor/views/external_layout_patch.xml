<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Patch to remove document_layout_id (not available in your db) -->
    <template id="external_layout_bold_patch" inherit_id="web.external_layout_bold">
        
        <!-- Replace the problematic company logo container -->
        <xpath expr="//div[@style='width:50%;']" position="replace">
            <!-- Force it to always align left -->
            <div style="width:50%;" class="d-flex justify-content-start"/>
        </xpath>

    </template>
</odoo>
