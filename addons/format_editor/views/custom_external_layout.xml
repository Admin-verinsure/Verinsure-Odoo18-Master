<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <template id="report_invoice_document_use_custom_layout"
            inherit_id="account.report_invoice_document"
            priority="40">
    <xpath expr="//t[@t-call='web.external_layout']" position="attributes">
      <attribute name="t-call">your_module_name.external_layout_standard_custom</attribute>
    </xpath>
  </template>
</odoo>
