<odoo>
  <data>
    <record id="res_partner_toggle_org_membership" model="ir.ui.view">
      <field name="name">res.partner: toggle Membership/Org tabs by company_type</field>
      <field name="model">res.partner</field>
      <field name="inherit_id" ref="base.view_partner_form"/>
      <!-- ensure we run after membership & rotary views -->
      <field name="priority">999</field>
      <field name="arch" type="xml">

        <!-- Hide MEMBERSHIP for Companies -->
        <xpath expr="//page[@name='membership']" position="attributes">
          <attribute name="invisible">[('company_type', '=', 'company')]</attribute>
        </xpath>

        <!-- Hide ROTARY ORG INFO for Individuals
             We don't rely on @string or exact @name; we anchor by fields that tab contains. -->
        <xpath expr="//page[
                        .//field[contains(@name,'rotary')]
                        or .//field[contains(@name,'club')]
                        or .//field[contains(@name,'district')]
                     ]"
               position="attributes">
          <attribute name="invisible">[('company_type', '=', 'person')]</attribute>
        </xpath>

      </field>
    </record>
  </data>
</odoo>
