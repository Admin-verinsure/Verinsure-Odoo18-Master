<odoo>
  <data>

    <!-- FINAL, HIGH-PRIORITY OVERRIDES ON THE PAGES THEMSELVES -->

    <!-- Membership: VISIBLE for Individuals, HIDDEN for Companies -->
    <record id="final_fix_membership_visibility" model="ir.ui.view">
      <field name="name">res.partner: membership visible for individuals</field>
      <field name="model">res.partner</field>
      <!-- inherit the view that DEFINES the membership page -->
      <field name="inherit_id" ref="membership.view_partner_form"/>
      <!-- win over everything else -->
      <field name="priority">100000</field>
      <field name="arch" type="xml">
        <xpath expr="//page[@name='membership']" position="attributes">
          <!-- Odoo 17/18 expression (no attrs/states) -->
          <attribute name="invisible">is_company or company_type == 'company'</attribute>
        </xpath>
      </field>
    </record>

    <!-- Org Info: VISIBLE for Companies, HIDDEN for Individuals -->
    <record id="final_fix_orginfo_visibility" model="ir.ui.view">
      <field name="name">res.partner: org info visible for companies</field>
      <field name="model">res.partner</field>
      <!-- inherit the Rotary view that DEFINES the org tab -->
      <field name="inherit_id" ref="rotary_project_map.view_partner_form_inherit_club_type"/>
      <field name="priority">100000</field>
      <field name="arch" type="xml">
        <!-- exact technical name from your server file -->
        <xpath expr="//page[@name='club_information']" position="attributes">
          <!-- HIDE on Individuals -->
          <attribute name="invisible">not is_company or company_type == 'person'</attribute>
        </xpath>
      </field>
    </record>

  </data>
</odoo>
