<odoo>
  <data>
    <record id="res_partner_hide_tabs_by_type" model="ir.ui.view">
      <field name="name">res.partner: hide Membership/Org tabs by partner type</field>
      <field name="model">res.partner</field>
      <field name="inherit_id" ref="base.view_partner_form"/>
      <!-- run after the views that add the tabs -->
      <field name="priority">200</field>

      <field name="arch" type="xml">

        <!-- MEMBERSHIP: hide only for Companies -->
        <xpath expr="//page[@name='membership']" position="attributes">
          <attribute name="attrs">
            {'invisible': [('company_type', '=', 'company')]}
          </attribute>
        </xpath>

        <!-- ORG INFO: hide only for Individuals -->
        <!-- Replace/add the exact technical name of your Org tab if different -->
        <xpath expr="//page[@name='rotary_org_info' or @name='org_info']" position="attributes">
          <attribute name="attrs">
            {'invisible': [('company_type', '=', 'person')]}
          </attribute>
        </xpath>

      </field>
    </record>
  </data>
</odoo>
